{% extends 'base.html.twig' %}

{% block title %}Modifier le Projet - Champions{% endblock %}

{% block body %}
<section class="py-5" style="background-color: #f8f9fa; min-height: 90vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                
                {# Bouton Retour style Dashboard #}
                <div class="mb-4">
                    <a href="{{ path('app_credit_index') }}" class="text-decoration-none text-primary fw-bold">
                        <i class="fas fa-arrow-left me-2"></i>Retour à la liste
                    </a>
                </div>

                <div class="card-header p-4 d-flex align-items-center justify-content-between" style="background: #343a40; border-bottom: none;">
    <div class="d-flex align-items-center">
        {# Icône avec fond violet circulaire #}
        <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px; background-color: #6f42c1;">
            <i class="fas fa-hand-holding-usd text-white"></i>
        </div>
        <div>
            {# Texte forcé en BLANC #}
            <h2 class="h3 mb-0 fw-bold text-white">Modifier le Crédit 🚀</h2>
            <p class="mb-0 small text-white-50">Mettez à jour les informations du projet "{{ credit.projet.title }}"</p>
        </div>
    </div>
</div>

                    <div class="card-body p-4 p-md-5">
                        {# Message d'erreur Symfony si besoin #}
                        {% if not form.vars.valid %}
                            <div class="alert alert-danger border-0 rounded-4 mb-4">
                                <i class="fas fa-times-circle me-2"></i>Veuillez vérifier les champs en rouge ci-dessous.
                            </div>
                        {% endif %}

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                            
                            <h5 class="fw-bold mb-4" style="color: #495057;">Informations de Financement</h5>
                            
                            <div class="row g-4">
                                {# Sélection du Projet #}
                                <div class="col-12">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-rocket me-2 text-primary" style="color: #6f42c1 !important;"></i>SÉLECTIONNER LE PROJET
                                    </label>
                                    {{ form_widget(form.projet, {'attr': {'class': 'form-select p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px;'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.projet) }}</div>
                                </div>

                                {# Montant et Devise #}
                                <div class="col-md-7">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-money-bill-wave me-2 text-primary" style="color: #6f42c1 !important;"></i>MONTANT DU PRÊT
                                    </label>
                                    <div class="input-group">
                                        {{ form_widget(form.montant, {'attr': {'class': 'form-control p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px 0 0 12px;'}}) }}
                                        <span class="input-group-text bg-light border-light-subtle px-4" style="border-radius: 0 12px 12px 0;">DT</span>
                                    </div>
                                    <div class="text-danger small mt-1">{{ form_errors(form.montant) }}</div>
                                </div>

                                <div class="col-md-5">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-globe me-2 text-primary" style="color: #6f42c1 !important;"></i>DEVISE
                                    </label>
                                    {{ form_widget(form.devise, {'attr': {'class': 'form-select p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px;'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.devise) }}</div>
                                </div>

                                {# Taux et Durée #}
                                <div class="col-md-6">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-percentage me-2 text-primary" style="color: #6f42c1 !important;"></i>TAUX D'INTÉRÊT (%)
                                    </label>
                                    {{ form_widget(form.taux, {'attr': {'class': 'form-control p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px;', 'placeholder': 'Ex: 2.5'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.taux) }}</div>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-calendar-alt me-2 text-primary" style="color: #6f42c1 !important;"></i>DURÉE (EN MOIS)
                                    </label>
                                    {{ form_widget(form.duree, {'attr': {'class': 'form-control p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px;', 'placeholder': 'Nombre de mois'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.duree) }}</div>
                                </div>

                                {# Description #}
                                <div class="col-12">
                                    <label class="form-label text-uppercase fw-bold small text-muted">
                                        <i class="fas fa-align-left me-2 text-primary" style="color: #6f42c1 !important;"></i>DESCRIPTION
                                    </label>
                                    {{ form_widget(form.description, {'attr': {'class': 'form-control p-3 border-light-subtle bg-light', 'style': 'border-radius: 12px;', 'rows': '4', 'placeholder': 'Détails de la modification...'}}) }}
                                    <div class="text-danger small mt-1">{{ form_errors(form.description) }}</div>
                                </div>
                            </div>

                            {# Boutons Actions style Champions #}
                            <div class="mt-5 d-flex flex-column flex-md-row gap-3">
                                <button type="submit" class="btn btn-primary flex-grow-1 py-3 fw-bold shadow-sm" style="background: #7a48d6; border: none; border-radius: 12px; font-size: 1.1rem;">
                                    <i class="fas fa-paper-plane me-2"></i>METTRE À JOUR LA DEMANDE
                                </button>
                                <a href="{{ path('app_credit_index') }}" class="btn btn-light py-3 px-5 fw-bold text-muted border border-light-subtle" style="border-radius: 12px;">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>
                            </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Effet Focus identique à ton screen */
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        border-color: #7a48d6 !important;
        box-shadow: 0 0 0 0.25rem rgba(122, 72, 214, 0.1) !important;
    }
    
    .btn-primary:hover {
        background: #6236b5 !important;
        transform: translateY(-2px);
        transition: all 0.2s ease;
    }
</style>
{% endblock %}