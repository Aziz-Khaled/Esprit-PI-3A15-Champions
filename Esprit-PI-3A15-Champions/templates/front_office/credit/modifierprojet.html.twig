{# templates/front_office/credit/modifierprojet.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier Projet - {{ projet.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    {# Retour à la liste #}
    <div class="mb-4">
        <a href="{{ path('app_projet_index') }}" class="text-decoration-none fw-bold" style="color: #8b5cf6; transition: 0.3s;">
            <i class="fas fa-chevron-left me-2"></i> Annuler et retourner à la liste
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg" style="border-radius: 25px; overflow: hidden;">
                
                {# En-tête avec dégradé pro #}
                <div class="p-4 text-white d-flex justify-content-between align-items-center" 
                     style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);">
                    <div>
                        <h2 class="fw-bold mb-1">Modifier le projet ✏️</h2>
                        <p class="mb-0 opacity-75 small">Mettez à jour les informations de votre campagne de financement.</p>
                    </div>
                    <i class="fas fa-edit fa-3x opacity-25"></i>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    
                    {# Message d'erreur global en rouge #}
                    {% for message in app.flashes('danger') %}
                        <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center" 
                             style="border-radius: 15px; background-color: #fff1f2; color: #e11d48;">
                            <i class="fas fa-exclamation-circle me-3 fa-lg"></i>
                            <span class="fw-bold">{{ message }}</span>
                        </div>
                    {% endfor %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'needs-validation'}}) }}
                        
                        <div class="row">
                            {# Section Gauche : Informations Générales #}
                            <div class="col-md-6 border-end pe-md-4">
                                <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-info-circle me-2"></i>Informations Générales</h5>
                                
                                <div class="mb-4">
                                    <label class="form-label fw-bold text-dark">Titre du projet</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-font text-muted"></i></span>
                                        {{ form_widget(form.title, {'attr': {'class': 'form-control border-start-0 ' ~ (form.title.vars.valid ? '' : 'is-invalid'), 'placeholder': 'Ex: Ma Startup Tech'}}) }}
                                    </div>
                                    <div class="text-danger small mt-1 fw-bold">{{ form_errors(form.title) }}</div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-dark">Description détaillée</label>
                                    {{ form_widget(form.description, {'attr': {'class': 'form-control ' ~ (form.description.vars.valid ? '' : 'is-invalid'), 'rows': '5', 'placeholder': 'Expliquez votre vision...'}}) }}
                                    <div class="text-danger small mt-1 fw-bold">{{ form_errors(form.description) }}</div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-dark">Secteur d'activité</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-layer-group text-muted"></i></span>
                                        {{ form_widget(form.secteur, {'attr': {'class': 'form-select border-start-0'}}) }}
                                    </div>
                                </div>
                            </div>

                            {# Section Droite : Chiffres et Dates #}
                            <div class="col-md-6 ps-md-4">
                                <h5 class="fw-bold mb-4 text-success"><i class="fas fa-coins me-2"></i>Besoin de Financement</h5>

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-dark">Montant cible (DT)</label>
                                    <div class="input-group">
                                        {{ form_widget(form.targetAmount, {'attr': {'class': 'form-control border-end-0 ' ~ (form.targetAmount.vars.valid ? '' : 'is-invalid')}}) }}
                                        <span class="input-group-text bg-light fw-bold text-muted border-start-0">DT</span>
                                    </div>
                                    <div class="text-danger small mt-1 fw-bold">{{ form_errors(form.targetAmount) }}</div>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-6">
                                        <label class="form-label fw-bold text-dark small">Date de début</label>
                                        {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-bold text-dark small">Échéance de fin</label>
                                        {{ form_widget(form.endDate, {'attr': {'class': 'form-control ' ~ (form.endDate.vars.valid ? '' : 'is-invalid')}}) }}
                                    </div>
                                    <div class="col-12">
                                        <div class="text-danger small fw-bold">{{ form_errors(form.endDate) }}</div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold text-dark">URL de l'image illustrative</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="fas fa-image text-muted"></i></span>
                                        {{ form_widget(form.imageUrl, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'https://...'}}) }}
                                    </div>
                                </div>

                                {# Aperçu rapide de l'image actuelle #}
                                {% if projet.imageUrl %}
                                    <div class="mt-3 p-2 border rounded-3 bg-light text-center">
                                        <p class="small text-muted mb-2 italic">Aperçu actuel :</p>
                                        <img src="{{ projet.imageUrl }}" style="height: 80px; border-radius: 10px; object-fit: cover;">
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        {# Actions de fin #}
                        <div class="row mt-5">
                            <div class="col-md-8 mx-auto">
                                <button type="submit" class="btn btn-lg w-100 fw-bold text-white shadow-sm hover-elevate" 
                                        style="background-color: #f59e0b; border-radius: 15px; padding: 16px; border: none; font-size: 1.1rem;">
                                    <i class="fas fa-save me-2"></i> Enregistrer les modifications
                                </button>
                                <p class="text-center text-muted small mt-3">
                                    <i class="fas fa-lock me-1"></i> Vos modifications seront immédiatement visibles sur le tableau de bord.
                                </p>
                            </div>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Design Pro et Responsif */
    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px 15px;
        border: 1px solid #e2e8f0;
        transition: 0.3s;
    }
    .form-control:focus {
        border-color: #8b5cf6;
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
    }
    .is-invalid {
        border-color: #e11d48 !important;
    }
    .is-invalid:focus {
        box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.1) !important;
    }
    .input-group-text {
        border-radius: 10px;
        border: 1px solid #e2e8f0;
    }
    .hover-elevate {
        transition: all 0.3s ease;
    }
    .hover-elevate:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(245, 158, 11, 0.3) !important;
        background-color: #d97706 !important;
    }
    /* Style pour les erreurs Symfony en rouge */
    .text-danger {
        color: #e11d48 !important;
    }
</style>
{% endblock %}