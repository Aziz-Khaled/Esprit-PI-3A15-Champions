{% extends 'base.html.twig' %}

{% block title %}Mes Demandes de Crédit{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<section class="py-5 bg-light min-vh-100">
    <div class="container">
        {# Header harmonisé #}
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 animate__animated animate__fadeInDown">
            <div>
                <h1 class="fw-bold text-dark mb-1">Espace Financement</h1>
                <p class="text-muted">Consultez l'historique et l'état de vos demandes de crédit "Champions".</p>
            </div>
            <a href="{{ path('app_credit_new') }}" class="nav-btn-violet shadow-sm">
                <i class="fas fa-plus-circle me-2"></i>Nouvelle Demande
            </a>
        </div>

        {# Statistiques #}
        <div class="row mb-5 g-4 animate__animated animate__fadeIn">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body d-flex align-items-center p-4">
                        <div class="icon-shape bg-soft-violet text-violet rounded-4 me-3">
                            <i class="fas fa-wallet fa-lg"></i>
                        </div>
                        <div>
                            <small class="text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">Dossiers Actifs</small>
                            <h3 class="fw-bold mb-0 text-dark">{{ credits|length }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Conteneur du Tableau #}
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__fadeInUp">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4 py-4 border-0">Projet</th>
                            <th class="py-4 border-0">Engagement</th>
                            <th class="py-4 border-0 text-center">Conditions</th>
                            <th class="py-4 border-0 text-center">Statut du Dossier</th>
                            <th class="py-4 border-0 text-end pe-4">Gestion</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0 bg-white">
                    {% for credit in credits %}
                        <tr class="credit-row border-bottom">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-square me-3 text-violet">
                                        <i class="fas fa-rocket"></i>
                                    </div>
                                    <div>
                                        <span class="d-block fw-bold text-dark">{{ credit.projet.title }}</span>
                                        <span class="badge bg-light text-muted border fw-normal" style="font-size: 0.7rem;">ID #{{ credit.idCredit }}</span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-dark fs-5">{{ credit.montant|number_format(2, ',', ' ') }}</span>
                                    <span class="text-violet fw-bold" style="font-size: 0.7rem;">{{ credit.devise }}</span>
                                </div>
                            </td>
                            <td class="text-center py-3">
                                <div class="condition-tag">
                                    <span class="fw-bold">{{ credit.taux }}%</span>
                                    <span class="mx-2 text-muted">|</span>
                                    <span>{{ credit.duree }} mois</span>
                                </div>
                            </td>
                            <td class="text-center py-3">
                                {% if credit.status == 'OPEN' %}
                                    <span class="badge-status status-open">EN ATTENTE</span>
                                {% elseif credit.status == 'APPROVED' %}
                                    <span class="badge-status status-approved">APPROUVÉ</span>
                                {% else %}
                                    <span class="badge-status status-default">{{ credit.status }}</span>
                                {% endif %}
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end align-items-center gap-2">
                                    {# BOUTON MODIFIER : Indigo/Violet harmonisé #}
                                    <a href="{{ path('app_credit_edit', {'id_credit': credit.idCredit}) }}" 
                                       class="btn-action btn-ui-modifier">
                                        <i class="fas fa-edit me-2"></i>Modifier
                                    </a>
                                    
                                    {# BOUTON SUPPRIMER : Rouge soft/poubelle #}
                                    <form method="post" action="{{ path('app_credit_delete', {'id_credit': credit.idCredit}) }}" 
                                          onsubmit="return confirm('Supprimer ce dossier définitivement ?');" 
                                          class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ credit.idCredit) }}">
                                        <button class="btn-action btn-ui-supprimer" type="submit">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                                <p>Aucune demande de crédit enregistrée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<style>
    /* Design Global harmonisé avec tes captures */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
    :root {
        --primary-violet: #8353E2; /* Couleur issue de ta capture "Nouveau Projet" */
        --hover-violet: #6d3ec9;
    }

    body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }

    /* Bouton principal violet */
    .nav-btn-violet {
        background-color: var(--primary-violet) !important;
        color: #fff !important;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.3s ease;
        display: inline-block;
    }
    .nav-btn-violet:hover { background-color: var(--hover-violet) !important; transform: translateY(-2px); }

    /* Tableau & Lignes */
    .credit-row { transition: all 0.2s ease; }
    .credit-row:hover { background-color: #fcfcfc !important; }

    .avatar-square {
        width: 40px; height: 40px; background: #f3efff;
        border: 1px solid #e0d4ff; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
    }
    .text-violet { color: var(--primary-violet) !important; }

    .condition-tag {
        background: #f8f9fa; padding: 6px 14px;
        border-radius: 10px; border: 1px solid #efefef; font-size: 0.85rem;
    }

    /* Statuts Badges */
    .badge-status {
        font-size: 0.75rem; font-weight: 700; padding: 6px 14px; border-radius: 50px;
    }
    .status-open { background: #e0f2ff; color: #0084ff; border: 1px solid #b3d9ff; }
    .status-approved { background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
    .status-default { background: #f5f5f5; color: #757575; }

    /* BOUTONS D'ACTION HARMONISÉS */
    .btn-action {
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 12px; font-weight: 600; transition: all 0.3s ease;
        border: none; text-decoration: none;
    }

    /* Bouton Modifier (Violet interface) */
    .btn-ui-modifier {
        padding: 10px 18px;
        background-color: var(--primary-violet) !important;
        color: #fff !important;
        font-size: 0.85rem;
        box-shadow: 0 4px 6px rgba(131, 83, 226, 0.15);
    }
    .btn-ui-modifier:hover {
        background-color: var(--hover-violet) !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(131, 83, 226, 0.25);
    }

    /* Bouton Supprimer (Soft Red) */
    .btn-ui-supprimer {
        width: 42px; height: 42px;
        background-color: #fff0f0 !important;
        color: #e74c3c !important;
        border: 1px solid #fadbd8 !important;
    }
    .btn-ui-supprimer:hover {
        background-color: #e74c3c !important;
        color: #fff !important;
        transform: translateY(-2px);
    }

    .icon-shape { width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; }
    .bg-soft-violet { background: rgba(131, 83, 226, 0.1); }
</style>
{% endblock %}