<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>{% block title %}SB Admin 2 - Dashboard{% endblock %}</title>

    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="/css/sb-admin-2.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">        
        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">

            <!-- Sidebar - Brand -->
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="{{ path('app_admin_panel') }}">
                <div class="sidebar-brand-text mx-3">NexVault Admin panel</div>
            </a>

            <hr class="sidebar-divider my-0">

            <!-- Dashboard -->
            <li class="nav-item active">
                <a class="nav-link" href="{{ path('app_admin_panel') }}">
                    <i class="fas fa-fw fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <hr class="sidebar-divider">
            <div class="sidebar-heading">User Management</div>

            <!-- Pending Approvals -->
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_admin_pending_users') }}">
                    <i class="fas fa-fw fa-user-clock"></i>
                    <span>Pending Approvals</span>
                </a>
            </li>

            <!-- All Users -->
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_admin_users_list') }}">
                    <i class="fas fa-fw fa-users"></i>
                    <span>Users</span>
                </a>
            </li>

            <hr class="sidebar-divider">
            <div class="sidebar-heading">Trading</div>

            <!-- Assets -->
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_backoffice_asset_index') }}">
                    <i class="fas fa-fw fa-coins"></i>
                    <span>Assets</span>
                </a>
            </li>

            <hr class="sidebar-divider">
            <div class="sidebar-heading">Interface</div>

            <!-- Assets -->
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_back_product_index') }}">
                    <i class="fas fa-fw fa-coins"></i>
                    <span>Produits</span>
                </a>
            </li>

             <li class="nav-item">
                <a class="nav-link" href="{{ path('app_back_order_index') }}">
                    <i class="fas fa-fw fa-coins"></i>
                    <span>Commandes</span>
                </a>
            </li>

            <hr class="sidebar-divider">
            <div class="sidebar-heading">Billing</div>
                
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_admin_transactions') }}">
                    <i class="fas fa-fw fa-coins"></i>
                    <span>transactions</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_admin_currency_index') }}">
                    <i class="fas fa-fw fa-coins"></i>
                    <span>Currencies</span>
                </a>
            </li>
            <hr class="sidebar-divider">
            <!-- Logout -->
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_logout') }}">
                    <i class="fas fa-fw fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </li>

            <hr class="sidebar-divider d-none d-md-block">

            <!-- Sidebar Toggler -->
            <div class="text-center d-none d-md-inline">
                <button class="rounded-circle border-0" id="sidebarToggle"></button>
            </div>

        </ul>
        
        <!-- End of Sidebar -->

        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">

                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">

                    <!-- Sidebar Toggle (Topbar) -->
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <!-- Topbar Navbar -->
                    <ul class="navbar-nav ml-auto">

                        <div class="topbar-divider d-none d-sm-block"></div>

                        <!-- Nav Item - User Information -->
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small">Douglas McGee</span>
                                <img class="img-profile rounded-circle" src="/img/undraw_profile.svg">
                            </a>
                        </li>

                    </ul>

                </nav>
                <!-- End of Topbar -->

                <!-- Begin Page Content -->
                <div class="container-fluid">
                    {% block body_back %}{% endblock %}
                </div>
                <!-- /.container-fluid -->

            </div>
            <!-- End of Main Content -->

            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Copyright &copy; Your Website {{ "now"|date("Y") }}</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="/js/sb-admin-2.min.js"></script>
    {% block javascripts %}{% endblock %}

</body>
</html>
