{# Authentication UI — NexVault Fintech App #}
{# Screens: Login | Sign Up Step 1 (Profile) | Sign Up Step 2 (KYC) | Pending Review #}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ page_title | default('NexVault — Authentication') }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg:       #070B14;
    --surface:  #0D1526;
    --surface2: #111E35;
    --border:   rgba(0,212,255,0.12);
    --cyan:     #00D4FF;
    --cyan-dim: rgba(0,212,255,0.08);
    --gold:     #F0B429;
    --gold-dim: rgba(240,180,41,0.10);
    --text:     #E8F0FE;
    --muted:    #5A7090;
    --danger:   #FF4D6A;
    --success:  #00E5A0;
    --radius:   16px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Manrope', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  /* ── BACKGROUND ── */
  .bg-grid {
    position: fixed; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(0,212,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: gridDrift 20s linear infinite;
  }
  @keyframes gridDrift {
    0%   { background-position: 0 0; }
    100% { background-position: 48px 48px; }
  }

  .bg-orb {
    position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none;
  }
  .bg-orb-1 {
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(0,212,255,0.12) 0%, transparent 70%);
    top: -180px; left: -120px;
    animation: orbFloat 8s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(240,180,41,0.10) 0%, transparent 70%);
    bottom: -140px; right: -80px;
    animation: orbFloat 11s ease-in-out infinite alternate-reverse;
  }
  .bg-orb-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(0,229,160,0.07) 0%, transparent 70%);
    top: 50%; right: 20%;
    animation: orbFloat 14s ease-in-out infinite alternate;
  }
  @keyframes orbFloat {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(30px,20px) scale(1.08); }
  }

  /* ── WRAPPER ── */
  .auth-wrapper {
    position: relative; z-index: 10;
    width: 100%; max-width: 480px;
    padding: 24px;
  }

  /* ── CARD ── */
  .card {
    background: linear-gradient(145deg, var(--surface), var(--surface2));
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px 40px 36px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,212,255,0.05);
    backdrop-filter: blur(20px);
  }
  .card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--gold), transparent);
    opacity: 0.6;
  }
  .card-corner {
    position: absolute; top: 18px; right: 18px;
    width: 32px; height: 32px;
    border-top: 2px solid var(--cyan);
    border-right: 2px solid var(--cyan);
    border-radius: 0 8px 0 0;
    opacity: 0.4;
  }

  /* ── LOGO ── */
  .logo {
    display: flex; align-items: center; gap: 10px; margin-bottom: 32px;
  }
  .logo-mark {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--cyan), var(--gold));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif;
    font-weight: 800; font-size: 16px;
    color: var(--bg);
    flex-shrink: 0;
    box-shadow: 0 0 20px rgba(0,212,255,0.3);
  }
  .logo-text {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 18px;
    letter-spacing: 0.05em;
    background: linear-gradient(90deg, var(--text), var(--cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }

  /* ── SCREEN TRANSITIONS ── */
  .screen {
    display: none;
    animation: slideIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .screen.active { display: block; }
  .screen.slide-out {
    animation: slideOut 0.3s cubic-bezier(0.4, 0, 0.8, 0.2) both;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(28px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideOut {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(-28px); }
  }
  .screen.slide-in-left {
    animation: slideInLeft 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-28px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── HEADINGS ── */
  .screen-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 24px;
    margin-bottom: 6px;
    line-height: 1.2;
  }
  .screen-subtitle {
    color: var(--muted); font-size: 13.5px; margin-bottom: 28px;
    font-weight: 400; line-height: 1.5;
  }

  /* ── PROGRESS STEPS ── */
  .step-track {
    display: flex; align-items: center; gap: 0; margin-bottom: 28px;
  }
  .step-node {
    display: flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 50%;
    border: 1.5px solid var(--muted);
    font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 500;
    color: var(--muted);
    transition: all 0.4s ease;
    position: relative; z-index: 1; flex-shrink: 0;
  }
  .step-node.active {
    border-color: var(--cyan); color: var(--cyan);
    box-shadow: 0 0 14px rgba(0,212,255,0.35);
    background: rgba(0,212,255,0.08);
  }
  .step-node.done {
    border-color: var(--success); background: var(--success);
    color: var(--bg); font-weight: 700;
  }
  .step-line {
    flex: 1; height: 1px; background: var(--muted); opacity: 0.3;
    transition: background 0.4s ease, opacity 0.4s ease;
    margin: 0 6px;
  }
  .step-line.active { background: var(--cyan); opacity: 0.5; }
  .step-label {
    font-size: 10.5px; color: var(--muted); margin-left: 6px;
    font-family: 'DM Mono', monospace; letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .step-label.active { color: var(--cyan); }
  .step-wrapper { display: flex; flex-direction: column; align-items: center; gap: 4px; }

  /* ── INPUTS ── */
  .field { margin-bottom: 16px; }
  .field label {
    display: block; font-size: 11px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 7px;
  }
  .input-wrap { position: relative; }
  .input-wrap .ico {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: var(--muted); font-size: 16px; pointer-events: none;
    transition: color 0.2s;
  }
  input[type="text"], input[type="email"], input[type="password"], input[type="tel"], select {
    width: 100%; padding: 12px 14px 12px 42px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(90,112,144,0.3);
    border-radius: 10px;
    color: var(--text); font-size: 14px;
    font-family: 'Manrope', sans-serif;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    -webkit-appearance: none;
  }
  input:focus, select:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.12);
    background: rgba(0,212,255,0.04);
  }
  input:focus + .ico, select:focus + .ico { color: var(--cyan); }
  .input-wrap .ico { pointer-events: none; }
  select { cursor: pointer; }
  select option { background: #111E35; }

  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* ── UPLOAD ZONES ── */
  .upload-zone {
    border: 1.5px dashed rgba(90,112,144,0.4);
    border-radius: 12px; padding: 20px 16px;
    text-align: center; cursor: pointer;
    transition: all 0.25s ease;
    background: rgba(0,0,0,0.2);
    position: relative; overflow: hidden;
  }
  .upload-zone:hover {
    border-color: var(--cyan);
    background: rgba(0,212,255,0.04);
    box-shadow: 0 0 20px rgba(0,212,255,0.08);
  }
  .upload-zone.has-file {
    border-color: var(--success);
    background: rgba(0,229,160,0.06);
  }
  .upload-zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .upload-icon { font-size: 26px; margin-bottom: 6px; display: block; }
  .upload-label { font-size: 12px; color: var(--muted); font-weight: 500; }
  .upload-label span { color: var(--cyan); }
  .upload-preview {
    display: none; width: 60px; height: 60px; border-radius: 8px;
    object-fit: cover; margin: 0 auto 6px;
    border: 2px solid var(--success);
  }
  .upload-zone.has-file .upload-preview { display: block; }
  .upload-zone.has-file .upload-icon { display: none; }
  .upload-zone.has-file .upload-label { color: var(--success); }

  /* ── ROLE CARDS ── */
  .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .role-card {
    border: 1.5px solid rgba(90,112,144,0.25);
    border-radius: 12px; padding: 14px 12px;
    cursor: pointer; transition: all 0.25s ease;
    background: rgba(0,0,0,0.2); text-align: center;
    position: relative;
  }
  .role-card:hover { border-color: rgba(0,212,255,0.4); background: rgba(0,212,255,0.05); }
  .role-card.selected {
    border-color: var(--cyan);
    background: rgba(0,212,255,0.09);
    box-shadow: 0 0 20px rgba(0,212,255,0.15);
  }
  .role-card input { position: absolute; opacity: 0; }
  .role-icon { font-size: 22px; margin-bottom: 6px; }
  .role-name { font-size: 12px; font-weight: 600; color: var(--text); }
  .role-desc { font-size: 10.5px; color: var(--muted); margin-top: 2px; line-height: 1.4; }
  .role-card.selected .role-name { color: var(--cyan); }
  .role-check {
    position: absolute; top: 8px; right: 8px;
    width: 16px; height: 16px; border-radius: 50%;
    border: 1.5px solid var(--muted);
    transition: all 0.2s;
  }
  .role-card.selected .role-check {
    background: var(--cyan); border-color: var(--cyan);
    box-shadow: 0 0 8px rgba(0,212,255,0.5);
  }

  /* ── BUTTONS ── */
  .btn-primary {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, var(--cyan) 0%, #0099CC 100%);
    border: none; border-radius: 12px;
    color: var(--bg); font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 14px; letter-spacing: 0.06em;
    cursor: pointer; transition: all 0.25s ease;
    position: relative; overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,212,255,0.25);
  }
  .btn-primary::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
    opacity: 0; transition: opacity 0.2s;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 12px 32px rgba(0,212,255,0.35); }
  .btn-primary:hover::after { opacity: 1; }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    width: 100%; padding: 13px;
    background: transparent; border: 1.5px solid rgba(90,112,144,0.35);
    border-radius: 12px; color: var(--muted);
    font-family: 'Manrope', sans-serif; font-weight: 600; font-size: 14px;
    cursor: pointer; transition: all 0.25s ease; margin-top: 10px;
  }
  .btn-secondary:hover { border-color: var(--cyan); color: var(--cyan); background: rgba(0,212,255,0.05); }

  .btn-row { display: flex; gap: 10px; margin-top: 20px; }
  .btn-row .btn-back {
    flex: 0 0 48px; padding: 13px;
    background: transparent; border: 1.5px solid rgba(90,112,144,0.3);
    border-radius: 12px; color: var(--muted);
    font-size: 18px; cursor: pointer; transition: all 0.25s;
    display: flex; align-items: center; justify-content: center;
  }
  .btn-row .btn-back:hover { border-color: var(--cyan); color: var(--cyan); }
  .btn-row .btn-primary { flex: 1; margin-top: 0; }

  /* ── DIVIDER ── */
  .divider {
    display: flex; align-items: center; gap: 12px;
    margin: 20px 0; color: var(--muted); font-size: 12px;
  }
  .divider::before, .divider::after {
    content: ''; flex: 1; height: 1px; background: rgba(90,112,144,0.25);
  }

  /* ── LINK ── */
  .auth-link { text-align: center; font-size: 13px; color: var(--muted); margin-top: 20px; }
  .auth-link a { color: var(--cyan); text-decoration: none; font-weight: 600; cursor: pointer; }
  .auth-link a:hover { text-decoration: underline; }

  /* ── PASSWORD TOGGLE ── */
  .pw-toggle {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    color: var(--muted); cursor: pointer; font-size: 15px; transition: color 0.2s;
    background: none; border: none; padding: 0;
  }
  .pw-toggle:hover { color: var(--cyan); }

  /* ── TICKER TAPE ── */
  .ticker {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: rgba(7,11,20,0.85); backdrop-filter: blur(10px);
    border-top: 1px solid rgba(0,212,255,0.1);
    padding: 8px 0; overflow: hidden; z-index: 5;
  }
  .ticker-inner {
    display: flex; gap: 48px; white-space: nowrap;
    animation: ticker 28s linear infinite;
    width: max-content;
  }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .tick-item {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'DM Mono', monospace; font-size: 11.5px;
  }
  .tick-sym { color: var(--muted); }
  .tick-price { color: var(--text); font-weight: 500; }
  .tick-chg.up { color: var(--success); }
  .tick-chg.dn { color: var(--danger); }

  /* ── PENDING SCREEN ── */
  .pending-anim {
    width: 80px; height: 80px; margin: 0 auto 24px;
    position: relative;
  }
  .pending-ring {
    width: 80px; height: 80px; border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: var(--cyan);
    border-right-color: var(--gold);
    animation: spin 2s linear infinite;
    position: absolute; inset: 0;
  }
  .pending-ring-2 {
    width: 62px; height: 62px; border-radius: 50%;
    border: 1.5px solid transparent;
    border-bottom-color: rgba(0,212,255,0.4);
    animation: spin 3s linear infinite reverse;
    position: absolute; top: 9px; left: 9px;
  }
  .pending-icon {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-size: 26px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .pending-title {
    font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 700;
    text-align: center; margin-bottom: 8px;
  }
  .pending-sub {
    text-align: center; color: var(--muted); font-size: 13.5px; line-height: 1.6;
    margin-bottom: 28px;
  }

  .info-pill {
    background: rgba(0,212,255,0.07); border: 1px solid rgba(0,212,255,0.15);
    border-radius: 10px; padding: 12px 16px;
    display: flex; align-items: flex-start; gap: 10px; margin-bottom: 10px;
  }
  .info-pill-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .info-pill-text { font-size: 12.5px; color: var(--muted); line-height: 1.5; }
  .info-pill-text strong { color: var(--text); font-weight: 600; }

  /* ── PASSWORD STRENGTH ── */
  .pw-strength { margin-top: 6px; }
  .pw-bars { display: flex; gap: 4px; margin-bottom: 4px; }
  .pw-bar {
    flex: 1; height: 3px; border-radius: 2px;
    background: rgba(90,112,144,0.25);
    transition: background 0.3s ease;
  }
  .pw-bar.weak { background: var(--danger); }
  .pw-bar.fair { background: var(--gold); }
  .pw-bar.strong { background: var(--success); }
  .pw-label { font-size: 10.5px; color: var(--muted); }

  /* ── CHECKBOX ── */
  .check-row {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 12.5px; color: var(--muted); margin-bottom: 16px; cursor: pointer;
  }
  .check-row input[type="checkbox"] {
    width: 16px; height: 16px; flex-shrink: 0; cursor: pointer;
    accent-color: var(--cyan); margin-top: 1px; padding: 0;
  }
  .check-row a { color: var(--cyan); text-decoration: none; }
  .check-row a:hover { text-decoration: underline; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(0,212,255,0.2); border-radius: 2px; }

  /* ── INPUT NO PADDING (no icon variant) ── */
  .no-icon input, .no-icon select { padding-left: 14px; }

  /* ── OVERSCROLL SAFE ── */
  .card-body { max-height: 70vh; overflow-y: auto; padding-right: 2px; }

  @media (max-height: 700px) {
    .card { padding: 28px 32px 24px; }
    .card-body { max-height: 65vh; }
  }
</style>
</head>
<body>

<div class="bg-grid"></div>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>
<div class="bg-orb bg-orb-3"></div>

<!-- ════════════════════════ CARD ════════════════════════ -->
<div class="auth-wrapper">
  <div class="card">
    <div class="card-corner"></div>

    <div class="logo">
      <div class="logo-mark">N</div>
      <div class="logo-text">{{ app_name | default('NexVault') }}</div>
    </div>

    <!-- ─── SCREEN 1 : LOGIN ─── -->
    <div class="screen active" id="s-login">
      <div class="screen-title">Welcome back</div>
      <div class="screen-subtitle">Sign in to your trading account</div>

   
    {{ form_start(loginForm, {
    'action': path('app_login'),
    'method': 'POST',
    'attr': {'id': 'login-form'}
}) }}

<div class="field">
    {{ form_row(loginForm.email) }}
</div>
<div class="field">
    {{ form_row(loginForm.motDePasse) }}
</div>

<button type="submit" class="btn-primary">Sign In</button>

{{ form_end(loginForm) }}

      <div class="divider">or</div>
      <button class="btn-secondary" onclick="goto('s-signup1')">Create an Account</button>
      <div class="auth-link" style="margin-top:16px">
        New to {{ app_name | default('NexVault') }}? <a onclick="goto('s-signup1')">Register free</a>
      </div>
    </div>

    <!-- ─── SCREEN 2 : SIGNUP STEP 1 ─── -->
    <div class="screen" id="s-signup1">
      <div class="step-track">
        <div class="step-wrapper">
          <div class="step-node active">1</div>
          <span class="step-label active">Profile</span>
        </div>
        <div class="step-line active"></div>
        <div class="step-wrapper">
          <div class="step-node" id="step2-node">2</div>
          <span class="step-label" id="step2-label">KYC</span>
        </div>
        <div class="step-line" id="step-line2"></div>
        <div class="step-wrapper">
          <div class="step-node" id="step3-node">3</div>
          <span class="step-label" id="step3-label">Review</span>
        </div>
      </div>

      <div class="screen-title">Create Account</div>
      <div class="screen-subtitle">General information — Step 1 of 2</div>

      <div class="card-body">
        <form method="POST" action="{{ register_step1_path | default('/register/step1') }}" id="signup1-form">
        {% if csrf_token is defined %}
        <input type="hidden" name="_token" value="{{ csrf_token('register') }}" />
        {% endif %}

        <div class="field-row">
          <div class="field">
            <label>First Name</label>
            <div class="input-wrap">
              <input type="text" name="first_name" placeholder="Alex" required />
              <span class="ico">👤</span>
            </div>
          </div>
          <div class="field">
            <label>Last Name</label>
            <div class="input-wrap no-icon">
              <input type="text" name="last_name" placeholder="Morgan" style="padding-left:14px" required />
            </div>
          </div>
        </div>

        <div class="field">
          <label>Phone Number</label>
          <div class="input-wrap">
            <input type="tel" name="phone" placeholder="+1 (555) 000-0000" required />
            <span class="ico">📱</span>
          </div>
        </div>

        <div class="field">
          <label>Email Address</label>
          <div class="input-wrap">
            <input type="email" name="email" placeholder="you@{{ app_name | default('nexvault') | lower }}.io" required />
            <span class="ico">✉</span>
          </div>
        </div>

        <div class="field">
          <label>Password</label>
          <div class="input-wrap">
            <input type="password" id="signup-pw" name="password" placeholder="Min. 8 characters" oninput="checkStrength(this)" required />
            <span class="ico">🔒</span>
            <button type="button" class="pw-toggle" onclick="togglePw('signup-pw',this)">👁</button>
          </div>
          <div class="pw-strength">
            <div class="pw-bars">
              <div class="pw-bar" id="bar1"></div>
              <div class="pw-bar" id="bar2"></div>
              <div class="pw-bar" id="bar3"></div>
              <div class="pw-bar" id="bar4"></div>
            </div>
            <div class="pw-label" id="pw-label">Enter a password</div>
          </div>
        </div>

        <label class="check-row">
          <input type="checkbox" name="agree_terms" required />
          I agree to the <a href="{{ terms_path | default('/terms') }}">Terms of Service</a>&nbsp;and&nbsp;<a href="{{ privacy_path | default('/privacy') }}">Privacy Policy</a>
        </label>

        <button type="submit" class="btn-primary" onclick="goto('s-signup2');return false;">Continue to KYC →</button>
        </form>
        <div class="auth-link">Already have an account? <a onclick="goto('s-login')">Sign In</a></div>
      </div>
    </div>

    <!-- ─── SCREEN 3 : SIGNUP STEP 2 KYC ─── -->
    <div class="screen" id="s-signup2">
      <div class="step-track">
        <div class="step-wrapper">
          <div class="step-node done">✓</div>
          <span class="step-label">Profile</span>
        </div>
        <div class="step-line active"></div>
        <div class="step-wrapper">
          <div class="step-node active">2</div>
          <span class="step-label active">KYC</span>
        </div>
        <div class="step-line" id="kyc-line2"></div>
        <div class="step-wrapper">
          <div class="step-node" id="kyc-step3">3</div>
          <span class="step-label">Review</span>
        </div>
      </div>

      <div class="screen-title">Identity Verification</div>
      <div class="screen-subtitle">KYC required for regulatory compliance — Step 2 of 2</div>

      <div class="card-body">
        <form method="POST" action="{{ register_step2_path | default('/register/step2') }}" id="kyc-form" enctype="multipart/form-data">
        {% if csrf_token is defined %}
        <input type="hidden" name="_token" value="{{ csrf_token('kyc') }}" />
        {% endif %}

        <div class="field-row" style="margin-bottom:16px">
          <div>
            <label style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px">Profile Photo</label>
            <div class="upload-zone" id="zone-selfie" onclick="triggerUpload('up-selfie','zone-selfie','prev-selfie')">
              <input type="file" id="up-selfie" name="selfie" accept="image/*" onchange="handleFile(this,'zone-selfie','prev-selfie')" />
              <img class="upload-preview" id="prev-selfie" />
              <span class="upload-icon">🤳</span>
              <div class="upload-label"><span>Upload</span> selfie</div>
            </div>
          </div>
          <div>
            <label style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px">ID Document</label>
            <div class="upload-zone" id="zone-id" onclick="triggerUpload('up-id','zone-id','prev-id')">
              <input type="file" id="up-id" name="id_document" accept="image/*" onchange="handleFile(this,'zone-id','prev-id')" />
              <img class="upload-preview" id="prev-id" />
              <span class="upload-icon">🪪</span>
              <div class="upload-label"><span>Upload</span> ID card</div>
            </div>
          </div>
        </div>

        <div class="field">
          <label>How will you use {{ app_name | default('NexVault') }}?</label>
          <div class="role-grid">
            <label class="role-card" onclick="selectRole(this)">
              <input type="radio" name="role" value="trader" required />
              <div class="role-check"></div>
              <div class="role-icon">📈</div>
              <div class="role-name">Trader</div>
              <div class="role-desc">Active crypto & asset trading</div>
            </label>
            <label class="role-card" onclick="selectRole(this)">
              <input type="radio" name="role" value="investor" />
              <div class="role-check"></div>
              <div class="role-icon">💼</div>
              <div class="role-name">Investor</div>
              <div class="role-desc">Long-term portfolio growth</div>
            </label>
            <label class="role-card" onclick="selectRole(this)">
              <input type="radio" name="role" value="business" />
              <div class="role-check"></div>
              <div class="role-icon">🏢</div>
              <div class="role-name">Business</div>
              <div class="role-desc">Corporate treasury & payments</div>
            </label>
            <label class="role-card" onclick="selectRole(this)">
              <input type="radio" name="role" value="developer" />
              <div class="role-check"></div>
              <div class="role-icon">⚡</div>
              <div class="role-name">Developer</div>
              <div class="role-desc">API access & integration</div>
            </label>
          </div>
        </div>

        <div class="btn-row">
          <button type="button" class="btn-back" onclick="goto('s-signup1','left')">←</button>
          <button type="submit" class="btn-primary" onclick="goto('s-pending');return false;">Submit Application →</button>
        </div>
        </form>
      </div>
    </div>

    <!-- ─── SCREEN 4 : PENDING ─── -->
    <div class="screen" id="s-pending">
      <div class="pending-anim">
        <div class="pending-ring"></div>
        <div class="pending-ring-2"></div>
        <div class="pending-icon">⏳</div>
      </div>
      <div class="pending-title">Under Review</div>
      <div class="pending-sub">
        Your application has been submitted and is pending admin approval. We'll notify you once verified.
      </div>

      <div class="info-pill">
        <span class="info-pill-icon">📧</span>
        <div class="info-pill-text"><strong>Check your email</strong> — a confirmation link has been sent to your inbox.</div>
      </div>
      <div class="info-pill" style="background:var(--gold-dim);border-color:rgba(240,180,41,0.2)">
        <span class="info-pill-icon">⏱</span>
        <div class="info-pill-text"><strong>Typical review time:</strong> 1–2 business days. You'll receive an email with the decision.</div>
      </div>
      <div class="info-pill" style="background:rgba(0,229,160,0.06);border-color:rgba(0,229,160,0.15)">
        <span class="info-pill-icon">🛡</span>
        <div class="info-pill-text">Your documents are encrypted and handled in compliance with <strong>GDPR & AML</strong> standards.</div>
      </div>

      <button class="btn-secondary" onclick="goto('s-login')" style="margin-top:20px">← Back to Login</button>
    </div>

  </div><!-- /card -->
</div>

<!-- ─── TICKER ─── -->
<div class="ticker">
  <div class="ticker-inner" id="ticker-inner"></div>
</div>

<script>
/* ── SCREEN NAVIGATION ── */
let current = 's-login';
function goto(id, dir = 'right') {
  const prev = document.getElementById(current);
  const next = document.getElementById(id);
  prev.classList.add('slide-out');
  setTimeout(() => {
    prev.classList.remove('active', 'slide-out');
    next.classList.add('active');
    if (dir === 'left') {
      next.classList.add('slide-in-left');
      setTimeout(() => next.classList.remove('slide-in-left'), 460);
    }
    current = id;
  }, 280);
}

/* ── PASSWORD TOGGLE ── */
function togglePw(id, btn) {
  const inp = document.getElementById(id);
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
  else { inp.type = 'password'; btn.textContent = '👁'; }
}

/* ── PASSWORD STRENGTH ── */
function checkStrength(inp) {
  const v = inp.value;
  const bars = [1,2,3,4].map(i => document.getElementById('bar'+i));
  const label = document.getElementById('pw-label');
  bars.forEach(b => b.className = 'pw-bar');
  if (!v) { label.textContent = 'Enter a password'; return; }
  let score = 0;
  if (v.length >= 8) score++;
  if (/[A-Z]/.test(v)) score++;
  if (/[0-9]/.test(v)) score++;
  if (/[^A-Za-z0-9]/.test(v)) score++;
  const cls = score <= 1 ? 'weak' : score <= 2 ? 'fair' : 'strong';
  const txt = score <= 1 ? 'Weak' : score <= 2 ? 'Fair' : score <= 3 ? 'Good' : 'Strong';
  const col = score <= 1 ? '#FF4D6A' : score <= 2 ? '#F0B429' : '#00E5A0';
  for (let i = 0; i < score; i++) bars[i].className = 'pw-bar ' + cls;
  label.textContent = txt; label.style.color = col;
}

/* ── FILE UPLOAD ── */
function triggerUpload(inputId) { document.getElementById(inputId).click(); }
function handleFile(input, zoneId, previewId) {
  const file = input.files[0]; if (!file) return;
  const zone = document.getElementById(zoneId);
  const prev = document.getElementById(previewId);
  const reader = new FileReader();
  reader.onload = e => { prev.src = e.target.result; zone.classList.add('has-file'); };
  reader.readAsDataURL(file);
}
/* Prevent zone click from bubbling into input when clicking input directly */
document.querySelectorAll('.upload-zone input').forEach(inp => {
  inp.addEventListener('click', e => e.stopPropagation());
});

/* ── ROLE SELECTION ── */
function selectRole(card) {
  document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
}

/* ── TICKER DATA ── */
const ticks = [
  { sym:'BTC/USD', price:'67,412.50', chg:'+2.34%', up:true },
  { sym:'ETH/USD', price:'3,521.80', chg:'+1.87%', up:true },
  { sym:'SOL/USD', price:'152.45', chg:'-0.62%', up:false },
  { sym:'BNB/USD', price:'578.20', chg:'+0.94%', up:true },
  { sym:'XRP/USD', price:'0.6120', chg:'-1.10%', up:false },
  { sym:'ADA/USD', price:'0.4530', chg:'+3.21%', up:true },
  { sym:'DOGE/USD', price:'0.1620', chg:'+5.44%', up:true },
  { sym:'AVAX/USD', price:'38.91', chg:'-2.15%', up:false },
  { sym:'LINK/USD', price:'14.72', chg:'+1.23%', up:true },
  { sym:'MATIC/USD', price:'0.8840', chg:'-0.48%', up:false },
];
const ticker = document.getElementById('ticker-inner');
const html = [...ticks,...ticks].map(t =>
  `<span class="tick-item">
    <span class="tick-sym">${t.sym}</span>
    <span class="tick-price">${t.price}</span>
    <span class="tick-chg ${t.up?'up':'dn'}">${t.chg}</span>
   </span>`).join('');
ticker.innerHTML = html;
</script>
</body>
</html>
