<!-- ─── SCREEN 3 : SIGNUP STEP 2 KYC ─── -->
<div class="screen" id="s-signup2">
  <div class="step-track">
    <div class="step-wrapper">
      <div class="step-node done">✓</div>
      <span class="step-label">Profile</span>
    </div>
    <div class="step-line active"></div>
    <div class="step-wrapper">
      <div class="step-node active">2</div>
      <span class="step-label active">KYC</span>
    </div>
    <div class="step-line"></div>
    <div class="step-wrapper">
      <div class="step-node">3</div>
      <span class="step-label">Review</span>
    </div>
  </div>

  <div class="screen-title">Identity Verification</div>
  <div class="screen-subtitle">KYC required for regulatory compliance — Step 2 of 2</div>

  <div class="card-body">

    {{ form_start(kycForm, {
        'action': path('app_register_step2'),
        'method': 'POST',
        'attr': {'id': 'kyc-form', 'enctype': 'multipart/form-data'}
    }) }}

    {# ── File Uploads ── #}
    <div class="field-row" style="margin-bottom:16px">

      {# Selfie #}
      <div>
        <label style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px">
          Profile Photo
        </label>
        <div class="upload-zone" id="zone-selfie">
          {# Hide the default file input visually but keep it in the DOM #}
          <div style="position:absolute;inset:0;opacity:0;cursor:pointer;" onclick="document.getElementById('{{ kycForm.selfie.vars.id }}').click()"></div>
          {{ form_widget(kycForm.selfie, {'attr': {
              'id': kycForm.selfie.vars.id,
              'style': 'position:absolute;inset:0;opacity:0;cursor:pointer;',
              'onchange': "handleFile(this,'zone-selfie','prev-selfie')"
          }}) }}
          <img class="upload-preview" id="prev-selfie" />
          <span class="upload-icon">🤳</span>
          <div class="upload-label"><span>Upload</span> selfie</div>
        </div>
        {% if kycForm.selfie.vars.errors|length %}
          <div style="color:#FF4D6A;font-size:11.5px;margin-top:4px;">
            {{ kycForm.selfie.vars.errors[0].message }}
          </div>
        {% endif %}
      </div>

      {# ID Document #}
      <div>
        <label style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px">
          ID Document
        </label>
        <div class="upload-zone" id="zone-id">
          <div style="position:absolute;inset:0;opacity:0;cursor:pointer;" onclick="document.getElementById('{{ kycForm.pieceIdentiteFile.vars.id }}').click()"></div>
          {{ form_widget(kycForm.pieceIdentiteFile, {'attr': {
              'id': kycForm.pieceIdentiteFile.vars.id,
              'style': 'position:absolute;inset:0;opacity:0;cursor:pointer;',
              'onchange': "handleFile(this,'zone-id','prev-id')"
          }}) }}
          <img class="upload-preview" id="prev-id" />
          <span class="upload-icon">🪪</span>
          <div class="upload-label"><span>Upload</span> ID card</div>
        </div>
        {% if kycForm.pieceIdentiteFile.vars.errors|length %}
          <div style="color:#FF4D6A;font-size:11.5px;margin-top:4px;">
            {{ kycForm.pieceIdentiteFile.vars.errors[0].message }}
          </div>
        {% endif %}
      </div>

    </div>

    {# ── Role Selection — styled cards, Symfony radios hidden underneath ── #}
    <div class="field">
      <label style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:7px">
        Your Role
      </label>

      {# Symfony renders real radio inputs — hide them, sync via JS #}
      <div style="display:none">
        {{ form_widget(kycForm.role) }}
      </div>

      {% set roleIcons = {'CLIENT': '👤', 'INVESTISSEUR': '💼', 'COMMERCANT': '🏢', 'ADMIN': '⚡'} %}
      {% set roleDescs = {
          'CLIENT':       'Standard account access',
          'INVESTISSEUR': 'Long-term portfolio growth',
          'COMMERCANT':   'Business & payments',
          'ADMIN':        'Full platform access'
      } %}

      <div class="role-grid">
        {% for choice in kycForm.role.vars.choices %}
          <div class="role-card" onclick="selectRole(this, '{{ choice.value }}')">
            <div class="role-check"></div>
            <div class="role-icon">{{ roleIcons[choice.value] ?? '👤' }}</div>
            <div class="role-name">{{ choice.label }}</div>
            <div class="role-desc">{{ roleDescs[choice.value] ?? '' }}</div>
          </div>
        {% endfor %}
      </div>

      {% if kycForm.role.vars.errors|length %}
        <div style="color:#FF4D6A;font-size:11.5px;margin-top:4px;">
          {{ kycForm.role.vars.errors[0].message }}
        </div>
      {% endif %}
      <div id="role-error" style="display:none;color:#FF4D6A;font-size:11.5px;margin-bottom:10px;">
        Please select a role to continue.
      </div>
    </div>

    <div class="btn-row">
      <button type="button" class="btn-back" onclick="goto('s-signup1','left')">←</button>
      <button type="submit" class="btn-primary" onclick="return validateKyc()">
        Submit Application →
      </button>
    </div>

    {{ form_end(kycForm) }}

  </div>
</div>

    <!-- ─── SCREEN 4 : PENDING ─── -->
    <div class="screen" id="s-pending">
      <div class="pending-anim">
        <div class="pending-ring"></div>
        <div class="pending-ring-2"></div>
        <div class="pending-icon">⏳</div>
      </div>
      <div class="pending-title">Under Review</div>
      <div class="pending-sub">
        Your application has been submitted and is pending admin approval. We'll notify you once verified.
      </div>

      <div class="info-pill">
        <span class="info-pill-icon">📧</span>
        <div class="info-pill-text"><strong>Check your email</strong> — a confirmation link has been sent to your inbox.</div>
      </div>
      <div class="info-pill" style="background:var(--gold-dim);border-color:rgba(240,180,41,0.2)">
        <span class="info-pill-icon">⏱</span>
        <div class="info-pill-text"><strong>Typical review time:</strong> 1–2 business days. You'll receive an email with the decision.</div>
      </div>
      <div class="info-pill" style="background:rgba(0,229,160,0.06);border-color:rgba(0,229,160,0.15)">
        <span class="info-pill-icon">🛡</span>
        <div class="info-pill-text">Your documents are encrypted and handled in compliance with <strong>GDPR & AML</strong> standards.</div>
      </div>

      <button class="btn-secondary" onclick="goto('s-login')" style="margin-top:20px">← Back to Login</button>
    </div>

  </div><!-- /card -->
</div>

<!-- ─── TICKER ─── -->
<div class="ticker">
  <div class="ticker-inner" id="ticker-inner"></div>
</div>

<script>
/* ── SCREEN NAVIGATION ── */
let current = 's-login';
function goto(id, dir = 'right') {
  const prev = document.getElementById(current);
  const next = document.getElementById(id);
  prev.classList.add('slide-out');
  setTimeout(() => {
    prev.classList.remove('active', 'slide-out');
    next.classList.add('active');
    if (dir === 'left') {
      next.classList.add('slide-in-left');
      setTimeout(() => next.classList.remove('slide-in-left'), 460);
    }
    current = id;
  }, 280);
}

/* ── PASSWORD TOGGLE ── */
function togglePw(id, btn) {
  const inp = document.getElementById(id);
  if (inp.type === 'password') { inp.type = 'text'; btn.textContent = '🙈'; }
  else { inp.type = 'password'; btn.textContent = '👁'; }
}

/* ── PASSWORD STRENGTH ── */

function checkStrength(inp) {
  const v = inp.value;
  const label = document.getElementById('pw-label');
  const bars  = [1,2,3].map(i => document.getElementById('bar'+i));

  // Reset
  bars.forEach(b => b.className = 'pw-bar');
  label.textContent = '';

  if (!v) { label.textContent = 'Enter a password'; label.style.color = 'var(--muted)'; return; }

  // Your exact 3 constraints from GeneralInfoType
  const rules = [
    { pass: v.length >= 8,      bar: 'bar1', text: '8+ characters' },
    { pass: /[A-Z]/.test(v),    bar: 'bar2', text: 'uppercase letter' },
    { pass: /[0-9]/.test(v),    bar: 'bar3', text: 'number' },
  ];

  const passed = rules.filter(r => r.pass).length;

  // Color per score
  const config = {
    1: { cls: 'weak',   col: '#FF4D6A', txt: 'Weak'   },
    2: { cls: 'fair',   col: '#F0B429', txt: 'Fair'   },
    3: { cls: 'strong', col: '#00E5A0', txt: 'Strong' },
  };

  if (passed === 0) {
    label.textContent = 'Too short';
    label.style.color = 'var(--muted)';
    return;
  }

  const { cls, col, txt } = config[passed];

  // Light up only bars for passed rules
  rules.forEach(r => {
    if (r.pass) document.getElementById(r.bar).className = 'pw-bar ' + cls;
  });

  // Show which rule is still missing
  const missing = rules.find(r => !r.pass);
  label.textContent = missing ? `${txt} — missing: ${missing.text}` : '✓ All requirements met';
  label.style.color = col;
}

/* ── FILE UPLOAD ── */
function triggerUpload(inputId) { document.getElementById(inputId).click(); }
function handleFile(input, zoneId, previewId) {
  const file = input.files[0]; if (!file) return;
  const zone = document.getElementById(zoneId);
  const prev = document.getElementById(previewId);
  const reader = new FileReader();
  reader.onload = e => { prev.src = e.target.result; zone.classList.add('has-file'); };
  reader.readAsDataURL(file);
}
/* Prevent zone click from bubbling into input when clicking input directly */
document.querySelectorAll('.upload-zone input').forEach(inp => {
  inp.addEventListener('click', e => e.stopPropagation());
});

/* ── ROLE SELECTION ── */
function selectRole(card, value) {
  document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');

  // Find Symfony's generated radio input by value and check it
  document.querySelectorAll('#kyc-form input[type="radio"]').forEach(r => {
    r.checked = (r.value === value);
  });
}

/* ── TICKER DATA ── */
const ticks = [
  { sym:'BTC/USD', price:'67,412.50', chg:'+2.34%', up:true },
  { sym:'ETH/USD', price:'3,521.80', chg:'+1.87%', up:true },
  { sym:'SOL/USD', price:'152.45', chg:'-0.62%', up:false },
  { sym:'BNB/USD', price:'578.20', chg:'+0.94%', up:true },
  { sym:'XRP/USD', price:'0.6120', chg:'-1.10%', up:false },
  { sym:'ADA/USD', price:'0.4530', chg:'+3.21%', up:true },
  { sym:'DOGE/USD', price:'0.1620', chg:'+5.44%', up:true },
  { sym:'AVAX/USD', price:'38.91', chg:'-2.15%', up:false },
  { sym:'LINK/USD', price:'14.72', chg:'+1.23%', up:true },
  { sym:'MATIC/USD', price:'0.8840', chg:'-0.48%', up:false },
];

const initialStep = "{{ initial_step | default('login') }}";
if (initialStep === 'signup1') goto('s-signup1');
else if (initialStep === '2')  goto('s-signup2');
else if (initialStep === 'pending') goto('s-pending');

const ticker = document.getElementById('ticker-inner');
const html = [...ticks,...ticks].map(t =>
  `<span class="tick-item">
    <span class="tick-sym">${t.sym}</span>
    <span class="tick-price">${t.price}</span>
    <span class="tick-chg ${t.up?'up':'dn'}">${t.chg}</span>
   </span>`).join('');
ticker.innerHTML = html;

function validateKyc() {
  const roleSelected = document.querySelector('#kyc-form input[type="radio"]:checked');
  const roleError    = document.getElementById('role-error');

  if (!roleSelected) {
    roleError.style.display = 'block';
    return false;
  }
  roleError.style.display = 'none';
  return true;
}


</script>
</body>
</html>
