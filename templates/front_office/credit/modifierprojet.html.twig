                    </div>

                    {# Description #}
                    <div class="cf-field">
                        <label class="cf-label">Description détaillée</label>
                        {{ form_widget(form.description, {'attr': {'class': 'cf-textarea', 'rows': '5', 'placeholder': 'Expliquez votre vision...'}}) }}
                        <div class="cf-error">{{ form_errors(form.description) }}</div>
                    </div>

                    {# Secteur #}
                    <div class="cf-field">
                        <label class="cf-label">Secteur d'activité</label>
                        <div class="cf-input-group">
                            <div class="cf-input-group-icon">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="6" height="6"/><rect x="16" y="3" width="6" height="6"/><rect x="2" y="15" width="6" height="6"/><path d="M16 18h6M19 15v6"/><path d="M8 6h8M12 6v6M8 18h4"/></svg>
                            </div>
                            <div class="cf-select-wrap" style="flex:1;">
                                {{ form_widget(form.secteur, {'attr': {'class': 'cf-select'}}) }}
                                <svg class="cf-select-arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                            </div>
                        </div>
                    </div>
                </div>

                {# ── COLONNE DROITE ── #}
                <div>
                    <div class="cf-section-head">
                        <div class="cf-section-icon cf-section-icon-cyan">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        </div>
                        <span class="cf-section-title">Besoin de Financement</span>
                    </div>
                    <div class="cf-col-divider"></div>

                    {# Montant cible #}
                    <div class="cf-field">
                        <label class="cf-label">Montant cible (DT)</label>
                        <div class="cf-input-group">
                            {{ form_widget(form.targetAmount, {'attr': {'class': 'cf-input cf-input-no-right'}}) }}
                            <div class="cf-suffix-cyan">DT</div>
                        </div>
                        <div class="cf-error">{{ form_errors(form.targetAmount) }}</div>
                    </div>

                    {# Dates #}
                    <div class="cf-field">
                        <div class="cf-date-pair">
                            <div>
                                <label class="cf-label">Date de début</label>
                                <div class="cf-date-wrap">
                                    <svg class="cf-date-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    {{ form_widget(form.startDate, {'attr': {'class': 'cf-input', 'style': 'padding-left: 32px; color-scheme: dark;'}}) }}
                                </div>
                            </div>
                            <div>
                                <label class="cf-label">Échéance de fin</label>
                                <div class="cf-date-wrap">
                                    <svg class="cf-date-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(248,113,113,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    {{ form_widget(form.endDate, {'attr': {'class': 'cf-input', 'style': 'padding-left: 32px; color-scheme: dark;'}}) }}
                                </div>
                                <div class="cf-error">{{ form_errors(form.endDate) }}</div>
                            </div>
                        </div>
                    </div>

                    {# Image URL #}
                    <div class="cf-field">
                        <label class="cf-label">URL de l'image illustrative</label>
                        <div class="cf-input-group">
                            <div class="cf-input-group-icon">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            </div>
                            {{ form_widget(form.imageUrl, {'attr': {'class': 'cf-input', 'placeholder': 'https://...'}}) }}
                        </div>
                    </div>

                    {# Aperçu de l'image actuelle #}
                    {% if projet.imageUrl %}
                    <div class="cf-img-preview">
                        <div class="cf-img-preview-bar">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            <span class="cf-img-preview-label">Aperçu actuel</span>
                        </div>
                        <div class="cf-img-preview-body">
                            <img src="{{ projet.imageUrl }}" alt="Aperçu du projet">
                        </div>
                    </div>
                    {% endif %}
                </div>

            </div>{# end .cf-cols #}

            <div class="cf-divider"></div>

            {# ── SUBMIT ── #}
            <div class="cf-submit-wrap">
                <button type="submit" class="cf-btn-submit">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    Enregistrer les modifications
                </button>
                <p class="cf-submit-note">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Vos modifications seront immédiatement visibles sur le tableau de bord.
                </p>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

</div>


  </div>
  <footer class="site-footer">
    © {{ "now"|date("Y") }} Champions Group. All rights reserved.
  </footer>
</div>
{% endblock %}