{# templates/front_office/credit/listeprojet.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - Champions{% endblock %}

{% block body %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
    :root { --violet: #8353E2; --violet-light: #a77af5; --violet-glow: rgba(131,83,226,0.35); }

    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); min-height: 100vh; }

    /* ── NAV ── */
    .cf-nav { background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
    .cf-nav-brand { display: flex; align-items: center; gap: 12px; }
    .cf-nav-logo { width: 36px; height: 36px; border-radius: 12px; background: linear-gradient(135deg, var(--violet), var(--violet-light)); display: flex; align-items: center; justify-content: center; }
    .cf-nav-title { font-weight: 800; color: #fff; font-size: 1.05rem; }
    .cf-nav-links { display: flex; align-items: center; gap: 24px; }
    .cf-nav-links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color .2s; }
    .cf-nav-links a:hover { color: #fff; }
    .cf-nav-links a.active { color: var(--violet-light); font-weight: 700; }
    .cf-avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--violet), var(--violet-light)); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: #fff; }

    /* ── LAYOUT ── */
    .cf-container { max-width: 1280px; margin: 0 auto; padding: 40px 24px; }

    /* ── HEADER ── */
    .cf-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 36px; gap: 20px; flex-wrap: wrap; }
    .cf-badge-label { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(131,83,226,0.2); color: var(--violet-light); border: 1px solid rgba(131,83,226,0.3); border-radius: 50px; padding: 4px 12px; margin-bottom: 10px; }
    .cf-title { font-size: 1.9rem; font-weight: 800; color: #fff; margin: 0 0 6px; letter-spacing: -0.5px; }
    .cf-subtitle { color: rgba(255,255,255,0.45); font-size: 0.875rem; margin: 0; }
    .cf-btn-new { display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; border-radius: 16px; font-weight: 700; font-size: 0.875rem; color: #fff; text-decoration: none; background: linear-gradient(135deg, var(--violet), var(--violet-light)); box-shadow: 0 8px 32px var(--violet-glow); transition: transform .2s, box-shadow .2s; border: none; cursor: pointer; }
    .cf-btn-new:hover { transform: translateY(-2px); box-shadow: 0 12px 40px var(--violet-glow); color: #fff; }

    /* ── STATS ── */
    .cf-stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
    .cf-stat-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 20px; display: flex; align-items: center; gap: 16px; }
    .cf-stat-icon { width: 44px; height: 44px; border-radius: 14px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .cf-stat-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.4); margin: 0 0 4px; }
    .cf-stat-value { font-size: 1.5rem; font-weight: 800; color: #fff; margin: 0; }

    /* ── FILTER ── */
    .cf-filter-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 20px; margin-bottom: 28px; }
    .cf-filter-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 12px; align-items: end; }
    .cf-filter-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.35); margin-bottom: 8px; display: block; }
    .cf-input-wrap { position: relative; }
    .cf-input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.3); pointer-events: none; }
    .cf-input, .cf-select { width: 100%; padding: 10px 12px; border-radius: 12px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); color: #fff; font-size: 0.875rem; font-family: 'Inter', sans-serif; outline: none; transition: border-color .2s; box-sizing: border-box; }
    .cf-input.with-icon { padding-left: 36px; }
    .cf-input::placeholder { color: rgba(255,255,255,0.25); }
    .cf-input:focus, .cf-select:focus { border-color: var(--violet); }
    .cf-select option { background: #1e1a3a; }
    .cf-btn-filter { width: 100%; padding: 10px; border-radius: 12px; font-weight: 700; font-size: 0.875rem; color: #fff; border: none; cursor: pointer; background: linear-gradient(135deg, var(--violet), var(--violet-light)); box-shadow: 0 4px 20px rgba(131,83,226,0.3); transition: transform .15s; }
    .cf-btn-filter:hover { transform: translateY(-1px); }

    /* ── CARDS GRID ── */
    .cf-cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    @media (max-width: 1100px) { .cf-cards-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px)  { .cf-cards-grid { grid-template-columns: 1fr; } }

    .cf-project-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09); border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; transition: transform .3s ease, box-shadow .3s ease; }
    .cf-project-card:hover { transform: translateY(-8px); box-shadow: 0 24px 60px rgba(0,0,0,0.35); }

    /* image */
    .cf-card-img-wrap { position: relative; height: 190px; overflow: hidden; }
    .cf-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
    .cf-project-card:hover .cf-card-img { transform: scale(1.05); }
    .cf-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(15,12,41,0.85) 0%, transparent 60%); }
    .cf-badge-sector { position: absolute; top: 12px; right: 12px; display: inline-flex; align-items: center; gap: 6px; font-size: 0.7rem; font-weight: 700; padding: 5px 10px; border-radius: 50px; backdrop-filter: blur(8px); }
    .cf-badge-status { position: absolute; bottom: 12px; left: 12px; display: inline-flex; align-items: center; gap: 6px; font-size: 0.7rem; font-weight: 700; padding: 5px 10px; border-radius: 50px; }
    .cf-badge-dot { width: 6px; height: 6px; border-radius: 50%; }
    .status-active   { background: rgba(74,222,128,0.2);  color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
    .status-draft    { background: rgba(250,204,21,0.2);  color: #facc15; border: 1px solid rgba(250,204,21,0.3); }
    .dot-active  { background: #4ade80; }
    .dot-draft   { background: #facc15; }
    .sector-tech { background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
    .sector-agri { background: rgba(34,197,94,0.12);  color: #4ade80; border: 1px solid rgba(34,197,94,0.2);  }
    .sector-sante{ background: rgba(234,179,8,0.15);  color: #facc15; border: 1px solid rgba(234,179,8,0.25); }
    .sector-other{ background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.1); }

    /* card body */
    .cf-card-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
    .cf-card-title { font-weight: 700; color: #fff; font-size: 0.95rem; margin: 0 0 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cf-card-desc  { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin: 0 0 18px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* progress */
    .cf-progress-box { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; padding: 14px; margin-bottom: 14px; }
    .cf-progress-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .cf-progress-lbl { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.35); }
    .cf-progress-val { font-size: 0.8rem; font-weight: 700; color: var(--violet-light); }
    .cf-progress-track { width: 100%; height: 6px; background: rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; }
    .cf-progress-bar  { height: 100%; background: linear-gradient(90deg, var(--violet), var(--violet-light)); border-radius: 10px; }
    .cf-progress-foot { display: flex; justify-content: space-between; margin-top: 6px; }
    .cf-progress-pct  { font-size: 0.65rem; color: rgba(255,255,255,0.25); }
    .cf-progress-pct.right { color: var(--violet-light); font-weight: 700; }

    /* dates */
    .cf-dates { display: flex; justify-content: space-between; margin-bottom: 18px; }
    .cf-date  { display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: rgba(255,255,255,0.4); }

    /* actions */
    .cf-card-actions { display: flex; align-items: center; gap: 8px; margin-top: auto; }
    .cf-btn-edit { flex: 1; padding: 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 700; color: #fff; text-decoration: none; text-align: center; background: linear-gradient(135deg, var(--violet), var(--violet-light)); box-shadow: 0 4px 16px rgba(131,83,226,0.3); transition: transform .15s; border: none; cursor: pointer; display: block; }
    .cf-btn-edit:hover { transform: translateY(-2px); color: #fff; }
    .cf-btn-del { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.22); color: #f87171; cursor: pointer; transition: all .15s; }
    .cf-btn-del:hover { background: #ef4444; color: #fff; transform: translateY(-2px); }

    /* empty */
    .cf-empty { padding: 60px 20px; text-align: center; color: rgba(255,255,255,0.3); }

    /* footer */
    .cf-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 28px; }
    .cf-footer-info { font-size: 0.75rem; color: rgba(255,255,255,0.25); }
    .cf-pagination { display: flex; align-items: center; gap: 6px; }
    .cf-page-btn { width: 32px; height: 32px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.4); font-size: 0.8rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .15s; }
    .cf-page-btn:hover { background: rgba(255,255,255,0.12); }
    .cf-page-btn.active { background: linear-gradient(135deg, var(--violet), var(--violet-light)); color: #fff; border: none; }
</style>

{# ── NAV ── #}
<nav class="cf-nav">
    <div class="cf-nav-brand">
        <div class="cf-nav-logo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
        <span class="cf-nav-title">ChampionsFinance</span>
    </div>
    <div class="cf-nav-links">
        <a href="#">Tableau de bord</a>
        <a href="{{ path('app_projet_index') }}" class="active">Mes Projets</a>
        <a href="#">Financement</a>
        <a href="#">Support</a>
    </div>
    <div class="cf-avatar">{{ app.user ? app.user.prenom|first ~ app.user.nom|first : 'JD' }}</div>
</nav>

<div class="cf-container">

    {# ── HEADER ── #}
    <div class="cf-header">
        <div>
            <span class="cf-badge-label">Tableau de Bord</span>
            <h1 class="cf-title">Mes Projets</h1>
            <p class="cf-subtitle">Gérez et suivez vos initiatives de financement.</p>
        </div>
        <a href="{{ path('app_projet_new') }}" class="cf-btn-new">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Lancer un Projet
        </a>
    </div>

    {# ── STATS ── #}
    <div class="cf-stats-grid">
        <div class="cf-stat-card">
            <div class="cf-stat-icon" style="background:rgba(131,83,226,0.15);border:1px solid rgba(131,83,226,0.25);color:#8353E2;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
                    <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
                </svg>
            </div>
            <div>
                <p class="cf-stat-label">Total Projets</p>
                <p class="cf-stat-value">{{ projets|length }}</p>
            </div>
        </div>
        <div class="cf-stat-card">
            <div class="cf-stat-icon" style="background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.2);color:#4ade80;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div>
                <p class="cf-stat-label">Projets Actifs</p>
                <p class="cf-stat-value">{{ projets|filter(p => p.status == 'ACTIVE')|length }}</p>
            </div>
        </div>
        <div class="cf-stat-card">
            <div class="cf-stat-icon" style="background:rgba(34,211,238,0.12);border:1px solid rgba(34,211,238,0.2);color:#22d3ee;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div>
                <p class="cf-stat-label">Objectif Total</p>
                <p class="cf-stat-value">
                    {% set total = 0 %}{% for p in projets %}{% set total = total + p.targetAmount %}{% endfor %}
                    {{ total|number_format(0, '.', ' ') }} <span style="font-size:0.75rem;color:#22d3ee;">DT</span>
                </p>
            </div>
        </div>
    </div>

    {# ── FILTRES ── #}
    <div class="cf-filter-card">
        <form method="get" action="{{ path('app_projet_index') }}" class="cf-filter-grid">
            <div>
                <label class="cf-filter-label">Rechercher</label>
                <div class="cf-input-wrap">
                    <svg class="cf-input-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" name="q" class="cf-input with-icon" placeholder="Nom du projet..." value="{{ app.request.query.get('q') }}">
                </div>
            </div>
            <div>
                <label class="cf-filter-label">Secteur</label>
                <select name="secteur" class="cf-select">
                    <option value="">Tous</option>
                    <option value="Technologie" {{ app.request.query.get('secteur') == 'Technologie' ? 'selected' : '' }}>Technologie</option>
                    <option value="Agriculture"  {{ app.request.query.get('secteur') == 'Agriculture'  ? 'selected' : '' }}>Agriculture</option>
                    <option value="Sante"        {{ app.request.query.get('secteur') == 'Sante'        ? 'selected' : '' }}>Santé</option>
                </select>
            </div>
            <div>
                <label class="cf-filter-label">Statut</label>
                <select name="status" class="cf-select">
                    <option value="">Tous</option>
                    <option value="DRAFT"  {{ app.request.query.get('status') == 'DRAFT'  ? 'selected' : '' }}>DRAFT</option>
                    <option value="ACTIVE" {{ app.request.query.get('status') == 'ACTIVE' ? 'selected' : '' }}>ACTIVE</option>
                </select>
            </div>
            <div>
                <label class="cf-filter-label">Trier par</label>
                <select name="sortBy" class="cf-select">
                    <option value="date_desc"   {{ app.request.query.get('sortBy') == 'date_desc'   ? 'selected' : '' }}>Plus récent</option>
                    <option value="amount_desc" {{ app.request.query.get('sortBy') == 'amount_desc' ? 'selected' : '' }}>Montant ↑</option>
                    <option value="amount_asc"  {{ app.request.query.get('sortBy') == 'amount_asc'  ? 'selected' : '' }}>Montant ↓</option>
                    <option value="title_asc"   {{ app.request.query.get('sortBy') == 'title_asc'   ? 'selected' : '' }}>Nom (A-Z)</option>
                </select>
            </div>
            <div>
                <button type="submit" class="cf-btn-filter">Filtrer</button>
            </div>
        </form>
    </div>

    {# ── GRILLE DES PROJETS ── #}
    <div class="cf-cards-grid">
        {% for projet in projets %}
        <div class="cf-project-card">

            {# Image + badges #}
            <div class="cf-card-img-wrap">
                <img src="{{ projet.imageUrl ?: 'https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?q=80&w=800' }}"
                     class="cf-card-img" alt="{{ projet.title }}">
                <div class="cf-card-img-overlay"></div>

                {# Secteur #}
                <span class="cf-badge-sector {% if projet.secteur == 'Technologie' %}sector-tech{% elseif projet.secteur == 'Agriculture' %}sector-agri{% elseif projet.secteur == 'Sante' %}sector-sante{% else %}sector-other{% endif %}">
                    <span class="cf-badge-dot" style="background:currentColor;"></span>
                    {{ projet.secteur ?: 'Autre' }}
                </span>

                {# Statut #}
                <span class="cf-badge-status {% if projet.status == 'ACTIVE' %}status-active{% else %}status-draft{% endif %}">
                    <span class="cf-badge-dot {% if projet.status == 'ACTIVE' %}dot-active{% else %}dot-draft{% endif %}"></span>
                    {{ projet.status }}
                </span>
            </div>

            {# Corps #}
            <div class="cf-card-body">
                <h4 class="cf-card-title">{{ projet.title }}</h4>
                <p class="cf-card-desc">{{ projet.description|slice(0, 100) }}...</p>

                {# Progression #}
                <div class="cf-progress-box">
                    <div class="cf-progress-head">
                        <span class="cf-progress-lbl">Objectif</span>
                        <span class="cf-progress-val">{{ projet.targetAmount|number_format(0, '.', ' ') }} DT</span>
                    </div>
                    <div class="cf-progress-track">
                        <div class="cf-progress-bar" style="width: 45%;"></div>
                    </div>
                    <div class="cf-progress-foot">
                        <span class="cf-progress-pct">0%</span>
                        <span class="cf-progress-pct right">45%</span>
                    </div>
                </div>

                {# Dates #}
                <div class="cf-dates">
                    <div class="cf-date">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#8353E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ projet.startDate|date('d/m/Y') }}
                    </div>
                    <div class="cf-date">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ projet.endDate|date('d/m/Y') }}
                    </div>
                </div>

                {# Actions #}
                <div class="cf-card-actions">
                    <a href="{{ path('app_projet_edit', {'id': projet.idProjet}) }}" class="cf-btn-edit">Modifier</a>
                    <form method="post" action="{{ path('app_projet_delete', {'id': projet.idProjet}) }}"
                          onsubmit="return confirm('Voulez-vous vraiment supprimer ce projet ?');" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.idProjet) }}">
                        <button type="submit" class="cf-btn-del">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="cf-empty" style="grid-column: 1/-1;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 16px;display:block;opacity:.2;">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
            <p>Aucun projet trouvé.</p>
        </div>
        {% endfor %}
    </div>

    {# ── PAGINATION ── #}
    <div class="cf-footer">
