{% extends 'base.html.twig' %}

{% block title %}Champions — Invest in Credits{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --bg-card2:     #111b2b;
    --border:       #1a2a40;
    --border-glow:  rgba(0,229,255,.15);
    --accent:       #00e5ff;
    --accent2:      #00b4cc;
    --accent-glow:  rgba(0,229,255,.18);
    --gold:         #f0b429;
    --gold-dim:     rgba(240,180,41,.10);
    --green:        #00e676;
    --green-dim:    rgba(0,230,118,.10);
    --red:          #ff1744;
    --red-dim:      rgba(255,23,68,.10);
    --purple:       #a855f7;
    --purple-dim:   rgba(168,85,247,.12);
    --text-1:       #f0f4ff;
    --text-2:       #b0bdd0;
    --text-3:       #5a7090;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
    --navbar-h:     64px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg-base);
    color: var(--text-1);
    min-height: 100vh;
    overflow-x: hidden;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 3px; }

  /* ── BACKGROUND ── */
  .bg-grid {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(0,229,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,.03) 1px, transparent 1px);
    background-size: 52px 52px;
    animation: gridDrift 25s linear infinite;
  }
  @keyframes gridDrift { 0% { background-position: 0 0; } 100% { background-position: 52px 52px; } }

  .bg-orb { position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .bg-orb-1 {
    width: 600px; height: 600px; top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(0,229,255,.08) 0%, transparent 70%);
    animation: orbFloat 10s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 440px; height: 440px; bottom: -160px; right: -100px;
    background: radial-gradient(circle, rgba(240,180,41,.07) 0%, transparent 70%);
    animation: orbFloat 14s ease-in-out infinite alternate-reverse;
  }
  @keyframes orbFloat { from { transform: translate(0,0) scale(1); } to { transform: translate(28px,18px) scale(1.06); } }

  .app-shell { display: flex; flex-direction: column; min-height: 100vh; position: relative; z-index: 1; }

  /* ── NAVBAR ── */
  .topnav {
    position: sticky; top: 0; z-index: 200; height: var(--navbar-h);
    background: rgba(8,13,20,.97); border-bottom: 1px solid var(--border);
    backdrop-filter: blur(20px);
    display: flex; align-items: center; padding: 0 32px; gap: 0; overflow: hidden;
  }
  .topnav::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.25;
  }
  .topnav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; margin-right: 36px; }
  .logo-icon {
    width: 34px; height: 34px; border-radius: 9px;
    background: linear-gradient(135deg, #1de9b6, #00b4cc);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px; color: #080d14; font-family: var(--font-head);
    box-shadow: 0 0 16px rgba(0,229,255,.3); flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-head); font-size: 18px; font-weight: 700;
    background: linear-gradient(90deg, var(--text-1), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .topnav-links { display: flex; align-items: center; gap: 2px; flex: 1; overflow-x: auto; scrollbar-width: none; }
  .topnav-links::-webkit-scrollbar { display: none; }
  .nav-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 10px; text-decoration: none; color: var(--text-1);
    font-size: 14px; font-weight: 500; transition: all .2s ease; position: relative;
    white-space: nowrap; background: none; border: none; cursor: pointer;
    font-family: var(--font-body); text-align: left; flex-shrink: 0;
  }
  .nav-btn i { font-size: 13px; flex-shrink: 0; }
  .nav-btn:hover { color: var(--text-1); background: rgba(255,255,255,.05); }
  .nav-btn.active { color: var(--accent); background: rgba(0,229,255,.08); border: 1px solid rgba(0,229,255,.15); }
  .nav-btn.active i { color: var(--accent); }
  .nav-btn .nav-badge {
    padding: 1px 7px; border-radius: 20px; background: rgba(0,229,255,.12); color: var(--accent);
    font-size: 10.5px; font-weight: 700; font-family: var(--font-mono); flex-shrink: 0;
  }
  .nav-btn.danger { color: var(--red); }
  .nav-btn.danger:hover { background: rgba(255,23,68,.08); color: var(--red); }
  .topnav-sep { width: 1px; height: 24px; background: var(--border); margin: 0 8px; flex-shrink: 0; }
  .topnav-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-left: 16px; }
  .user-card {
    display: flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 10px;
    background: rgba(255,255,255,.03); border: 1px solid var(--border); cursor: pointer; transition: border-color .2s;
  }
  .user-card:hover { border-color: rgba(0,229,255,.2); }
  .user-avatar {
    width: 28px; height: 28px; border-radius: 8px;
    background: linear-gradient(135deg, rgba(0,229,255,.2), rgba(0,180,204,.2));
    border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--accent); flex-shrink: 0;
  }
  .user-info { line-height: 1.25; }
  .user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }
  .user-role { font-size: 10.5px; color: var(--text-3); font-family: var(--font-mono); }

  /* ── TICKER ── */
  .ticker-wrap { width: 100%; background: rgba(8,13,20,.95); border-top: 1px solid var(--border); height: 38px; overflow: hidden; flex-shrink: 0; }
  .ticker-track { display: flex; align-items: center; height: 100%; white-space: nowrap; animation: tickerScroll 35s linear infinite; width: max-content; }
  .ticker-item { display: inline-flex; align-items: center; gap: 6px; padding: 0 28px; font-size: 13px; font-family: var(--font-mono); color: var(--text-2); border-right: 1px solid var(--border); }
  .ticker-item .sym { color: var(--accent); font-weight: 600; }
  .ticker-item .up { color: var(--green); }
  .ticker-item .dn { color: var(--red); }
  @keyframes tickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── MAIN ── */
  .main-content { flex: 1; padding: 36px 48px 60px; display: flex; flex-direction: column; gap: 28px; }

  /* ── PAGE HEADER ── */
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .page-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
  .page-title { font-family: var(--font-head); font-size: 32px; font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin-bottom: 6px; }
  .page-sub { font-size: 15px; color: var(--text-2); }

  /* ── WALLET BANNER ── */
  .wallet-banner {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 20px 28px; display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap; position: relative; overflow: hidden;
  }
  .wallet-banner::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.4;
  }
  .wallet-banner-left { display: flex; align-items: center; gap: 14px; }
  .wallet-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(0,229,255,.1); border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: 18px; flex-shrink: 0;
  }
  .wallet-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-3); font-family: var(--font-mono); margin-bottom: 4px; }
  .wallet-balance { font-family: var(--font-head); font-size: 24px; font-weight: 800; color: var(--text-1); }
  .wallet-balance span { font-size: 13px; color: var(--accent); font-family: var(--font-mono); margin-left: 5px; }
  .btn-offers {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 10px; font-size: 14px; font-weight: 600;
    font-family: var(--font-body); text-decoration: none;
    background: var(--purple-dim); color: var(--purple);
    border: 1px solid rgba(168,85,247,.25);
    transition: all .2s; white-space: nowrap;
  }
  .btn-offers:hover { background: rgba(168,85,247,.2); color: var(--purple); transform: translateY(-1px); border-color: rgba(168,85,247,.4); }

  /* ── CREDITS GRID ── */
  .credits-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 18px; }

  /* ── CREDIT CARD ── */
  .credit-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 22px; cursor: pointer;
    transition: border-color .25s, transform .2s; position: relative; overflow: hidden;
  }
  .credit-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    border-radius: var(--radius) var(--radius) 0 0;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0; transition: opacity .25s;
  }
  .credit-card:hover { border-color: rgba(0,229,255,.25); transform: translateY(-3px); }
  .credit-card:hover::before { opacity: 1; }

  .credit-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .credit-amount { font-family: var(--font-head); font-size: 22px; font-weight: 800; color: var(--text-1); }
  .credit-currency { font-size: 12px; color: var(--text-3); font-family: var(--font-mono); margin-left: 4px; }
  .credit-badge-open {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: 20px; font-size: 10px; font-weight: 700;
    font-family: var(--font-mono); letter-spacing: .06em;
    background: var(--green-dim); color: var(--green); border: 1px solid rgba(0,230,118,.2);
  }
  .credit-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); }

  .credit-project-name { font-family: var(--font-head); font-size: 15px; font-weight: 700; color: var(--text-1); margin-bottom: 6px; }
  .credit-desc {
    font-size: 13px; color: var(--text-3); line-height: 1.55; margin-bottom: 14px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* progress */
  .progress-track { width: 100%; height: 5px; background: rgba(255,255,255,.06); border-radius: 10px; overflow: hidden; margin-bottom: 8px; }
  .progress-fill  { height: 100%; background: linear-gradient(90deg, var(--green), var(--gold)); border-radius: 10px; transition: width .3s ease; }
  .progress-labels { display: flex; justify-content: space-between; margin-bottom: 14px; }
  .progress-lbl { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-3); }
  .progress-lbl.right { color: var(--accent); font-weight: 700; }

  /* meta row */
  .credit-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding-top: 14px; border-top: 1px solid var(--border); }
  .meta-chip {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--text-3);
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    border-radius: 8px; padding: 7px 10px;
  }
  .meta-chip i { color: var(--accent); font-size: 11px; }
  .meta-chip strong { color: var(--text-1); font-family: var(--font-mono); }

  /* ── MODALS ── */
  .modal-backdrop-custom {
    display: none; position: fixed; inset: 0; z-index: 500;
    background: rgba(4,8,16,.88); backdrop-filter: blur(6px);
    align-items: center; justify-content: center; padding: 20px;
    animation: fadeIn .2s ease both;
  }
  .modal-backdrop-custom.open { display: flex; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .modal-box {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 22px; width: 100%; max-width: 560px;
    box-shadow: 0 40px 100px rgba(0,0,0,.7); position: relative;
    overflow: hidden; animation: modalIn .3s cubic-bezier(.22,1,.36,1) both;
  }
  .modal-box.wide { max-width: 720px; }
  @keyframes modalIn { from { opacity: 0; transform: translateY(18px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  .modal-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.45;
  }

  .modal-header {
    padding: 22px 26px 18px; border-bottom: 1px solid var(--border);
    display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
  }
  .modal-header-left { display: flex; align-items: center; gap: 12px; }
  .modal-header-icon {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    background: rgba(0,229,255,.1); border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center; color: var(--accent); font-size: 15px;
  }
  .modal-title { font-family: var(--font-head); font-size: 18px; font-weight: 700; color: var(--text-1); margin-bottom: 3px; }
  .modal-sub { font-size: 13px; color: var(--text-3); }
  .modal-close {
    width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
    background: rgba(255,255,255,.05); border: 1px solid var(--border);
    color: var(--text-2); cursor: pointer; font-size: 16px;
    display: flex; align-items: center; justify-content: center; transition: all .2s;
  }
  .modal-close:hover { background: rgba(255,23,68,.1); border-color: rgba(255,23,68,.25); color: var(--red); }

  .modal-body { padding: 22px 26px; }

  /* project info block */
  .project-info-block {
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    border-radius: 12px; padding: 16px; margin-bottom: 20px;
  }
  .project-info-title { font-family: var(--font-head); font-size: 14px; font-weight: 700; color: var(--text-1); margin-bottom: 5px; }
  .project-info-desc { font-size: 13px; color: var(--text-3); line-height: 1.55; }

  /* detail grid */
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 6px; }
  .detail-box {
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    border-radius: 12px; padding: 14px; text-align: center;
  }
  .detail-box.highlight { background: var(--red-dim); border-color: rgba(255,23,68,.2); }
  .detail-box .d-val { font-family: var(--font-head); font-size: 20px; font-weight: 800; color: var(--text-1); display: block; margin-bottom: 4px; }
  .detail-box.highlight .d-val { color: var(--red); }
  .detail-box .d-lbl { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-3); font-family: var(--font-mono); }

  .modal-footer {
    padding: 18px 26px; border-top: 1px solid var(--border);
    display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap;
  }

  /* buttons */
  .btn-modal {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px; border-radius: 10px; font-size: 13px; font-weight: 600;
    font-family: var(--font-body); border: none; cursor: pointer; transition: all .2s; white-space: nowrap;
  }
  .btn-modal.secondary { background: rgba(255,255,255,.05); color: var(--text-2); border: 1px solid var(--border); }
  .btn-modal.secondary:hover { border-color: var(--accent); color: var(--accent); }
  .btn-modal.primary { background: var(--accent); color: #080d14; }
  .btn-modal.primary:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,229,255,.25); }
  .btn-modal.purple { background: var(--purple-dim); color: var(--purple); border: 1px solid rgba(168,85,247,.25); }
  .btn-modal.purple:hover { background: rgba(168,85,247,.2); transform: translateY(-1px); }
  .btn-modal.negotiate { background: var(--green-dim); color: var(--green); border: 1px solid rgba(0,230,118,.2); }
  .btn-modal.negotiate:hover { background: var(--green); color: #080d14; transform: translateY(-1px); }

  /* ── RISK MODAL ── */
  .risk-wallet-bar {
    background: rgba(0,229,255,.05); border: 1px solid rgba(0,229,255,.15);
    border-radius: 12px; padding: 14px 18px; margin-bottom: 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;
  }
  .risk-wallet-lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--text-3); font-family: var(--font-mono); }
  .risk-wallet-val { font-family: var(--font-head); font-size: 20px; font-weight: 800; color: var(--accent); }

  .risk-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 18px; }
  .risk-card {
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    border-radius: 12px; padding: 16px; text-align: center;
  }
  .risk-score { font-family: var(--font-head); font-size: 28px; font-weight: 800; margin-bottom: 6px; }
  .risk-score.low    { color: var(--green); }
  .risk-score.medium { color: var(--gold); }
  .risk-score.high   { color: var(--red); }
  .risk-card-lbl { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-3); font-family: var(--font-mono); }

  .recommendation-box {
    background: var(--green-dim); border: 1px solid rgba(0,230,118,.2);
    border-radius: 12px; padding: 16px; margin-bottom: 6px;
  }
  .recommendation-title { font-size: 14px; font-weight: 700; color: var(--green); margin-bottom: 6px; display: flex; align-items: center; gap: 7px; }
  .recommendation-text { font-size: 13px; color: var(--text-2); line-height: 1.6; }

  /* ── FOOTER ── */
  .site-footer { background: rgba(8,13,20,.98); border-top: 1px solid var(--border); position: relative; z-index: 10; flex-shrink: 0; }
  .site-footer::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent); opacity: 0.35; }
  .footer-inner { max-width: 1400px; margin: 0 auto; padding: 40px 48px 28px; display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 40px; }
  .footer-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 14px; }
  .footer-tagline { font-size: 13.5px; color: var(--text-3); line-height: 1.65; max-width: 260px; margin-bottom: 20px; }
  .footer-socials { display: flex; gap: 10px; }
  .social-btn { width: 34px; height: 34px; border-radius: 9px; background: rgba(255,255,255,.04); border: 1px solid var(--border); color: var(--text-3); font-size: 13px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all .2s; }
  .social-btn:hover { color: var(--accent); border-color: rgba(0,229,255,.25); background: rgba(0,229,255,.07); }
  .footer-col-title { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .footer-links li a { font-size: 14px; color: var(--text-3); text-decoration: none; transition: color .2s; }
  .footer-links li a:hover { color: var(--text-1); }
  .footer-bottom { border-top: 1px solid var(--border); padding: 18px 48px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; max-width: 1400px; margin: 0 auto; }
  .footer-copy { font-size: 13px; color: var(--text-3); font-family: var(--font-mono); }
  .footer-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; background: rgba(0,229,255,.07); border: 1px solid rgba(0,229,255,.15); font-size: 11.5px; font-weight: 600; color: var(--accent); font-family: var(--font-mono); }
  .footer-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 900px)  { .main-content { padding: 24px 20px 40px; } .topnav { padding: 0 16px; } .topnav-links .nav-btn span:not(.nav-badge) { display: none; } }
  @media (max-width: 600px)  { .detail-grid { grid-template-columns: 1fr; } .risk-grid { grid-template-columns: 1fr 1fr; } .modal-footer { flex-direction: column; } .btn-modal { width: 100%; justify-content: center; } }
</style>
{% endblock %}

{% block body %}
<div class="bg-grid"></div>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>

<div class="app-shell">

  <!-- ══ NAVBAR ══ -->
  <nav class="topnav">
    <a class="topnav-logo" href="#">
      <div class="logo-icon">C</div>
      <div class="logo-text">Champions</div>
    </a>
    <div class="topnav-links">
      <a href="#" class="nav-btn"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
      <a href="{{ path('app_wallet_index') }}" class="nav-btn"><i class="fas fa-wallet"></i> <span>My Wallets</span></a>
      <a href="{{ path('app_trading_dashboard') }}" class="nav-btn"><i class="fas fa-chart-line"></i> <span>Trades</span></a>
      <a href="{{ path('app_marketplace_index') }}" class="nav-btn"><i class="fas fa-shopping-cart"></i> <span>Marketplace</span></a>
      <div class="topnav-sep"></div>
      <a href="{{ path('app_credit_investor_index') }}" class="nav-btn active">
        <i class="fas fa-hand-holding-usd"></i> <span>Invest</span>
        <span class="nav-badge">{{ creditsWithAmounts|length }}</span>
      </a>
      <a href="{{ path('app_projet_index') }}" class="nav-btn"><i class="fas fa-rocket"></i> <span>Projects</span></a>
      <a href="{{ path('app_formations_index') }}" class="nav-btn"><i class="fas fa-book-open"></i> <span>Formations</span></a>
      <a href="{{ path('app_front_negociation_received') }}" class="nav-btn"><i class="fas fa-handshake"></i> <span>Negotiations</span></a>
    </div>
    <div class="topnav-right">
      <a href="#" class="nav-btn danger" style="padding:8px 12px"><i class="fas fa-sign-out-alt"></i></a>
      <div class="user-card">
        <div class="user-avatar"><i class="fas fa-user"></i></div>
        <div class="user-info">
          <div class="user-name">My Account</div>
          <div class="user-role">INVESTOR</div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══ TICKER ══ -->
  <div class="ticker-wrap">
    <div class="ticker-track">
      {% set ticks = [
        {sym:'BTC/USD', price:'67,412.50', change:'+2.34%', up:true},
        {sym:'ETH/USD', price:'3,521.80',  change:'+1.87%', up:true},
        {sym:'SOL/USD', price:'152.45',    change:'-0.62%', up:false},
        {sym:'BNB/USD', price:'578.20',    change:'+0.94%', up:true},
        {sym:'XRP/USD', price:'0.6120',    change:'-1.10%', up:false},
        {sym:'ADA/USD', price:'0.4530',    change:'+3.21%', up:true},
        {sym:'DOGE/USD',price:'0.1620',    change:'+5.44%', up:true},
        {sym:'AVAX/USD',price:'38.91',     change:'-2.15%', up:false},
        {sym:'LINK/USD',price:'14.72',     change:'+1.23%', up:true},
      ] %}
      {% for t in ticks %}{% for i in 1..2 %}
        <span class="ticker-item">
          <span class="sym">{{ t.sym }}</span>
          {{ t.price }}
          <span class="{{ t.up ? 'up' : 'dn' }}">{{ t.change }}</span>
        </span>
      {% endfor %}{% endfor %}
    </div>
  </div>

  <main class="main-content">

    {# ── PAGE HEADER ── #}
    <div class="page-header">
      <div>
        <div class="page-label">Investor Hub</div>
        <div class="page-title">Invest in Credits</div>
        <div class="page-sub">Browse available funding opportunities and make your move.</div>
      </div>
    </div>

    {# ── WALLET BANNER ── #}
    <div class="wallet-banner">
      <div class="wallet-banner-left">
        <div class="wallet-icon"><i class="fas fa-wallet"></i></div>
        <div>
          <div class="wallet-label">Available Balance</div>
          <div class="wallet-balance">
            {{ walletBalance|number_format(2, ',', ' ') }}<span>€</span>
          </div>
        </div>
      </div>
      <a href="{{ path('app_front_negociation_received') }}" class="btn-offers">
        <i class="fas fa-handshake"></i> View My Active Offers
      </a>
    </div>

    {# ── CREDITS GRID ── #}
    <div class="credits-grid">
      {% for item in creditsWithAmounts %}
        {% set credit = item.credit %}
        {% set totalInvested = item.totalInvested %}
        {% set remainingAmount = item.remainingAmount %}
        {% set progressPercent = (totalInvested / credit.montant * 100)|round %}

        <div class="credit-card"
             onclick="openModal(
               {{ credit.idCredit }},
               '{{ credit.projet.title|e('js') }}',
               '{{ credit.description|e('js') }}',
               '{{ credit.montant }}',
               '{{ credit.taux }}',
               '{{ credit.duree }}',
               '{{ remainingAmount }}',
               '{{ credit.devise }}'
             )">

          <div class="credit-card-top">
            <div>
              <div class="credit-amount">
                {{ credit.montant|number_format(2, ',', ' ') }}<span class="credit-currency">{{ credit.devise }}</span>
              </div>
            </div>
            <div class="credit-badge-open">
              <span class="credit-badge-dot"></span> Available
            </div>
          </div>

          <div class="credit-project-name">{{ credit.projet.title }}</div>
          <div class="credit-desc">{{ credit.description }}</div>

          <div class="progress-track">
            <div class="progress-fill" style="width: {{ progressPercent }}%"></div>
          </div>
          <div class="progress-labels">
            <span class="progress-lbl">Funded: {{ progressPercent }}%</span>
            <span class="progress-lbl right">
              Remaining: {{ remainingAmount|number_format(2, ',', ' ') }} {{ credit.devise }}
            </span>
          </div>

          <div class="credit-meta">
            <div class="meta-chip">
              <i class="fas fa-percent"></i>
              Rate: <strong>{{ credit.taux }}%</strong>
            </div>
            <div class="meta-chip">
              <i class="far fa-clock"></i>
              Duration: <strong>{{ credit.duree }} mo.</strong>
            </div>
          </div>
        </div>
      {% else %}
        <div style="grid-column:1/-1; text-align:center; padding: 70px 20px; color: var(--text-3); font-size: 15px;">
          <i class="fas fa-inbox" style="font-size: 2.5rem; display: block; margin-bottom: 14px; opacity: .25;"></i>
          No investment opportunities available at this time.
        </div>
      {% endfor %}
    </div>

  </main>

  <!-- ══ FOOTER ══ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <a class="footer-logo" href="#">
          <div class="logo-icon">C</div>
          <div class="logo-text">Champions</div>
        </a>
        <p class="footer-tagline">Your all-in-one digital finance platform. Manage fiat, crypto, and trading assets with confidence.</p>
        <div class="footer-socials">
          <a href="#" class="social-btn"><i class="fab fa-x-twitter"></i></a>
          <a href="#" class="social-btn"><i class="fab fa-linkedin-in"></i></a>
          <a href="#" class="social-btn"><i class="fab fa-telegram-plane"></i></a>
          <a href="#" class="social-btn"><i class="fab fa-github"></i></a>
        </div>
      </div>
      <div>
        <div class="footer-col-title">Platform</div>
        <ul class="footer-links">
          <li><a href="{{ path('app_wallet_index') }}"><i class="fas fa-wallet" style="width:14px;margin-right:7px;opacity:.5"></i>My Wallets</a></li>
          <li><a href="{{ path('app_trading_dashboard') }}"><i class="fas fa-chart-line" style="width:14px;margin-right:7px;opacity:.5"></i>Trades</a></li>
          <li><a href="{{ path('app_marketplace_index') }}"><i class="fas fa-shopping-cart" style="width:14px;margin-right:7px;opacity:.5"></i>Marketplace</a></li>
          <li><a href="{{ path('app_formations_index') }}"><i class="fas fa-book-open" style="width:14px;margin-right:7px;opacity:.5"></i>Formations</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">Investing</div>
        <ul class="footer-links">
          <li><a href="{{ path('app_credit_investor_index') }}"><i class="fas fa-hand-holding-usd" style="width:14px;margin-right:7px;opacity:.5"></i>Available Credits</a></li>
          <li><a href="{{ path('app_front_negociation_received') }}"><i class="fas fa-handshake" style="width:14px;margin-right:7px;opacity:.5"></i>My Offers</a></li>
          <li><a href="{{ path('app_projet_index') }}"><i class="fas fa-rocket" style="width:14px;margin-right:7px;opacity:.5"></i>Projects</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">Account</div>
        <ul class="footer-links">
          <li><a href="#"><i class="fas fa-shield-alt" style="width:14px;margin-right:7px;opacity:.5"></i>Security</a></li>
          <li><a href="#"><i class="fas fa-cog" style="width:14px;margin-right:7px;opacity:.5"></i>Settings</a></li>
          <li><a href="#" style="color:var(--red)"><i class="fas fa-sign-out-alt" style="width:14px;margin-right:7px;opacity:.5"></i>Sign Out</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© {{ "now"|date("Y") }} Champions Group. All rights reserved.</span>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="footer-badge"><span class="dot"></span> All systems operational</span>
        <span class="footer-copy" style="font-size:11px">v2.4.1</span>
      </div>
    </div>
  </footer>

</div>

{# ════════════ CREDIT DETAIL MODAL ════════════ #}
<div id="creditModal" class="modal-backdrop-custom" onclick="closeCreditModalBg(event)">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-header-left">
        <div class="modal-header-icon"><i class="fas fa-file-invoice-dollar"></i></div>
        <div>
          <div class="modal-title" id="modalTitle">Credit Details</div>
          <div class="modal-sub" id="modalProject">—</div>
        </div>
      </div>
      <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom: 18px;">
        <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--text-3); font-family:var(--font-mono); margin-bottom:10px;">Associated Project</div>
        <div class="project-info-block">
          <div class="project-info-title" id="projectTitle">—</div>
          <div class="project-info-desc" id="projectDescription">—</div>
        </div>
      </div>
      <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--text-3); font-family:var(--font-mono); margin-bottom:10px;">Credit Details</div>
      <div class="detail-grid">
        <div class="detail-box">
          <span class="d-val" id="creditAmount">—</span>
          <span class="d-lbl">Requested Amount</span>
        </div>
        <div class="detail-box">
          <span class="d-val" id="creditRate">—</span>
          <span class="d-lbl">Interest Rate</span>
        </div>
        <div class="detail-box">
          <span class="d-val" id="creditDuration">—</span>
          <span class="d-lbl">Duration</span>
        </div>
        <div class="detail-box highlight">
          <span class="d-val" id="remainingAmount">—</span>
          <span class="d-lbl">Remaining Amount</span>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-modal secondary" onclick="closeModal()"><i class="fas fa-times"></i> Close</button>
      <button class="btn-modal primary" onclick="openRiskAnalysis()"><i class="fas fa-search"></i> Scan Risk</button>
    </div>
  </div>
</div>

{# ════════════ RISK ANALYSIS MODAL ════════════ #}
<div id="riskModal" class="modal-backdrop-custom" onclick="closeRiskModalBg(event)">
  <div class="modal-box wide" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-header-left">
        <div class="modal-header-icon" style="background:var(--purple-dim); border-color:rgba(168,85,247,.25); color:var(--purple);">
          <i class="fas fa-chart-bar"></i>
        </div>
        <div>
          <div class="modal-title">Investment Risk Analysis</div>
          <div class="modal-sub">AI-powered assessment for this credit</div>
        </div>
      </div>
      <button class="modal-close" onclick="closeRiskModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">

      <div class="risk-wallet-bar">
        <div>
          <div class="risk-wallet-lbl">Your Available Balance</div>
          <div class="risk-wallet-val">{{ walletBalance|number_format(2, ',', ' ') }} €</div>
        </div>
        <span style="font-size:11px; color:var(--text-3); font-family:var(--font-mono);">used to assess affordability</span>
      </div>

      <div class="risk-grid">
        <div class="risk-card">
          <div class="risk-score low">A</div>
          <div class="risk-card-lbl">Risk Rating</div>
        </div>
        <div class="risk-card">
          <div class="risk-score medium">7.2/10</div>
          <div class="risk-card-lbl">Project Reliability</div>
        </div>
        <div class="risk-card">
          <div class="risk-score high">15%</div>
          <div class="risk-card-lbl">Default Risk</div>
        </div>
        <div class="risk-card">
          <div class="risk-score low">8.5/10</div>
          <div class="risk-card-lbl">Profitability</div>
        </div>
      </div>

      <div class="recommendation-box">
        <div class="recommendation-title"><i class="fas fa-check-circle"></i> Investment Recommendation</div>
        <div class="recommendation-text">
          This credit presents a strong risk profile with a solid underlying project.
          Investment is recommended given your available balance and the current market conditions.
        </div>
      </div>

    </div>
    <div class="modal-footer">
      <button class="btn-modal secondary" onclick="closeRiskModal()"><i class="fas fa-times"></i> Close</button>
      <button id="btnDetailedScanner" class="btn-modal purple"><i class="fas fa-chart-pie"></i> Full Report</button>
      <button class="btn-modal negotiate" onclick="openNegotiation()"><i class="fas fa-handshake"></i> Negotiate</button>
    </div>
  </div>
</div>

<script>
let currentCreditId = null;

function openModal(creditId, projectTitle, description, amount, rate, duration, remaining, currency) {
    currentCreditId = creditId;
    document.getElementById('modalTitle').textContent = 'Credit — ' + amount + ' ' + currency;
    document.getElementById('modalProject').textContent = 'Project: ' + projectTitle;
    document.getElementById('projectTitle').textContent = projectTitle;
    document.getElementById('projectDescription').textContent = description;
    document.getElementById('creditAmount').textContent = amount + ' ' + currency;
    document.getElementById('creditRate').textContent = rate + '%';
    document.getElementById('creditDuration').textContent = duration + ' mo.';
    document.getElementById('remainingAmount').textContent = remaining + ' ' + currency;
    document.getElementById('creditModal').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('creditModal').classList.remove('open');
    document.body.style.overflow = '';
}

function closeCreditModalBg(e) {
    if (e.target === document.getElementById('creditModal')) closeModal();
}

function openRiskAnalysis() {
    closeModal();
    const detailedBtn = document.getElementById('btnDetailedScanner');
    detailedBtn.onclick = function() {
        window.location.href = '/front/credit-gestion/investor/scanner/' + currentCreditId;
    };
    document.getElementById('riskModal').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeRiskModal() {
    document.getElementById('riskModal').classList.remove('open');
    document.body.style.overflow = '';
}

function closeRiskModalBg(e) {
    if (e.target === document.getElementById('riskModal')) closeRiskModal();
}

function openNegotiation() {
    window.location.href = '/front/credit-gestion/new-negociation/' + currentCreditId;
}
</script>
{% endblock %}
