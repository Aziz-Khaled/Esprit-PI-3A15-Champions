{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      {% for message in app.flashes('success_json') %}
        try {
          const data = {{ message|raw }};
          Swal.fire({
            title: '<strong>' + data.titre + '</strong>',
            icon: 'success',
            background: '#0e1623',
            color: '#f0f4ff',
            html: `
              <div style="text-align:center; margin-top:12px;">
                <p style="color:#b0bdd0; margin-bottom:14px;">${data.message}</p>
                <div style="padding:14px 18px; background:rgba(0,229,255,.06); border:1px solid rgba(0,229,255,.2); border-radius:10px;">
                  <span style="display:block; font-size:10px; text-transform:uppercase; letter-spacing:.1em; color:#5a7090; font-family:'DM Mono',monospace; margin-bottom:6px;">Remaining amount to fund</span>
                  <h3 style="font-family:'Syne',sans-serif; font-size:1.8rem; font-weight:800; color:#00e5ff; margin:0;">${data.reste}</h3>
                </div>
                ${data.isComplet ? '<div style="margin-top:14px; padding:8px 16px; background:rgba(0,230,118,.12); border:1px solid rgba(0,230,118,.25); border-radius:20px; color:#00e676; font-size:13px; font-weight:700; display:inline-block;">Funding complete! ✅</div>' : ''}
              </div>
            `,
            showCloseButton: true,
            focusConfirm: false,
            confirmButtonText: '<i class="fa fa-thumbs-up"></i> Great!',
            confirmButtonColor: '#00e5ff',
            customClass: { confirmButton: 'swal-confirm-btn' }
          });
        } catch (e) {
          console.error('Error reading flash JSON message', e);
        }
      {% endfor %}
    });
  </script>
  <style>
    .swal-confirm-btn { color: #080d14 !important; font-family: 'Space Grotesk', sans-serif !important; font-weight: 700 !important; }
    .swal2-popup { border: 1px solid #1a2a40 !important; border-radius: 16px !important; }
  </style>
{% endblock %}
