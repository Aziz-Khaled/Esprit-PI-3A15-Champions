{% extends 'base.html.twig' %}

{% block title %}Mes Négociations - Champions{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header p-4 text-white" style="background-color: #343a40;">
            <div class="d-flex align-items-center">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                    <i class="fas fa-handshake"></i>
                </div>
                <div>
                    <h2 class="h4 mb-0 fw-bold">Propositions de Négociation 🚀</h2>
                    <p class="mb-0 small opacity-75">Gérez les offres des investisseurs pour vos projets</p>
                </div>
            </div>
        </div>
        
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="ps-4">PROJET</th>
                        <th>INVESTISSEUR</th>
                        <th>MONTANT</th>
                        <th>TAUX</th>
                        <th class="text-end pe-4">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    {% for offre in offres %}
                    <tr>
                        <td class="ps-4 fw-bold">{{ offre.credit.projet.title }}</td>
                        <td>{{ offre.utilisateur.nom }}</td>
                        <td class="text-primary fw-bold">{{ offre.montant }} DT</td>
                        <td><span class="badge bg-light text-dark border">{{ offre.taux_propose }}%</span></td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <form action="{{ path('app_front_negociation_accept', {id: offre.id_negociation}) }}" method="post">
                                    <button class="btn btn-sm btn-success rounded-pill px-3">Accepter</button>
                                </form>
                                <form action="{{ path('app_front_negociation_delete', {id: offre.id_negociation}) }}" method="post" onsubmit="return confirm('Confirmer le rejet ?');">
                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Rejeter</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="text-center py-5 text-muted">Aucune offre reçue.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}