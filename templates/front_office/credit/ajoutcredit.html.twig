{% extends 'base.html.twig' %}

{% block title %}Nouvelle Demande de Crédit{% endblock %}

{% block body %}
<style id="champions-global-css">
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --bg-card2:     #111b2b;
    --border:       #1a2a40;
    --border-glow:  rgba(0,229,255,.15);
    --accent:       #00e5ff;
    --accent2:      #00b4cc;
    --accent-glow:  rgba(0,229,255,.18);
    --gold:         #f0b429;
    --text-1:       #f0f4ff;
    --text-2:       #f0f4ff;
    --text-3:       #f0f4ff;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
    --navbar-h:     64px;
    --primary-gradient: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);
  }

  body { font-family: var(--font-body) !important; background: var(--bg-base) !important; color: var(--text-1) !important; margin: 0; min-height: 100vh; overflow-x: hidden; }

  /* ── BACKGROUND EFFECTS ── */
  .bg-grid { position: fixed; inset: 0; pointer-events: none; z-index: 0; background-image: linear-gradient(rgba(0,229,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,.03) 1px, transparent 1px); background-size: 52px 52px; animation: gridDrift 25s linear infinite; }
  @keyframes gridDrift { 0% { background-position: 0 0; } 100% { background-position: 52px 52px; } }
  .bg-orb { position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .bg-orb-1 { width: 600px; height: 600px; top: -200px; left: -150px; background: radial-gradient(circle, rgba(0,229,255,.08) 0%, transparent 70%); }
  .bg-orb-2 { width: 440px; height: 440px; bottom: -160px; right: -100px; background: radial-gradient(circle, rgba(240,180,41,.07) 0%, transparent 70%); }

  .app-shell { display: flex; flex-direction: column; min-height: 100vh; position: relative; z-index: 1; }

  /* ── TOPNAV ── */
  .topnav { position: sticky; top: 0; z-index: 200; height: var(--navbar-h); background: rgba(8,13,20,.97); border-bottom: 1px solid var(--border); backdrop-filter: blur(20px); display: flex; align-items: center; padding: 0 32px; flex-shrink: 0; }
  .topnav::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent); opacity: 0.25; }
  .topnav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; margin-right: 36px; }
  .logo-icon { width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(135deg, #1de9b6, #00b4cc); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; color: #080d14; font-family: var(--font-head); box-shadow: 0 0 16px rgba(0,229,255,.3); }
  .logo-text { font-family: var(--font-head); font-size: 18px; font-weight: 700; background: linear-gradient(90deg, var(--text-1), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .topnav-links { display: flex; align-items: center; gap: 2px; flex: 1; overflow-x: auto; scrollbar-width: none; }
  .topnav-links::-webkit-scrollbar { display: none; }
  .nav-btn { display: inline-flex; align-items: center; gap: 7px; padding: 8px 14px; border-radius: 10px; text-decoration: none; color: var(--text-1); font-size: 14px; font-weight: 500; transition: all .2s ease; background: none; border: none; cursor: pointer; text-align: left; flex-shrink: 0; font-family: var(--font-body); }
  .nav-btn:hover { background: rgba(255,255,255,.05); color: var(--text-1); }
  .nav-btn.active { color: var(--accent); background: rgba(0,229,255,.08); border: 1px solid rgba(0,229,255,.15); }
  .topnav-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-left: 16px; }
  .user-card { display: flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 10px; background: rgba(255,255,255,.03); border: 1px solid var(--border); transition: border-color .2s; }
  .user-avatar { width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, rgba(0,229,255,.2), rgba(0,180,204,.2)); display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--accent); }
  .user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }

  /* OVERRIDES TO ASSIMILATE OLD UI */
  .cf-form-card, .form-card, .analytics-card, .card {
    background: var(--bg-card) !important; border: 1px solid var(--border) !important; border-radius: var(--radius) !important; color: var(--text-1) !important;
  }
  .cf-form-card-header, .form-card-header, .analytics-card-header, .card-header {
    background: rgba(0,229,255,.05) !important; border-bottom: 1px solid var(--border) !important; border-radius: var(--radius) var(--radius) 0 0 !important; color: var(--text-1) !important;
  }
  .cf-page-title, .cf-form-card-title, .form-card-title, h1, h2, h3, h4, h5, h6 { color: var(--text-1) !important; font-family: var(--font-head); }
  .cf-page-subtitle, .cf-form-card-sub, p.text-muted, .text-muted { color: var(--text-3) !important; }
  .field-label, .cf-label, .section-title, .cf-section-title { color: var(--accent) !important; }
  .cf-section-num { background: linear-gradient(135deg, var(--accent), #0099cc) !important; color: #080d14 !important; }

  /* inputs */
  .cf-input, .cf-textarea, .cf-select, .form-input, .form-textarea, .form-select-custom, .form-control, .form-select {
    background: rgba(0,0,0,.25) !important; border: 1px solid rgba(90,112,144,.3) !important; color: var(--text-1) !important; border-radius: 12px !important;
  }
  .cf-input:focus, .cf-textarea:focus, .cf-select:focus, .form-input:focus, .form-textarea:focus, .form-select-custom:focus, .form-control:focus {
    border-color: var(--accent) !important; box-shadow: 0 0 0 3px rgba(0,229,255,.1) !important;
  }
  .cf-input-suffix { background: rgba(0,229,255,.1) !important; border: 1px solid rgba(0,229,255,.3) !important; color: var(--accent) !important; }
  .cf-input::placeholder, .form-input::placeholder { color: rgba(255,255,255,0.2) !important; }

  /* buttons */
  .cf-btn-submit, .btn-submit, .btn-submit-full, .btn-primary {
    background: var(--primary-gradient) !important; border: none !important; color: #080d14 !important; border-radius: 14px !important; font-family: var(--font-head) !important; text-transform: uppercase; font-weight: 700 !important;
  }
  .cf-btn-submit:hover, .btn-submit:hover, .btn-submit-full:hover {
    box-shadow: 0 12px 28px rgba(0,229,255,.3) !important; transform: translateY(-2px) !important;
  }
  .btn-cancel, .btn-secondary, .btn-outline-custom { background: transparent !important; color: var(--text-2) !important; border: 1px solid var(--border) !important; }
  .btn-outline-custom:hover { background: rgba(0,229,255,.06) !important; color: var(--accent) !important; border-color: var(--accent) !important; }

  /* tables */
  .table-custom thead tr th, .table thead tr th { background: var(--bg-card2) !important; color: var(--accent) !important; border-bottom: 1px solid var(--border) !important; }
  .table-custom tbody tr, .table tbody tr { border-bottom: 1px solid var(--border) !important; }
  .table-custom tbody tr:hover, .table tbody tr:hover { background: rgba(0,229,255,.025) !important; }
  .table-custom tbody td, .table tbody td { color: var(--text-1) !important; }

  /* general structure alignment mapping */
  .sidebar, .cf-nav { display: none !important; }
  .main-content { margin-left: 0 !important; width: 100% !important; flex: 1; padding: 40px; }
  .cf-container { max-width: 1200px; margin: 0 auto; width: 100%; padding: 40px 24px; flex: 1; }
 
  .site-footer { background: rgba(8,13,20,.98); border-top: 1px solid var(--border); padding: 40px 48px; display: flex; color: var(--text-3); font-size: 13px; margin-top: auto; }
</style>

<div class="bg-grid"></div>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>

<div class="app-shell">
    <nav class="topnav">
    <a class="topnav-logo" href="#">
      <div class="logo-icon">C</div>
      <div class="logo-text">Champions</div>
    </a>
    <div class="topnav-links">
      <a href="{{ path('app_projet_index') }}" class="nav-btn active"><i class="fas fa-box"></i> <span>Mes Projets</span></a>
      <a href="{{ path('app_credit_index')|default('#') }}" class="nav-btn"><i class="fas fa-hand-holding-usd"></i> <span>Mes Crédits</span></a>
      <a href="{{ path('app_front_negociation_received') }}" class="nav-btn"><i class="fas fa-inbox"></i> <span>Offres Reçues</span></a>
    </div>
    <div class="topnav-right">
      <a href="{{ path('app_credit_investor_index') }}" class="nav-btn danger" style="border:1px solid rgba(255,100,100,0.3);"><i class="fas fa-exchange-alt"></i> <span>Vue Investisseur</span></a>
      <div class="user-card">
        <div class="user-avatar"><i class="fas fa-user-tie"></i></div>
        <div class="user-name">Emprunteur</div>
      </div>
    </div>
  </nav>

  <!-- Content Wrapper -->
  <div style="flex: 1; display: flex; flex-direction: column;">


<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
    :root { --violet: #8353E2; --violet-light: #a77af5; --violet-glow: rgba(131,83,226,0.35); }

   

    /* ── NAV ── */
    .cf-nav { background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
    .cf-nav-brand { display: flex; align-items: center; gap: 12px; }
    .cf-nav-logo { width: 36px; height: 36px; border-radius: 12px; background: linear-gradient(135deg, var(--violet), var(--violet-light)); display: flex; align-items: center; justify-content: center; }
    .cf-nav-title { font-weight: 800; color: #fff; font-size: 1.05rem; }
    .cf-nav-links { display: flex; align-items: center; gap: 24px; }
    .cf-nav-links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color .2s; }
    .cf-nav-links a:hover { color: #fff; }
    .cf-nav-links a.active { color: var(--violet-light); font-weight: 700; }
    .cf-avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--violet), var(--violet-light)); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: #fff; }

    /* ── LAYOUT ── */
    .cf-container { max-width: 760px; margin: 0 auto; padding: 40px 24px; }

    /* ── BADGE ── */
    .cf-badge-label { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(131,83,226,0.2); color: var(--violet-light); border: 1px solid rgba(131,83,226,0.3); border-radius: 50px; padding: 4px 12px; margin-bottom: 12px; }
    .cf-page-title { font-size: 1.9rem; font-weight: 800; color: #fff; margin: 0 0 6px; letter-spacing: -0.5px; }
    .cf-page-subtitle { color: rgba(255,255,255,0.45); font-size: 0.875rem; margin: 0 0 32px; }

    /* ── FLASH ALERTS ── */
    .cf-alert { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 16px; font-size: 0.875rem; font-weight: 500; margin-bottom: 18px; }
    .cf-alert-success { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
    .cf-alert-danger  { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.22); color: #f87171; }
    .cf-alert-close { margin-left: auto; background: none; border: none; color: inherit; opacity: .5; cursor: pointer; font-size: 1rem; line-height: 1; transition: opacity .15s; }
    .cf-alert-close:hover { opacity: 1; }

    /* ── ERROR BLOCK ── */
    .cf-errors-block { display: flex; flex-direction: column; gap: 4px; padding: 14px 16px; border-radius: 16px; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); margin-bottom: 22px; }
    .cf-errors-title { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; font-weight: 700; color: #f87171; margin-bottom: 6px; }
    .cf-errors-block ul { margin: 0; padding-left: 20px; }
    .cf-errors-block li { font-size: 0.78rem; color: rgba(248,113,113,0.85); margin-bottom: 2px; }

    /* ── FORM CARD ── */
    .cf-form-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09); border-radius: 28px; overflow: hidden; backdrop-filter: blur(24px); }
    .cf-form-card-header { padding: 20px 32px; display: flex; align-items: center; gap: 14px; background: rgba(131,83,226,0.1); border-bottom: 1px solid rgba(255,255,255,0.07); }
    .cf-form-card-icon { width: 48px; height: 48px; border-radius: 16px; background: linear-gradient(135deg, var(--violet), var(--violet-light)); display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(131,83,226,0.45); flex-shrink: 0; }
    .cf-form-card-title { font-weight: 700; color: #fff; font-size: 1rem; margin: 0; }
    .cf-form-card-sub   { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin: 2px 0 0; }
    .cf-form-card-

    /* ── FIELDS ── */
    .cf-field { margin-bottom: 20px; }
    .cf-label { display: flex; align-items: center; gap: 6px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
    .cf-label svg { color: var(--violet-light); }
    .cf-input, .cf-textarea, .cf-select {
        width: 100%; padding: 12px 16px; border-radius: 14px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        color: #fff; font-size: 0.875rem; font-family: 'Inter', sans-serif;
        outline: none; transition: border-color .2s, background .2s; box-sizing: border-box;
    }
    .cf-input::placeholder, .cf-textarea::placeholder { color: rgba(255,255,255,0.22); }
    .cf-input:focus, .cf-textarea:focus, .cf-select:focus { border-color: var(--violet); background: rgba(131,83,226,0.06); }
    .cf-textarea { resize: none; }
    .cf-select { appearance: none; -webkit-appearance: none; }
    .cf-select option { background: #1e1a3a; }
    .cf-select-wrap { position: relative; }
    .cf-select-arrow { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); pointer-events: none; color: rgba(255,255,255,0.3); }

    /* input with icon/suffix */
    .cf-input-wrap { position: relative; }
    .cf-input-prefix { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); pointer-events: none; color: rgba(255,255,255,0.25); }
    .cf-input-wrap .cf-input.has-prefix { padding-left: 38px; }
    .cf-input-suffix-tag { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 0.75rem; font-weight: 700; pointer-events: none; }

    /* 2-col grid */
    .cf-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .cf-grid-7-5 { display: grid; grid-template-columns: 7fr 5fr; gap: 16px; }
    @media (max-width: 600px) { .cf-grid-2, .cf-grid-7-5 { grid-template-columns: 1fr; } }

    /* error */
    .cf-error { font-size: 0.72rem; color: #f87171; margin-top: 5px; }

    /* divider */
    .cf-divider { width: 100%; height: 1px; background: rgba(255,255,255,0.06); margin: 28px 0; }

    /* actions */
    .cf-actions { display: flex; flex-direction: column; gap: 12px; }
    @media (min-width: 640px) { .cf-actions { flex-direction: row; } }
    .cf-btn-submit {
        flex: 1; padding: 15px; border-radius: 20px; border: none; cursor: pointer;
        font-weight: 700; font-size: 0.9rem; color: #fff; letter-spacing: .06em;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        box-shadow: 0 8px 32px rgba(131,83,226,0.4);
        transition: transform .2s, box-shadow .2s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .cf-btn-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(131,83,226,0.55); }
    .cf-btn-cancel {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        padding: 15px 28px; border-radius: 20px; font-weight: 600; font-size: 0.875rem;
        text-decoration: none; background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.55);
        transition: background .15s;
    }
    .cf-btn-cancel:hover { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
</style>

{# ── NAV ── #}


<div class="cf-container">

    {# ── FLASH MESSAGES ── #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="cf-alert cf-alert-{{ label == 'danger' ? 'danger' : 'success' }}">
                {% if label == 'danger' %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {% else %}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {% endif %}
                {{ message }}
                <button class="cf-alert-close" onclick="this.parentElement.remove()">✕</button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ── HEADER ── #}
    <span class="cf-badge-label">Espace Financement</span>
    <h1 class="cf-page-title">Nouvelle Demande de Crédit</h1>
    <p class="cf-page-subtitle">Complétez les informations pour votre projet "Champions"</p>

    {# ── FORM CARD ── #}
    <div class="cf-form-card">

        <div class="cf-form-card-header">
            <div class="cf-form-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div>
                <p class="cf-form-card-title">Demande de Financement</p>
                <p class="cf-form-card-sub">Complétez les informations pour votre projet "Champions"</p>
            </div>
        </div>

        <div class="cf-form-card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            {# ── BLOC ERREURS ── #}
            {% if not form.vars.valid %}
            <div class="cf-errors-block">
                <div class="cf-errors-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Erreurs de validation détectées :
                </div>
                <ul>
                    {% for error in form.vars.errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                    {% for child in form.children %}
                        {% if child.vars.errors is defined %}
                            {% for error in child.vars.errors %}
                                <li><strong>{{ child.vars.label|default(child.vars.name)|capitalize }} :</strong> {{ error.message }}</li>
                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            {# ── PROJET ── #}
            <div class="cf-field">
                <label class="cf-label">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
                    {{ form_label(form.projet) }}
                </label>
                <div class="cf-select-wrap">
                    {{ form_widget(form.projet, {'attr': {'class': 'cf-select'}}) }}
                    <svg class="cf-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
                <div class="cf-error">{{ form_errors(form.projet) }}</div>
            </div>

            {# ── MONTANT + DEVISE ── #}
            <div class="cf-grid-7-5">
                <div class="cf-field">
                    <label class="cf-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        {{ form_label(form.montant) }}
                    </label>
                    <div class="cf-input-wrap">
                        <svg class="cf-input-prefix" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        {{ form_widget(form.montant, {'attr': {'class': 'cf-input has-prefix', 'placeholder': 'Ex: 50 000'}}) }}
                    </div>
                    <div class="cf-error">{{ form_errors(form.montant) }}</div>
                </div>
                <div class="cf-field">
                    <label class="cf-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        {{ form_label(form.devise) }}
                    </label>
                    <div class="cf-select-wrap">
                        {{ form_widget(form.devise, {'attr': {'class': 'cf-select'}}) }}
                        <svg class="cf-select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>
                    <div class="cf-error">{{ form_errors(form.devise) }}</div>
                </div>
            </div>

            {# ── TAUX + DURÉE ── #}
            <div class="cf-grid-2">
                <div class="cf-field">
                    <label class="cf-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                        {{ form_label(form.taux) }}
                    </label>
                    <div class="cf-input-wrap">
                        {{ form_widget(form.taux, {'attr': {'class': 'cf-input', 'placeholder': 'Ex: 2.5', 'style': 'padding-right: 38px;'}}) }}
                        <span class="cf-input-suffix-tag" style="color:#a77af5;">%</span>
                    </div>
                    <div class="cf-error">{{ form_errors(form.taux) }}</div>
                </div>
                <div class="cf-field">
                    <label class="cf-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ form_label(form.duree) }}
                    </label>
                    <div class="cf-input-wrap">
                        {{ form_widget(form.duree, {'attr': {'class': 'cf-input', 'placeholder': 'Nombre de mois', 'style': 'padding-right: 52px;'}}) }}
                        <span class="cf-input-suffix-tag" style="color:rgba(255,255,255,0.3);font-size:0.7rem;">mois</span>
                    </div>
                    <div class="cf-error">{{ form_errors(form.duree) }}</div>
                </div>
            </div>

            {# ── DESCRIPTION ── #}
            <div class="cf-field">
                <label class="cf-label">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="21" y1="18" x2="3" y2="18"/></svg>
                    {{ form_label(form.description) }}
                </label>
                {{ form_widget(form.description, {'attr': {'class': 'cf-textarea', 'rows': '4', 'placeholder': 'Détails sur votre projet de financement...'}}) }}
                <div class="cf-error">{{ form_errors(form.description) }}</div>
            </div>

            <div class="cf-divider"></div>

            {# ── ACTIONS ── #}
            <div class="cf-actions">
                <button type="submit" class="cf-btn-submit">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                    ENVOYER LA DEMANDE
                </button>
                <a href="{{ path('app_credit_index') }}" class="cf-btn-cancel">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

</div>


  </div>
  <footer class="site-footer">
    © {{ "now"|date("Y") }} Champions Group. All rights reserved.
  </footer>
</div>
{% endblock %}