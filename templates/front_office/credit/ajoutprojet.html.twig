{# templates/front_office/credit/ajoutprojet.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Champions — New Project{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --bg-card2:     #111b2b;
    --border:       #1a2a40;
    --border-glow:  rgba(0,229,255,.15);
    --accent:       #00e5ff;
    --accent2:      #00b4cc;
    --accent-glow:  rgba(0,229,255,.18);
    --gold:         #f0b429;
    --gold-dim:     rgba(240,180,41,.10);
    --green:        #00e676;
    --red:          #ff1744;
    --text-1:       #f0f4ff;
    --text-2:       #b0bdd0;
    --text-3:       #5a7090;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
    --navbar-h:     64px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg-base);
    color: var(--text-1);
    min-height: 100vh;
    overflow-x: hidden;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 3px; }

  /* ── BACKGROUND ── */
  .bg-grid {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(0,229,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,.03) 1px, transparent 1px);
    background-size: 52px 52px;
    animation: gridDrift 25s linear infinite;
  }
  @keyframes gridDrift { 0% { background-position: 0 0; } 100% { background-position: 52px 52px; } }

  .bg-orb { position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .bg-orb-1 {
    width: 600px; height: 600px; top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(0,229,255,.08) 0%, transparent 70%);
    animation: orbFloat 10s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 440px; height: 440px; bottom: -160px; right: -100px;
    background: radial-gradient(circle, rgba(240,180,41,.07) 0%, transparent 70%);
    animation: orbFloat 14s ease-in-out infinite alternate-reverse;
  }
  @keyframes orbFloat { from { transform: translate(0,0) scale(1); } to { transform: translate(28px,18px) scale(1.06); } }

  .app-shell { display: flex; flex-direction: column; min-height: 100vh; position: relative; z-index: 1; }

  /* ── NAVBAR ── */
  .topnav {
    position: sticky; top: 0; z-index: 200; height: var(--navbar-h);
    background: rgba(8,13,20,.97); border-bottom: 1px solid var(--border);
    backdrop-filter: blur(20px);
    display: flex; align-items: center; padding: 0 32px; gap: 0; overflow: hidden;
  }
  .topnav::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.25;
  }
  .topnav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; margin-right: 36px; }
  .logo-icon {
    width: 34px; height: 34px; border-radius: 9px;
    background: linear-gradient(135deg, #1de9b6, #00b4cc);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px; color: #080d14; font-family: var(--font-head);
    box-shadow: 0 0 16px rgba(0,229,255,.3); flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-head); font-size: 18px; font-weight: 700;
    background: linear-gradient(90deg, var(--text-1), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .topnav-links { display: flex; align-items: center; gap: 2px; flex: 1; overflow-x: auto; scrollbar-width: none; }
  .topnav-links::-webkit-scrollbar { display: none; }
  .nav-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 10px; text-decoration: none; color: var(--text-1);
    font-size: 14px; font-weight: 500; transition: all .2s ease; position: relative;
    white-space: nowrap; background: none; border: none; cursor: pointer;
    font-family: var(--font-body); text-align: left; flex-shrink: 0;
  }
  .nav-btn i { font-size: 13px; flex-shrink: 0; }
  .nav-btn:hover { color: var(--text-1); background: rgba(255,255,255,.05); }
  .nav-btn.active { color: var(--accent); background: rgba(0,229,255,.08); border: 1px solid rgba(0,229,255,.15); }
  .nav-btn.active i { color: var(--accent); }
  .nav-btn.danger { color: var(--red); }
  .nav-btn.danger:hover { background: rgba(255,23,68,.08); color: var(--red); }
  .topnav-sep { width: 1px; height: 24px; background: var(--border); margin: 0 8px; flex-shrink: 0; }
  .topnav-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-left: 16px; }
  .user-card {
    display: flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 10px;
    background: rgba(255,255,255,.03); border: 1px solid var(--border); cursor: pointer; transition: border-color .2s;
  }
  .user-card:hover { border-color: rgba(0,229,255,.2); }
  .user-avatar {
    width: 28px; height: 28px; border-radius: 8px;
    background: linear-gradient(135deg, rgba(0,229,255,.2), rgba(0,180,204,.2));
    border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--accent); flex-shrink: 0;
  }
  .user-info { line-height: 1.25; }
  .user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }
  .user-role { font-size: 10.5px; color: var(--text-3); font-family: var(--font-mono); }

  /* ── TICKER ── */
  .ticker-wrap { width: 100%; background: rgba(8,13,20,.95); border-top: 1px solid var(--border); height: 38px; overflow: hidden; flex-shrink: 0; }
  .ticker-track { display: flex; align-items: center; height: 100%; white-space: nowrap; animation: tickerScroll 35s linear infinite; width: max-content; }
  .ticker-item { display: inline-flex; align-items: center; gap: 6px; padding: 0 28px; font-size: 13px; font-family: var(--font-mono); color: var(--text-2); border-right: 1px solid var(--border); }
  .ticker-item .sym { color: var(--accent); font-weight: 600; }
  .ticker-item .up { color: var(--green); }
  .ticker-item .dn { color: var(--red); }
  @keyframes tickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── MAIN ── */
  .main-content { flex: 1; padding: 40px 48px 60px; display: flex; flex-direction: column; gap: 28px; }
  .cf-container { max-width: 1000px; margin: 0 auto; width: 100%; }

  /* ── BACK LINK ── */
  .cf-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 600; color: var(--accent);
    text-decoration: none; margin-bottom: 28px; transition: color .2s, gap .2s;
  }
  .cf-back:hover { color: var(--text-1); gap: 12px; }

  /* ── PAGE HEADER ── */
  .page-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
  .page-title { font-family: var(--font-head); font-size: 32px; font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin-bottom: 6px; color: var(--text-1); }
  .page-sub { font-size: 15px; color: var(--text-2); margin-bottom: 32px; }

  /* ── FORM CARD ── */
  .cf-form-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    overflow: hidden; position: relative;
  }
  .cf-form-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.3;
  }

  /* card header */
  .cf-form-card-header {
    padding: 22px 32px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 14px;
    background: rgba(0,229,255,.03);
  }
  .cf-form-card-icon {
    width: 42px; height: 42px; border-radius: 12px;
    background: rgba(0,229,255,.1); border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-size: 17px; flex-shrink: 0;
  }
  .cf-form-card-title { font-family: var(--font-head); font-weight: 700; color: var(--text-1); font-size: 16px; margin: 0 0 3px; }
  .cf-form-card-sub   { font-size: 13px; color: var(--text-3); margin: 0; }

  /* card body */
  .cf-form-card-body { padding: 32px; }

  /* ── FORM GRID ── */
  .cf-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  @media (max-width: 768px) { .cf-form-grid { grid-template-columns: 1fr; } }

  /* ── SECTION HEADS ── */
  .cf-section-head { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
  .cf-section-num {
    width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 800; color: #080d14; flex-shrink: 0;
    font-family: var(--font-head);
  }
  .num-cyan { background: linear-gradient(135deg, var(--accent), #0099cc); }
  .num-gold { background: linear-gradient(135deg, var(--gold), #e09000); }
  .cf-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--text-3); margin: 0; font-family: var(--font-mono); }
  .cf-divider { width: 100%; height: 1px; background: var(--border); margin-bottom: 22px; }

  /* ── FIELDS ── */
  .cf-field { margin-bottom: 20px; }
  .cf-label {
    display: block; font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--text-3); margin-bottom: 8px;
    font-family: var(--font-mono);
  }

  .cf-input, .cf-textarea, .cf-select {
    width: 100%; padding: 11px 15px; border-radius: 10px;
    background: rgba(0,0,0,.25); border: 1px solid rgba(90,112,144,.3);
    color: var(--text-1); font-size: 14px; font-family: var(--font-body);
    outline: none; transition: border-color .2s, box-shadow .2s; box-sizing: border-box;
  }
  .cf-input::placeholder, .cf-textarea::placeholder { color: var(--text-3); opacity: .7; }
  .cf-input:focus, .cf-textarea:focus, .cf-select:focus {
    border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,229,255,.1);
  }
  .cf-textarea { resize: none; }
  .cf-select { appearance: none; -webkit-appearance: none; cursor: pointer; }
  .cf-select option { background: #111b2b; }

  /* select wrap */
  .cf-select-wrap { position: relative; }
  .cf-select-arrow {
    position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
    pointer-events: none; color: var(--text-3);
  }

  /* input group (with suffix) */
  .cf-input-group { display: flex; }
  .cf-input-group .cf-input { border-radius: 10px 0 0 10px; border-right: none; flex: 1; }
  .cf-input-suffix {
    display: flex; align-items: center; padding: 0 16px;
    border-radius: 0 10px 10px 0; font-weight: 700; font-size: 13px;
    background: rgba(0,229,255,.08); border: 1px solid rgba(0,229,255,.2);
    color: var(--accent); white-space: nowrap; font-family: var(--font-mono);
  }

  /* input with icon */
  .cf-input-icon-wrap { position: relative; }
  .cf-input-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--text-3); }
  .cf-input-icon-wrap .cf-input { padding-left: 38px; }

  /* dates grid */
  .cf-dates-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  /* info box */
  .cf-info-box {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 16px; border-radius: 12px;
    background: rgba(0,229,255,.04); border: 1px dashed rgba(0,229,255,.2);
    margin-top: 4px;
  }
  .cf-info-icon { color: var(--accent); flex-shrink: 0; margin-top: 2px; font-size: 13px; }
  .cf-info-text { font-size: 13px; color: var(--text-3); margin: 0; line-height: 1.55; }
  .cf-info-text strong { color: var(--gold); }

  /* error */
  .cf-error { font-size: 11.5px; color: var(--red); margin-top: 5px; font-family: var(--font-mono); }

  /* ── SUBMIT SECTION ── */
  .cf-submit-wrap { margin-top: 36px; }
  .cf-divider-bottom { width: 100%; height: 1px; background: var(--border); margin-bottom: 28px; }
  .cf-btn-submit {
    width: 100%; padding: 16px; border-radius: 12px; border: none; cursor: pointer;
    font-weight: 700; font-size: 15px; color: #080d14;
    background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);
    box-shadow: 0 8px 32px rgba(0,229,255,.25);
    transition: transform .2s, box-shadow .2s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    font-family: var(--font-head); letter-spacing: .04em;
  }
  .cf-btn-submit:hover { transform: translateY(-2px); box-shadow: 0 14px 40px rgba(0,229,255,.4); }

  /* date input dark */
  input[type="date"] { color-scheme: dark; }

  /* ── FOOTER ── */
  .site-footer { background: rgba(8,13,20,.98); border-top: 1px solid var(--border); position: relative; z-index: 10; flex-shrink: 0; }
  .site-footer::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent); opacity: 0.35; }
  .footer-inner { max-width: 1400px; margin: 0 auto; padding: 40px 48px 28px; display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 40px; }
  .footer-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 14px; }
  .footer-tagline { font-size: 13.5px; color: var(--text-3); line-height: 1.65; max-width: 260px; margin-bottom: 20px; }
  .footer-socials { display: flex; gap: 10px; }
  .social-btn { width: 34px; height: 34px; border-radius: 9px; background: rgba(255,255,255,.04); border: 1px solid var(--border); color: var(--text-3); font-size: 13px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all .2s; }
  .social-btn:hover { color: var(--accent); border-color: rgba(0,229,255,.25); background: rgba(0,229,255,.07); }
  .footer-col-title { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); margin-bottom: 14px; }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .footer-links li a { font-size: 14px; color: var(--text-3); text-decoration: none; transition: color .2s; }
  .footer-links li a:hover { color: var(--text-1); }
  .footer-bottom { border-top: 1px solid var(--border); padding: 18px 48px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; max-width: 1400px; margin: 0 auto; }
  .footer-copy { font-size: 13px; color: var(--text-3); font-family: var(--font-mono); }
  .footer-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; background: rgba(0,229,255,.07); border: 1px solid rgba(0,229,255,.15); font-size: 11.5px; font-weight: 600; color: var(--accent); font-family: var(--font-mono); }
  .footer-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 900px)  { .main-content { padding: 24px 20px 40px; } .topnav { padding: 0 16px; } .topnav-links .nav-btn span:not(.nav-badge) { display: none; } }
</style>
{% endblock %}

{% block body %}
<div class="bg-grid"></div>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>

<div class="app-shell">

  <!-- ══ NAVBAR ══ -->
  <nav class="topnav">
    <a class="topnav-logo" href="#">
      <div class="logo-icon">C</div>
      <div class="logo-text">Champions</div>
    </a>
    <div class="topnav-links">
      <a href="#" class="nav-btn"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
      <a href="{{ path('app_wallet_index') }}" class="nav-btn"><i class="fas fa-wallet"></i> <span>My Wallets</span></a>
      <a href="{{ path('app_trading_dashboard') }}" class="nav-btn"><i class="fas fa-chart-line"></i> <span>Trades</span></a>
      <a href="{{ path('app_marketplace_index') }}" class="nav-btn"><i class="fas fa-shopping-cart"></i> <span>Marketplace</span></a>
      <a href="{{ path('app_credit_index') }}" class="nav-btn"><i class="fas fa-hand-holding-usd"></i> <span>Credit</span></a>
      <div class="topnav-sep"></div>
      <a href="{{ path('app_projet_index') }}" class="nav-btn active">
        <i class="fas fa-rocket"></i> <span>Projects</span>
      </a>
      <a href="{{ path('app_formations_index') }}" class="nav-btn"><i class="fas fa-book-open"></i> <span>Formations</span></a>
      <a href="{{ path('app_front_negociation_received') }}" class="nav-btn"><i class="fas fa-handshake"></i> <span>Negotiations</span></a>
    </div>
    <div class="topnav-right">
      <a href="{{ path('app_credit_investor_index') }}" class="nav-btn danger" style="border:1px solid rgba(255,23,68,.2); padding: 8px 14px;">
        <i class="fas fa-exchange-alt"></i> <span>Investor View</span>
      </a>
      <a href="#" class="nav-btn danger" style="padding:8px 12px"><i class="fas fa-sign-out-alt"></i></a>
      <div class="user-card">
        <div class="user-avatar"><i class="fas fa-user-tie"></i></div>
        <div class="user-info">
          <div class="user-name">My Account</div>
          <div class="user-role">BORROWER</div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══ TICKER ══ -->
  <div class="ticker-wrap">
    <div class="ticker-track">
      {% set ticks = [
        {sym:'BTC/USD', price:'67,412.50', change:'+2.34%', up:true},
        {sym:'ETH/USD', price:'3,521.80',  change:'+1.87%', up:true},
        {sym:'SOL/USD', price:'152.45',    change:'-0.62%', up:false},
        {sym:'BNB/USD', price:'578.20',    change:'+0.94%', up:true},
        {sym:'XRP/USD', price:'0.6120',    change:'-1.10%', up:false},
        {sym:'ADA/USD', price:'0.4530',    change:'+3.21%', up:true},
        {sym:'DOGE/USD',price:'0.1620',    change:'+5.44%', up:true},
        {sym:'AVAX/USD',price:'38.91',     change:'-2.15%', up:false},
        {sym:'LINK/USD',price:'14.72',     change:'+1.23%', up:true},
      ] %}
      {% for t in ticks %}{% for i in 1..2 %}
        <span class="ticker-item">
          <span class="sym">{{ t.sym }}</span>
          {{ t.price }}
          <span class="{{ t.up ? 'up' : 'dn' }}">{{ t.change }}</span>
        </span>
      {% endfor %}{% endfor %}
    </div>
  </div>

  <main class="main-content">
    <div class="cf-container">

      {# ── BACK LINK ── #}
      <a href="{{ path('app_projet_index') }}" class="cf-back">
        <i class="fas fa-arrow-left" style="font-size:12px"></i>
        Back to Projects
      </a>

      {# ── PAGE HEADER ── #}
      <div class="page-label">New File</div>
      <h1 class="page-title">Create a Project</h1>
      <p class="page-sub">Configure your project before proceeding to the credit simulation.</p>

      {# ── FORM CARD ── #}
      <div class="cf-form-card">

        {# Card Header #}
        <div class="cf-form-card-header">
          <div class="cf-form-card-icon">
            <i class="fas fa-rocket"></i>
          </div>
          <div>
            <p class="cf-form-card-title">New Project</p>
            <p class="cf-form-card-sub">Fill in the information below to get started</p>
          </div>
        </div>

        {# Form Body #}
        <div class="cf-form-card-body">
          {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

          <div class="cf-form-grid">

            {# ── Section 1 : General Information ── #}
            <div>
              <div class="cf-section-head">
                <div class="cf-section-num num-cyan">1</div>
                <h5 class="cf-section-title">General Information</h5>
              </div>
              <div class="cf-divider"></div>

              <div class="cf-field">
                {{ form_label(form.title, 'Project Title', {'label_attr': {'class': 'cf-label'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'cf-input', 'placeholder': 'Your company name or idea'}}) }}
                <div class="cf-error">{{ form_errors(form.title) }}</div>
              </div>

              <div class="cf-field">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'cf-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'cf-textarea', 'rows': '5', 'placeholder': 'Describe your project in detail…'}}) }}
                <div class="cf-error">{{ form_errors(form.description) }}</div>
              </div>

              <div class="cf-field">
                {{ form_label(form.secteur, 'Sector', {'label_attr': {'class': 'cf-label'}}) }}
                <div class="cf-select-wrap">
                  {{ form_widget(form.secteur, {'attr': {'class': 'cf-select'}}) }}
                  <svg class="cf-select-arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
                <div class="cf-error">{{ form_errors(form.secteur) }}</div>
              </div>
            </div>

            {# ── Section 2 : Funding Requirements ── #}
            <div>
              <div class="cf-section-head">
                <div class="cf-section-num num-gold">2</div>
                <h5 class="cf-section-title">Funding Requirements</h5>
              </div>
              <div class="cf-divider"></div>

              <div class="cf-field">
                {{ form_label(form.targetAmount, 'Requested Amount (DT)', {'label_attr': {'class': 'cf-label'}}) }}
                <div class="cf-input-group">
                  {{ form_widget(form.targetAmount, {'attr': {'class': 'cf-input', 'placeholder': '0'}}) }}
                  <div class="cf-input-suffix">DT</div>
                </div>
                <div class="cf-error">{{ form_errors(form.targetAmount) }}</div>
              </div>

              <div class="cf-field cf-dates-grid">
                <div>
                  {{ form_label(form.startDate, 'Start Date', {'label_attr': {'class': 'cf-label'}}) }}
                  <div class="cf-input-icon-wrap">
                    <i class="far fa-calendar-days cf-input-icon" style="font-size:12px"></i>
                    {{ form_widget(form.startDate, {'attr': {'class': 'cf-input'}}) }}
                  </div>
                  <div class="cf-error">{{ form_errors(form.startDate) }}</div>
                </div>
                <div>
                  {{ form_label(form.endDate, 'End Date', {'label_attr': {'class': 'cf-label'}}) }}
                  <div class="cf-input-icon-wrap">
                    <i class="far fa-calendar-check cf-input-icon" style="font-size:12px; color: var(--red);"></i>
                    {{ form_widget(form.endDate, {'attr': {'class': 'cf-input'}}) }}
                  </div>
                  <div class="cf-error">{{ form_errors(form.endDate) }}</div>
                </div>
              </div>

              <div class="cf-field">
                {{ form_label(form.imageUrl, 'Project Image (URL)', {'label_attr': {'class': 'cf-label'}}) }}
                <div class="cf-input-icon-wrap">
                  <i class="fas fa-image cf-input-icon" style="font-size:12px"></i>
                  {{ form_widget(form.imageUrl, {'attr': {'class': 'cf-input', 'placeholder': 'https://…'}}) }}
                </div>
                <div class="cf-error">{{ form_errors(form.imageUrl) }}</div>
              </div>

              <div class="cf-info-box">
                <span class="cf-info-icon"><i class="fas fa-lock"></i></span>
                <p class="cf-info-text">
                  The status will be set to <strong>DRAFT</strong> by default until validation by our team.
                </p>
              </div>
            </div>

          </div>{# end cf-form-grid #}

          {# ── SUBMIT ── #}
          <div class="cf-submit-wrap">
            <div class="cf-divider-bottom"></div>
            <button type="submit" class="cf-btn-submit">
              <i class="fas fa-rocket"></i>
              Create Project &amp; Simulate Credit
            </button>
          </div>

          {{ form_end(form) }}
        </div>{# end cf-form-card-body #}
      </div>{# end cf-form-card #}

    </div>{# end cf-container #}
  </main>

