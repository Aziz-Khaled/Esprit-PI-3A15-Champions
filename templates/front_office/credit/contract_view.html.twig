{% extends 'base.html.twig' %}

{% block title %}Signature Certifiée | Champions Fintech{% endblock %}

{% block body %}
<div class="container-fluid py-5 bg-premium">
    <div class="container">
        {# Barre de progression interactive #}
        <div class="row mb-5 justify-content-center">
            <div class="col-md-8 text-center">
                <div class="stepper-wrapper">
                    <div class="stepper-item completed">
                        <div class="step-counter"><i class="fas fa-check"></i></div>
                        <div class="step-name text-muted">Négociation</div>
                    </div>
                    <div class="stepper-item active">
                        <div class="step-counter shadow-pulse">2</div>
                        <div class="step-name fw-bold">Certification</div>
                    </div>
                    <div class="stepper-item">
                        <div class="step-counter">3</div>
                        <div class="step-name text-muted">Finalisation</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            {# Colonne Gauche : Détails techniques #}
            <div class="col-lg-4">
                <div class="glass-card p-4 h-100">
                    <h5 class="text-uppercase small fw-bold text-primary mb-4">Récapitulatif financier</h5>
                    
                    <div class="info-item mb-3">
                        <label class="d-block text-muted small">Capital engagé</label>
                        <span class="h4 fw-bold text-dark">{{ negociation.montant|number_format(2, ',', ' ') }} <small>DT</small></span>
                    </div>

                    <div class="info-item mb-4">
                        <label class="d-block text-muted small">Taux d'intérêt annuel</label>
                        <span class="h5 fw-bold text-success">{{ negociation.tauxPropose }} %</span>
                    </div>

                    <hr class="my-4 opacity-10">

                    <h5 class="text-uppercase small fw-bold text-primary mb-3">Audit de sécurité</h5>
                    <div class="security-box p-3 rounded bg-white-50">
                        <div class="d-flex align-items-center mb-2">
                            <i class="fas fa-microchip me-2 text-info"></i>
                            <span class="small fw-bold">Algorithme : HMAC-SHA256</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="fas fa-lock me-2 text-warning"></i>
                            <span class="small fw-bold">Protocole : SSL/JWT TLS 1.3</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <label class="text-muted small">Empreinte du certificat (Hash)</label>
                        <code class="d-block text-truncate p-2 bg-dark text-warning rounded mt-1 small">
                            {{ fingerprint|default('NON_GENERE') }}
                        </code>
                    </div>
                </div>
            </div>

            {# Colonne Droite : Le Contrat #}
            <div class="col-lg-8">
                <div class="main-contract-card shadow-lg">
                    <div class="contract-header d-flex justify-content-between align-items-center p-4 text-white">
                        <div>
                            <h3 class="mb-0">Contrat de Prêt Numérique</h3>
                            <span class="opacity-75 small">Document certifié conforme par Champions Fintech</span>
                        </div>
                        <i class="fas fa-file-invoice-dollar fa-3x opacity-25"></i>
                    </div>

                    <div class="contract-viewport p-5" id="contractContent">
                        {% if contrat is defined and contrat is not null %}
                            <div class="contract-text shadow-inner">
                                {{ contrat|raw }}
                            </div>

                            <form action="{{ path('app_front_negociation_confirm_send', {'id': negociation.id_negociation}) }}" method="POST" class="mt-5 text-center">
                                <input type="hidden" name="contrat_content" value="{{ contrat|e('html_attr') }}">
                                
                                <div class="certification-area p-4 rounded mb-4">
                                    <div class="form-check d-inline-block text-start">
                                        <input class="form-check-input" type="checkbox" id="confirmTerms" required>
                                        <label class="form-check-label small" for="confirmTerms">
                                            Je certifie avoir pris connaissance des clauses financières et j'appose ma signature électronique irrévocable.
                                        </label>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-center gap-3">
                                    <a href="{{ path('app_front_negociation_received') }}" class="btn btn-light btn-lg px-4 border">
                                        Abandonner
                                    </a>
                                    <button type="submit" class="btn btn-primary-gradient btn-lg px-5 shadow">
                                        <i class="fas fa-pen-nib me-2"></i> Signer & Envoyer
                                    </button>
                                </div>
                            </form>
                        {% else %}
                            <div class="text-center py-5">
                                <div class="success-checkmark mb-4">
                                    <div class="check-icon">
                                        <span class="icon-line line-tip"></span>
                                        <span class="icon-line line-long"></span>
                                        <div class="icon-circle"></div>
                                        <div class="icon-fix"></div>
                                    </div>
                                </div>
                                <h3 class="fw-bold text-success">Document Scellé avec Succès</h3>
                                <p class="text-muted">L'original a été archivé et transmis par email.</p>
                                <div class="mt-4">
                                    <button class="btn btn-outline-dark me-2" onclick="window.print()">
                                        <i class="fas fa-print"></i> PDF Certifié
                                    </button>
                                    <a href="{{ path('app_front_negociation_received') }}" class="btn btn-primary">Retour au Dashboard</a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* DESIGN SYSTEM FINTECH */
    :root {
        --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #003da5 100%);
        --glass-bg: rgba(255, 255, 255, 0.7);
    }

    .bg-premium { background-color: #f4f7fa; min-height: 100vh; }

    /* Glassmorphism */
    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
    }

    .main-contract-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        border: none;
    }

    .contract-header { background: var(--primary-gradient); }

    .contract-text {
        font-family: 'Inter', sans-serif;
        font-size: 1.05rem;
        line-height: 1.8;
        color: #444;
        background: #fdfdfd;
        padding: 40px;
        border-radius: 12px;
        border: 1px solid #eee;
        white-space: pre-wrap;
    }

    /* Stepper */
    .stepper-wrapper { display: flex; justify-content: space-between; position: relative; }
    .stepper-item { position: relative; display: flex; flex-direction: column; align-items: center; flex: 1; }
    .stepper-item::before { position: absolute; content: ""; border-bottom: 2px solid #ddd; width: 100%; top: 20px; left: -50%; z-index: 1; }
    .stepper-item:first-child::before { content: none; }
    .step-counter { position: relative; z-index: 2; display: flex; justify-content: center; align-items: center; width: 40px; height: 40px; border-radius: 50%; background: #ccc; margin-bottom: 6px; color: white; }
    .stepper-item.active .step-counter { background-color: #0d6efd; }
    .stepper-item.completed .step-counter { background-color: #198754; }

    /* Animations & Buttons */
    .btn-primary-gradient {
        background: var(--primary-gradient);
        color: white;
        border: none;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .btn-primary-gradient:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(13, 110, 253, 0.3); color: white; }

    .shadow-pulse {
        animation: pulse-blue 2s infinite;
    }

    @keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.7); }
        70% { box-shadow: 0 0 0 15px rgba(13, 110, 253, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
    }

    .certification-area { background: #fff3cd; border: 1px dashed #ffc107; }

    @media print {
        .bg-premium, .stepper-wrapper, .glass-card, form, .btn, .contract-header i { display: none !important; }
        .col-lg-8 { width: 100% !important; }
        .contract-viewport { padding: 0 !important; }
        .contract-text { border: none !important; box-shadow: none !important; font-size: 12pt; }
    }
</style>

<script>
    // Ajoute un effet interactif lors de la signature
    document.querySelector('form')?.addEventListener('submit', function() {
        const btn = this.querySelector('button[type="submit"]');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Signature en cours...';
        btn.classList.add('disabled');
    });
</script>
{% endblock %}