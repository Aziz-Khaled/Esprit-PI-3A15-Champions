{% extends 'base.html.twig' %}

{% block title %}Mes Demandes de Crédit{% endblock %}

{% block body %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    :root {
        --violet: #8353E2;
        --violet-light: #a77af5;
        --violet-glow: rgba(131, 83, 226, 0.35);
        --success: #4ade80;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
        min-height: 100vh;
        color: #fff;
    }

    /* ── NAV ── */
    .cf-nav {
        background: rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 14px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .cf-nav-brand { display: flex; align-items: center; gap: 12px; }
    .cf-nav-logo {
        width: 36px; height: 36px; border-radius: 12px;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        display: flex; align-items: center; justify-content: center;
    }
    .cf-nav-title { font-weight: 800; color: #fff; font-size: 1.05rem; letter-spacing: -0.3px; }
    .cf-nav-links { display: flex; align-items: center; gap: 24px; }
    .cf-nav-links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color .2s; }
    .cf-nav-links a:hover { color: #fff; }
    .cf-nav-links a.active { color: var(--violet-light); font-weight: 700; }
    .cf-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 700; color: #fff;
    }

    /* ── LAYOUT ── */
    .cf-container { max-width: 1280px; margin: 0 auto; padding: 40px 24px; }

    /* ── HEADER ── */
    .cf-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; gap: 20px; flex-wrap: wrap; }
    .cf-badge-label {
        display: inline-block; font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .1em;
        background: rgba(131,83,226,0.2); color: var(--violet-light);
        border: 1px solid rgba(131,83,226,0.3); border-radius: 50px;
        padding: 4px 12px; margin-bottom: 10px;
    }
    .cf-title { font-size: 1.9rem; font-weight: 800; color: #fff; margin: 0 0 6px; letter-spacing: -0.5px; }
    .cf-subtitle { color: rgba(255,255,255,0.45); font-size: 0.875rem; margin: 0; }
    
    /* ── BUTTONS ── */
    .cf-btn-new {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 22px; border-radius: 16px; font-weight: 700;
        font-size: 0.875rem; color: #fff !important; text-decoration: none;
        background: linear-gradient(135deg, var(--violet) 0%, var(--violet-light) 100%);
        box-shadow: 0 8px 32px var(--violet-glow);
        transition: transform .2s, box-shadow .2s;
        border: none; cursor: pointer;
    }
    .cf-btn-new:hover { transform: translateY(-2px); box-shadow: 0 12px 40px var(--violet-glow); }

    .cf-btn-sign {
        background: linear-gradient(135deg, #059669, #10b981);
        color: white !important;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.78rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        border: none;
        cursor: pointer;
    }

    .cf-btn-edit {
        background: rgba(255,255,255,0.1);
        color: #fff !important;
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 0.78rem;
        text-decoration: none;
        font-weight: 600;
    }

    /* ── TABLE ── */
    .cf-table-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px; overflow: hidden; backdrop-filter: blur(20px);
    }
    .cf-table-head {
        display: grid; grid-template-columns: 2fr 1.2fr 1fr 1fr 1.5fr;
        padding: 14px 24px; background: rgba(131,83,226,0.12);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .cf-th { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.4); }
    .cf-th.center { text-align: center; }
    .cf-th.right  { text-align: right; }

    .cf-row {
        display: grid; grid-template-columns: 2fr 1.2fr 1fr 1fr 1.5fr;
        padding: 16px 24px; align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .cf-row:hover { background: rgba(255,255,255,0.04); }

    /* ── BADGES ── */
    .cf-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 700; }
    .cf-badge-open { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.25); color: #60a5fa; }
    .cf-badge-approved { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
    .cf-badge-completed { background: rgba(131, 83, 226, 0.15); border: 1px solid rgba(131, 83, 226, 0.25); color: #a77af5; }
</style>

<nav class="cf-nav">
    <div class="cf-nav-brand">
        <div class="cf-nav-logo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
        <span class="cf-nav-title">ChampionsFinance</span>
    </div>
    <div class="cf-nav-links">
        <a href="/front/credit/liste" class="cf-btn-edit">Consulter mes projets</a>

        <a href="{{ path('app_credit_index') }}" class="active">Mes Demandes</a>
       
    </div>
    <div class="cf-avatar">{{ app.user ? app.user.prenom|first ~ app.user.nom|first : 'JD' }}</div>
</nav>

<div class="cf-container">
    <div class="cf-header">
        <div>
            <span class="cf-badge-label">Espace Financement</span>
            <h1 class="cf-title">Mes Demandes de Crédit</h1>
            <p class="cf-subtitle">Gérez vos contrats et suivez vos validations en temps réel.</p>
            
        </div>
        <a href="{{ path('app_credit_new') }}" class="cf-btn-new">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Nouvelle Demande
        </a>
        
    
    <div class="cf-table-card">
        <div class="cf-table-head">
            <div class="cf-th">Projet</div>
            <div class="cf-th">Engagement</div>
            <div class="cf-th center">Conditions</div>
            <div class="cf-th center">Statut</div>
            <div class="cf-th right">Actions</div>
        </div>

        {% for credit in credits %}
        <div class="cf-row">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(131,83,226,0.2); display: flex; align-items: center; justify-content: center;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a77af5" stroke-width="2"><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
                </div>
                <div>
                    <div style="font-weight:600; font-size: 0.875rem;">{{ credit.projet.title }}</div>
                    <div style="font-size: 0.7rem; color: rgba(255,255,255,0.3);">ID #{{ credit.idCredit }}</div>
                </div>
            </div>

            <div>
                <div style="font-size: 1.1rem; font-weight: 800;">{{ credit.montant|number_format(2) }}</div>
                <div style="font-size: 0.7rem; color: var(--violet-light);">{{ credit.devise }}</div>
            </div>

            <div style="text-align: center;">
                <span style="background: rgba(255,255,255,0.06); padding: 4px 10px; border-radius: 8px; font-size: 0.8rem;">
                    {{ credit.taux }}% | {{ credit.duree }} mois
                </span>
            </div>

            <div style="text-align: center;">
    {% if credit.status|upper == 'OPEN' %}
        <span class="badge bg-primary">EN ATTENTE</span>
    {% elseif credit.status|upper == 'APPROVED' %}
        <span class="badge bg-success">APPROUVÉ</span>
    {% elseif credit.status|upper == 'SIGNED' %}
        <span class="badge bg-warning text-dark">SIGNATURE INVESTISSEUR</span>
    {% elseif credit.status|upper == 'CLOSED' %}
        <span class="cf-badge cf-badge-completed">CONTRAT SCELLÉ</span>
    {% else %}
        <span class="badge bg-secondary">{{ credit.status }}</span>
    {% endif %}
</div>

            <div style="text-align: right;">
                {# --- DÉBUT LOGIQUE ACTIONS CORRIGÉE --- #}
                {% if credit.status|upper == 'SIGNED' or credit.status|upper == 'APPROVED' %}
                    {# ACTION : SIGNER (Via la page de preview) #}
                    <a href="{{ path('app_front_credit_preview', {'id': credit.idCredit}) }}" class="cf-btn-sign">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34"/>
                            <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"/>
                        </svg>
                        Consulter et Signer
                    </a>

                {% elseif credit.status|upper == 'COMPLETED' %}
                    {# ACTION : TÉLÉCHARGER #}
                    <a href="{{ asset('uploads/contracts/Contract_Final_' ~ credit.idCredit ~ '.pdf') }}" 
                       class="cf-btn-edit" 
                       style="background: #059669;" 
                       target="_blank">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 5px;">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Télécharger PDF
                    </a>

                {% elseif credit.status|upper == 'OPEN' or credit.status is empty %}
                    {# ACTION : MODIFIER #}
                    <a href="{{ path('app_credit_edit', {'id_credit': credit.idCredit}) }}" class="cf-btn-edit">
                        Modifier
                    </a>

                {% else %}
                    <span style="font-size: 0.75rem; color: rgba(255,255,255,0.4);">Traitement...</span>
                {% endif %}
                {# --- FIN LOGIQUE ACTIONS --- #}
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{% endblock %}