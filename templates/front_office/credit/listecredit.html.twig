{% extends 'base.html.twig' %}

{% block title %}Mes Demandes de Crédit{% endblock %}

{% block body %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

    :root {
        --violet: #8353E2;
        --violet-light: #a77af5;
        --violet-glow: rgba(131, 83, 226, 0.35);
    }

    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
        min-height: 100vh;
    }

    /* ── NAV ── */
    .cf-nav {
        background: rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 14px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .cf-nav-brand { display: flex; align-items: center; gap: 12px; }
    .cf-nav-logo {
        width: 36px; height: 36px; border-radius: 12px;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        display: flex; align-items: center; justify-content: center;
    }
    .cf-nav-title { font-weight: 800; color: #fff; font-size: 1.05rem; letter-spacing: -0.3px; }
    .cf-nav-links { display: flex; align-items: center; gap: 24px; }
    .cf-nav-links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color .2s; }
    .cf-nav-links a:hover { color: #fff; }
    .cf-nav-links a.active { color: var(--violet-light); font-weight: 700; }
    .cf-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 700; color: #fff;
    }

    /* ── LAYOUT ── */
    .cf-container { max-width: 1280px; margin: 0 auto; padding: 40px 24px; }

    /* ── HEADER ── */
    .cf-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; gap: 20px; flex-wrap: wrap; }
    .cf-badge-label {
        display: inline-block; font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .1em;
        background: rgba(131,83,226,0.2); color: var(--violet-light);
        border: 1px solid rgba(131,83,226,0.3); border-radius: 50px;
        padding: 4px 12px; margin-bottom: 10px;
    }
    .cf-title { font-size: 1.9rem; font-weight: 800; color: #fff; margin: 0 0 6px; letter-spacing: -0.5px; }
    .cf-subtitle { color: rgba(255,255,255,0.45); font-size: 0.875rem; margin: 0; }
    .cf-btn-new {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 22px; border-radius: 16px; font-weight: 700;
        font-size: 0.875rem; color: #fff; text-decoration: none;
        background: linear-gradient(135deg, var(--violet) 0%, var(--violet-light) 100%);
        box-shadow: 0 8px 32px var(--violet-glow);
        transition: transform .2s, box-shadow .2s;
        border: none; cursor: pointer;
    }
    .cf-btn-new:hover { transform: translateY(-2px); box-shadow: 0 12px 40px var(--violet-glow); color: #fff; }

    /* ── KPI CARDS ── */
    .cf-kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
    @media (max-width: 768px) { .cf-kpi-grid { grid-template-columns: 1fr; } }
    .cf-kpi-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px; padding: 20px; display: flex; align-items: center; gap: 16px;
        backdrop-filter: blur(20px);
    }
    .cf-kpi-icon {
        width: 48px; height: 48px; border-radius: 16px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
    }
    .cf-kpi-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.4); margin: 0 0 4px; }
    .cf-kpi-value { font-size: 1.6rem; font-weight: 800; color: #fff; margin: 0; line-height: 1; }
    .cf-kpi-suffix { font-size: 0.8rem; font-weight: 700; margin-left: 4px; }

    /* ── FILTER BAR ── */
    .cf-filter-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px; padding: 20px; margin-bottom: 24px; backdrop-filter: blur(20px);
    }
    .cf-filter-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr 1fr; gap: 12px; align-items: end; }
    @media (max-width: 900px) { .cf-filter-grid { grid-template-columns: 1fr 1fr; } }
    .cf-filter-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.35); margin-bottom: 8px; display: block; }
    .cf-input-wrap { position: relative; }
    .cf-input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.3); pointer-events: none; }
    .cf-input, .cf-select {
        width: 100%; padding: 10px 12px; border-radius: 12px;
        background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
        color: #fff; font-size: 0.875rem; font-family: 'Inter', sans-serif;
        outline: none; transition: border-color .2s; box-sizing: border-box;
    }
    .cf-input.with-icon { padding-left: 36px; }
    .cf-input::placeholder { color: rgba(255,255,255,0.25); }
    .cf-input:focus, .cf-select:focus { border-color: var(--violet); }
    .cf-select option { background: #1e1a3a; color: #fff; }
    .cf-btn-filter {
        width: 100%; padding: 10px; border-radius: 12px; font-weight: 700;
        font-size: 0.875rem; color: #fff; cursor: pointer; border: none;
        background: linear-gradient(135deg, var(--violet) 0%, var(--violet-light) 100%);
        box-shadow: 0 4px 20px rgba(131,83,226,0.3);
        transition: transform .15s, opacity .15s;
    }
    .cf-btn-filter:hover { transform: translateY(-1px); opacity: .9; }

    /* ── TABLE ── */
    .cf-table-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px; overflow: hidden; backdrop-filter: blur(20px);
    }
    .cf-table-head {
        display: grid; grid-template-columns: 2fr 1.2fr 1fr 1fr 1fr;
        padding: 14px 24px; background: rgba(131,83,226,0.12);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .cf-th {
        font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .1em; color: rgba(255,255,255,0.4);
    }
    .cf-th.center { text-align: center; }
    .cf-th.right  { text-align: right; }

    .cf-row {
        display: grid; grid-template-columns: 2fr 1.2fr 1fr 1fr 1fr;
        padding: 16px 24px; align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background .15s;
    }
    .cf-row:last-child { border-bottom: none; }
    .cf-row:hover { background: rgba(255,255,255,0.04); }

    /* ── ROW CELLS ── */
    .cf-proj-wrap { display: flex; align-items: center; gap: 12px; }
    .cf-proj-icon {
        width: 40px; height: 40px; border-radius: 12px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(131,83,226,0.2); border: 1px solid rgba(131,83,226,0.3);
    }
    .cf-proj-name { font-weight: 600; color: #fff; font-size: 0.875rem; line-height: 1.3; }
    .cf-proj-id {
        font-size: 0.7rem; font-weight: 500; margin-top: 3px; display: inline-block;
        background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.35);
        padding: 2px 8px; border-radius: 6px;
    }
    .cf-amount { font-size: 1.25rem; font-weight: 800; color: #fff; line-height: 1.2; }
    .cf-devise { font-size: 0.7rem; font-weight: 700; color: var(--violet-light); }
    .cf-cond {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 12px; border-radius: 10px; font-size: 0.8rem;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);
    }
    .cf-cond-rate { font-weight: 700; color: #fff; }
    .cf-cond-sep  { color: rgba(255,255,255,0.2); }
    .cf-cond-dur  { color: rgba(255,255,255,0.55); }
    .cf-cell-center { text-align: center; }

    /* badges */
    .cf-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 700;
    }
    .cf-badge-dot { width: 6px; height: 6px; border-radius: 50%; }
    .cf-badge-open   { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.25); color: #60a5fa; }
    .cf-badge-dot-open { background: #60a5fa; animation: pulse 1.8s infinite; }
    .cf-badge-approved { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.25); color: #4ade80; }
    .cf-badge-dot-approved { background: #4ade80; }
    .cf-badge-default  { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.4); }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* action buttons */
    .cf-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
    .cf-btn-edit {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 12px; font-weight: 700; font-size: 0.78rem;
        color: #fff; text-decoration: none; border: none; cursor: pointer;
        background: linear-gradient(135deg, var(--violet), var(--violet-light));
        box-shadow: 0 2px 12px rgba(131,83,226,0.3);
        transition: transform .15s, box-shadow .15s;
    }
    .cf-btn-edit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(131,83,226,0.4); color: #fff; }
    .cf-btn-delete {
        width: 36px; height: 36px; border-radius: 12px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.2);
        color: #f87171; cursor: pointer; transition: all .15s;
    }
    .cf-btn-delete:hover { background: #ef4444; color: #fff; transform: translateY(-2px); }

    /* empty state */
    .cf-empty { padding: 60px 20px; text-align: center; color: rgba(255,255,255,0.3); }
    .cf-empty svg { margin: 0 auto 16px; display: block; opacity: .25; }

    /* pagination */
    .cf-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 20px; }
    .cf-footer-info { font-size: 0.75rem; color: rgba(255,255,255,0.25); }
    .cf-pagination { display: flex; align-items: center; gap: 6px; }
    .cf-page-btn {
        width: 32px; height: 32px; border-radius: 10px; border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.8rem; font-weight: 700;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.4); transition: background .15s;
    }
    .cf-page-btn:hover { background: rgba(255,255,255,0.12); }
    .cf-page-btn.active { background: linear-gradient(135deg, var(--violet), var(--violet-light)); color: #fff; border: none; }
</style>

{# ── NAV ── #}
<nav class="cf-nav">
    <div class="cf-nav-brand">
        <div class="cf-nav-logo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
        </div>
        <span class="cf-nav-title">ChampionsFinance</span>
    </div>
    <div class="cf-nav-links">
        <a href="#">Tableau de bord</a>
        <a href="{{ path('app_credit_index') }}" class="active">Mes Demandes</a>
        <a href="#">Simulation</a>
        <a href="#">Support</a>
    </div>
    <div class="cf-avatar">{{ app.user ? app.user.firstName|first ~ app.user.lastName|first : 'JD' }}</div>
</nav>

<div class="cf-container">

    {# ── HEADER ── #}
    <div class="cf-header">
        <div>
            <span class="cf-badge-label">Espace Financement</span>
            <h1 class="cf-title">Mes Demandes de Crédit</h1>
            <p class="cf-subtitle">Consultez l'historique et l'état de vos demandes de crédit "Champions".</p>
        </div>
        <a href="{{ path('app_credit_new') }}" class="cf-btn-new">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Nouvelle Demande
        </a>
    </div>

    {# ── KPI CARDS ── #}
    <div class="cf-kpi-grid">
        <div class="cf-kpi-card">
            <div class="cf-kpi-icon" style="background:rgba(131,83,226,0.15);border:1px solid rgba(131,83,226,0.25);color:#8353E2;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="15" rx="2"/><polyline points="17 2 12 7 7 2"/>
                </svg>
            </div>
            <div>
                <p class="cf-kpi-label">Dossiers Actifs</p>
                <p class="cf-kpi-value">{{ credits|length }}</p>
            </div>
        </div>
        <div class="cf-kpi-card">
            <div class="cf-kpi-icon" style="background:rgba(34,211,238,0.12);border:1px solid rgba(34,211,238,0.2);color:#22d3ee;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div>
                <p class="cf-kpi-label">Montant Total</p>
                <p class="cf-kpi-value">
                    {% set total = 0 %}
                    {% for c in credits %}{% set total = total + c.montant %}{% endfor %}
                    {{ total|number_format(0, ',', ' ') }}
                    <span class="cf-kpi-suffix" style="color:#22d3ee;">EUR</span>
                </p>
            </div>
        </div>
        <div class="cf-kpi-card">
            <div class="cf-kpi-icon" style="background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.2);color:#4ade80;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <div>
                <p class="cf-kpi-label">Dossiers Approuvés</p>
                <p class="cf-kpi-value">
                    {{ credits|filter(c => c.status == 'APPROVED')|length }}
                    <span class="cf-kpi-suffix" style="color:#4ade80;">/ {{ credits|length }}</span>
                </p>
            </div>
        </div>
    </div>

    {# ── FILTER BAR ── #}
    <div class="cf-filter-card">
        <form method="get" class="cf-filter-grid">
            <div>
                <label class="cf-filter-label">Rechercher un projet</label>
                <div class="cf-input-wrap">
                    <svg class="cf-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" name="q" class="cf-input with-icon" placeholder="Nom du projet..." value="{{ app.request.query.get('q') }}">
                </div>
            </div>
            <div>
                <label class="cf-filter-label">Statut</label>
                <select name="status" class="cf-select">
                    <option value="">Tous les statuts</option>
                    <option value="OPEN" {{ app.request.query.get('status') == 'OPEN' ? 'selected' : '' }}>EN ATTENTE</option>
                    <option value="APPROVED" {{ app.request.query.get('status') == 'APPROVED' ? 'selected' : '' }}>APPROUVÉ</option>
                </select>
            </div>
            <div>
                <label class="cf-filter-label">Montant Min</label>
                <input type="number" name="minAmount" class="cf-input" placeholder="0.00" value="{{ app.request.query.get('minAmount') }}">
            </div>
            <div>
                <label class="cf-filter-label">Trier par</label>
                <select name="sortBy" class="cf-select">
                    <option value="date_desc"   {{ app.request.query.get('sortBy') == 'date_desc'   ? 'selected' : '' }}>Plus récent</option>
                    <option value="date_asc"    {{ app.request.query.get('sortBy') == 'date_asc'    ? 'selected' : '' }}>Plus ancien</option>
                    <option value="amount_desc" {{ app.request.query.get('sortBy') == 'amount_desc' ? 'selected' : '' }}>Montant (Décroissant)</option>
                    <option value="amount_asc"  {{ app.request.query.get('sortBy') == 'amount_asc'  ? 'selected' : '' }}>Montant (Croissant)</option>
                </select>
            </div>
            <div>
                <button type="submit" class="cf-btn-filter">Filtrer</button>
            </div>
        </form>
    </div>

    {# ── TABLE ── #}
    <div class="cf-table-card">
        <div class="cf-table-head">
            <div class="cf-th">Projet</div>
            <div class="cf-th">Engagement</div>
            <div class="cf-th center">Conditions</div>
            <div class="cf-th center">Statut du Dossier</div>
            <div class="cf-th right">Gestion</div>
        </div>

        {% for credit in credits %}
        <div class="cf-row">

            {# Projet #}
            <div class="cf-proj-wrap">
                <div class="cf-proj-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a77af5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
                        <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
                        <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
                        <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
                    </svg>
                </div>
                <div>
                    <span class="cf-proj-name">{{ credit.projet.title }}</span>
                    <span class="cf-proj-id">ID #{{ credit.idCredit }}</span>
                </div>
            </div>

            {# Engagement #}
            <div>
                <div class="cf-amount">{{ credit.montant|number_format(2, ',', ' ') }}</div>
                <div class="cf-devise">{{ credit.devise }}</div>
            </div>

            {# Conditions #}
            <div class="cf-cell-center">
                <div class="cf-cond">
                    <span class="cf-cond-rate">{{ credit.taux }}%</span>
                    <span class="cf-cond-sep">|</span>
                    <span class="cf-cond-dur">{{ credit.duree }} mois</span>
                </div>
            </div>

            {# Statut #}
            <div class="cf-cell-center">
                {% if credit.status == 'OPEN' %}
                    <span class="cf-badge cf-badge-open">
                        <span class="cf-badge-dot cf-badge-dot-open"></span>EN ATTENTE
                    </span>
                {% elseif credit.status == 'APPROVED' %}
                    <span class="cf-badge cf-badge-approved">
                        <span class="cf-badge-dot cf-badge-dot-approved"></span>APPROUVÉ
                    </span>
                {% else %}
                    <span class="cf-badge cf-badge-default">{{ credit.status }}</span>
                {% endif %}
            </div>

            {# Gestion #}
            <div class="cf-actions">
                <a href="{{ path('app_credit_edit', {'id_credit': credit.idCredit}) }}" class="cf-btn-edit">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Modifier
                </a>
                <form method="post" action="{{ path('app_credit_delete', {'id_credit': credit.idCredit}) }}"
                      onsubmit="return confirm('Supprimer ce dossier définitivement ?');" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ credit.idCredit) }}">
                    <button class="cf-btn-delete" type="submit">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                            <path d="M10 11v6"/><path d="M14 11v6"/>
                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                        </svg>
                    </button>
                </form>
            </div>

        </div>
        {% else %}
        <div class="cf-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
            <p>Aucune demande de crédit trouvée.</p>
        </div>
        {% endfor %}
    </div>

    {# ── FOOTER PAGINATION ── #}
    <div class="cf-footer">
        <span class="cf-footer-info">Affichage de {{ credits|length }} dossier(s)</span>
