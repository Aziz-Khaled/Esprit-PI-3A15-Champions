{% extends 'back_base.html.twig' %}

{% block title %}Gestion des Produits - Marketplace Fintech{% endblock %}

{% block body_back %}
<div class="container-fluid py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-900 font-weight-bold">Catalogue des Produits</h1>
            <p class="text-muted small">Gérez l'ensemble de vos actifs numériques et matériels. <span class="badge badge-light border ml-1" id="product-count-badge">{{ products|length }} items</span></p>
        </div>
        <a href="{{ path('app_back_product_new') }}" class="btn btn-primary rounded-pill px-4 shadow-lg border-0 py-2">
            <i class="fas fa-plus mr-2"></i> Ajouter un produit
        </a>
    </div>

    <!-- Product Analytics Row -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2 upgraded-card">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Commandes</div>
                            <div class="h4 mb-0 font-weight-bold text-gray-800">128</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-shopping-cart fa-2x text-gray-200"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% set low_stock = 0 %}
        {% for p in products %}
            {% if p.stock < 10 %}{% set low_stock = low_stock + 1 %}{% endif %}
        {% endfor %}

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2 upgraded-card">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Alertes Stock Bas</div>
                            <div class="h4 mb-0 font-weight-bold text-{{ low_stock > 0 ? 'danger' : 'success' }}">{{ low_stock }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-warning opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== SEARCH + SORT BAR ========== -->
    <div class="card shadow-sm mb-4 border-0 rounded-lg">
        <div class="card-body py-3">
            <div class="row align-items-center">
                <!-- Search Input -->
                <div class="col-md-5 mb-2 mb-md-0">
                    <div class="input-group search-input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0">
                                <i class="fas fa-search text-gray-400"></i>
                            </span>
                        </div>
                        <input type="text" id="admin-search-input" class="form-control border-left-0 py-2" 
                            placeholder="Rechercher par nom, marque, catégorie..." autocomplete="off">
                        <div class="input-group-append" id="clear-search-btn" style="display:none;">
                            <span class="input-group-text bg-white border-left-0 cursor-pointer">
                                <i class="fas fa-times text-gray-400"></i>
                            </span>
                        </div>
                    </div>
                </div>
                <!-- Sort By -->
                <div class="col-md-3 mb-2 mb-md-0">
                    <select id="admin-sort-field" class="form-control form-control-sm custom-select py-2">
                        <option value="name">Trier par : Nom</option>
                        <option value="price">Trier par : Prix</option>
                        <option value="stock">Trier par : Stock</option>
                        <option value="category">Trier par : Catégorie</option>
                        <option value="brand">Trier par : Marque</option>
                        <option value="createdAt">Trier par : Date</option>
                    </select>
                </div>
                <!-- Sort Direction -->
                <div class="col-md-2 mb-2 mb-md-0">
                    <select id="admin-sort-dir" class="form-control form-control-sm custom-select py-2">
                        <option value="ASC">Croissant ↑</option>
                        <option value="DESC">Décroissant ↓</option>
                    </select>
                </div>
                <!-- Live indicator -->
                <div class="col-md-2 text-right">
                    <span id="search-loading" class="text-primary small" style="display:none;">
                        <i class="fas fa-circle-notch fa-spin mr-1"></i> Recherche...
                    </span>
                    <span id="search-live-badge" class="badge badge-success-soft rounded-pill px-3 py-1">
                        <i class="fas fa-bolt mr-1"></i> Live AJAX
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Table Card -->
    <div class="card shadow-sm mb-4 border-0 rounded-lg">
        <div class="card-header py-3 bg-white border-bottom d-flex align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">Liste du Marketplace</h6>
            <div class="btn-group">
                <button class="btn btn-sm btn-white border px-3" onclick="adminSearch()"><i class="fas fa-sync mr-1"></i> Sync</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" id="admin-products-table">
                    <thead class="bg-light text-gray-700">
                        <tr>
                            <th class="pl-4 sortable-th" data-sort="name">
                                Produit & Détails <i class="fas fa-sort text-gray-300 ml-1"></i>
                            </th>
                            <th class="sortable-th" data-sort="brand">
                                Marque <i class="fas fa-sort text-gray-300 ml-1"></i>
                            </th>
                            <th class="sortable-th" data-sort="category">
                                Catégorie <i class="fas fa-sort text-gray-300 ml-1"></i>
                            </th>
                            <th class="sortable-th" data-sort="price">
                                Prix (BTC) <i class="fas fa-sort text-gray-300 ml-1"></i>
                            </th>
                            <th class="sortable-th" data-sort="stock">
                                Stock <i class="fas fa-sort text-gray-300 ml-1"></i>
                            </th>
                            <th>Statut</th>
                            <th class="text-center pr-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="admin-products-tbody">
                    {% for product in products %}
                        <tr class="upgraded-tr">
                            <td class="pl-4 py-3 align-middle">
                                <div class="d-flex align-items-center">
                                    <div class="mr-3">
                                        {% if product.imageUrl %}
                                            <div class="image-wrapper shadow-sm rounded-lg overflow-hidden border">
                                                <img src="{{ asset('uploads/products/' ~ product.imageUrl) }}" class="img-fluid" style="width: 50px; height: 50px; object-fit: cover;" alt="{{ product.name }}">
                                            </div>
                                        {% else %}
                                            <div class="rounded-lg bg-gray-100 d-flex align-items-center justify-content-center border" style="width: 50px; height: 50px;">
                                                <i class="fas fa-box text-gray-300"></i>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <div class="font-weight-bold text-dark fs-6">{{ product.name }}</div>
                                        <div class="small text-gray-500">
                                            {% if product.avgRating %}
                                                <span class="text-warning mr-1"><i class="fas fa-star text-xxs"></i> {{ product.avgRating }}</span>
                                            {% endif %}
                                            {{ product.description|slice(0, 30) }}...
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="align-middle">
                                <span class="text-gray-700 font-weight-bold letter-spacing-1">{{ product.brand ?: 'N/A' }}</span>
                            </td>
                            <td class="align-middle">
                                <span class="badge badge-info-soft rounded-pill px-3 py-1 font-weight-bold">
                                    {{ product.category|replace({'_': ' '})|title }}
                                </span>
                            </td>
                            <td class="align-middle">
                                <div class="d-flex flex-column">
                                    {% if product.discountPrice and product.discountPrice > 0 %}
                                        <span class="text-success font-weight-bold h6 mb-0">{{ product.discountPrice }} BTC</span>
                                        <del class="text-muted small">{{ product.price }} BTC</del>
                                    {% else %}
                                        <span class="font-weight-bold text-primary h6 mb-0">{{ product.price }} BTC</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="align-middle text-center">
                                <span class="font-weight-bold {{ product.stock < 10 ? 'text-danger' : 'text-dark' }}">{{ product.stock }}</span>
                                <div class="progress progress-xs w-100 mt-1 mx-auto" style="max-width: 40px;">
                                    <div class="progress-bar {{ product.stock < 10 ? 'bg-danger' : 'bg-success' }}" role="progressbar" style="width: {{ product.stock > 100 ? 100 : product.stock }}%"></div>
                                </div>
                            </td>
                            <td class="align-middle text-center">
                                {% if product.status == 'available' %}
                                    <span class="badge badge-success-soft rounded-pill px-3 py-1">En vente</span>
                                {% elseif product.status == 'out_of_stock' %}
                                    <span class="badge badge-danger-soft rounded-pill px-3 py-1">Rupture Stock</span>
                                {% elseif product.status == 'coming_soon' %}
                                    <span class="badge badge-warning-soft rounded-pill px-3 py-1">Bientôt</span>
                                {% else %}
                                    <span class="badge badge-light border rounded-pill px-3 py-1">{{ product.status ?: 'Archivé' }}</span>
                                {% endif %}
                            </td>
                            <td class="align-middle text-center pr-4">
                                <div class="btn-group shadow-sm">
                                    <a href="{{ path('app_back_product_show', {'id': product.id}) }}" class="btn btn-sm btn-white border" title="Voir">
                                        <i class="fas fa-eye text-primary"></i>
                                    </a>
                                    <a href="{{ path('app_back_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-white border" title="Modifier">
                                        <i class="fas fa-edit text-info"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_back_product_delete', {'id': product.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression du produit ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                        <button class="btn btn-sm btn-white border" title="Supprimer">
                                            <i class="fas fa-trash text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-5 text-gray-500">Aucun produit trouvé.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light-blue { background-color: #f8fafc; }
    .upgraded-tr:hover { background-color: #fcfdfe; transition: 0.2s; }
    .upgraded-card { transition: 0.3s; cursor: pointer; border-radius: 12px; }
    .upgraded-card:hover { transform: translateY(-5px); }
    
    .badge-success-soft { background-color: #dcfce7; color: #166534; }
    .badge-info-soft { background-color: #e0f2fe; color: #075985; }
    .badge-warning-soft { background-color: #fef9c3; color: #854d0e; }
    .badge-danger-soft { background-color: #fee2e2; color: #991b1b; }
    
    .progress-xs { height: 4px; }
    .text-xxs { font-size: 0.65rem; }
    .letter-spacing-1 { letter-spacing: 0.05rem; }
    .rounded-lg { border-radius: 0.75rem !important; }

    /* Search & Sort UI */
    .search-input-group .input-group-text {
        border-radius: 50px 0 0 50px;
        border-color: #e2e8f0;
    }
    .search-input-group .form-control {
        border-color: #e2e8f0;
        font-size: 0.9rem;
    }
    .search-input-group .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.15rem rgba(78, 115, 223, 0.15);
    }
    .search-input-group .input-group-append .input-group-text {
        border-radius: 0 50px 50px 0;
        border-color: #e2e8f0;
        cursor: pointer;
    }
    .custom-select {
        border-color: #e2e8f0;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        color: #4a5568;
    }
    .custom-select:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.15rem rgba(78, 115, 223, 0.15);
    }

    /* Sortable table headers */
    .sortable-th {
        cursor: pointer;
        user-select: none;
        transition: 0.2s;
    }
    .sortable-th:hover {
        color: #4e73df !important;
        background-color: #f8f9fc;
    }
    .sortable-th.active-sort {
        color: #4e73df !important;
    }
    .sortable-th.active-sort .fas {
        color: #4e73df !important;
    }

    /* Fade transition for AJAX results */
    #admin-products-tbody {
        transition: opacity 0.3s ease;
    }
    #admin-products-tbody.loading {
        opacity: 0.4;
    }

    .cursor-pointer { cursor: pointer; }

    /* Highlight matching text animation */
    @keyframes highlight-in {
        from { background-color: rgba(78, 115, 223, 0.2); }
        to { background-color: transparent; }
    }
    .upgraded-tr { animation: highlight-in 0.5s ease; }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function() {
    var searchInput = document.getElementById('admin-search-input');
    var sortField = document.getElementById('admin-sort-field');
    var sortDir = document.getElementById('admin-sort-dir');
    var tbody = document.getElementById('admin-products-tbody');
    var loadingIndicator = document.getElementById('search-loading');
    var liveBadge = document.getElementById('search-live-badge');
    var clearBtn = document.getElementById('clear-search-btn');
    var countBadge = document.getElementById('product-count-badge');
    var debounceTimer = null;

    function adminSearch() {
        var q = searchInput.value.trim();
        var sort = sortField.value;
        var dir = sortDir.value;

        // Show loading
        loadingIndicator.style.display = 'inline';
        liveBadge.style.display = 'none';
        tbody.classList.add('loading');

        // Show/hide clear button
        clearBtn.style.display = q.length > 0 ? '' : 'none';

        var url = '{{ path("app_back_product_ajax_search") }}' + 
                  '?q=' + encodeURIComponent(q) + 
                  '&sort=' + encodeURIComponent(sort) + 
                  '&dir=' + encodeURIComponent(dir);

        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                loadingIndicator.style.display = 'none';
                liveBadge.style.display = 'inline';
                tbody.classList.remove('loading');

                if (xhr.status === 200) {
                    tbody.innerHTML = xhr.responseText;
                    // Update count badge
                    var rowCount = tbody.querySelectorAll('tr.upgraded-tr').length;
                    countBadge.textContent = rowCount + ' items';
                } else {
                    console.error('AJAX search failed:', xhr.status);
                }
            }
        };
        xhr.send();
    }

    // Make adminSearch available globally for Sync button
    window.adminSearch = adminSearch;

    // Debounced live search on input
    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(adminSearch, 300);
    });

    // Instant search on sort change
    sortField.addEventListener('change', adminSearch);
    sortDir.addEventListener('change', adminSearch);

    // Clear search
    clearBtn.addEventListener('click', function() {
        searchInput.value = '';
        clearBtn.style.display = 'none';
        adminSearch();
    });

    // Clickable column headers for sorting
    document.querySelectorAll('.sortable-th').forEach(function(th) {
        th.addEventListener('click', function() {
            var field = this.getAttribute('data-sort');
            
            // Toggle direction if same field, else set ASC
            if (sortField.value === field) {
                sortDir.value = sortDir.value === 'ASC' ? 'DESC' : 'ASC';
            } else {
                sortField.value = field;
                sortDir.value = 'ASC';
            }

            // Update active states
            document.querySelectorAll('.sortable-th').forEach(function(h) { h.classList.remove('active-sort'); });
            this.classList.add('active-sort');

            // Update icon
            var icon = this.querySelector('.fas');
            if (icon) {
                icon.className = 'fas ml-1 ' + (sortDir.value === 'ASC' ? 'fa-sort-up' : 'fa-sort-down');
            }

            adminSearch();
        });
    });

    // Enter key triggers search
    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            adminSearch();
        }
    });
})();
</script>
{% endblock %}
