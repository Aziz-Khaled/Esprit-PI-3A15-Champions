{% extends 'base.html.twig' %}

{% block title %}Nos Projets - Lindy{% endblock %}

{% block body %}
    <section id="about" class="about-section about-style-1 mb-80">
      <div class="container">
        <div class="row">
          <div class="col-xl-5 offset-xl-7 col-lg-6 offset-lg-6">
            <div class="about-content-wrapper">
              <div class="section-title">
                <h3 class="mb-25 wow fadeInUp" data-wow-delay=".2s">The future of designing starts here</h3>
                <p class="mb-30 wow fadeInUp" data-wow-delay=".4s">Stop wasting time and money designing and managing a website that doesn’t get results.</p>
              </div>
              <div class="content">
                <div class="single-item">
                  <div class="icon"><i class="lni lni-layers"></i></div>
                  <div class="text">
                    <h6 class="mb-10">Web Design</h6>
                    <p>No more missing fonts or broken layouts.</p>
                  </div>
                </div>
                <div class="single-item">
                  <div class="icon"><i class="lni lni-display"></i></div>
                  <div class="text">
                    <h6 class="mb-10">Web Development</h6>
                    <p>Fast and reliable development processes.</p>
                  </div>
                </div>
                <a href="#0" class="read-more-button">Read more</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="about-image">
        <img src="{{ asset('/assets/img/about/about-1/about-img-1.jpg') }}" alt="">
      </div>
    </section>

    <section id="about" class="about-section about-style-2 mb-80">
      <div class="container">
        <div class="row">
          <div class="col-xl-5 col-lg-6">
            <div class="about-content-wrapper">
              <div class="section-title mb-40">
                <h3 class="mb-25">The future of designing starts here</h3>
                <p>Happiness guaranteed for your next project.</p>
              </div>
              <a href="#0" class="button button-lg radius-3">Learn More</a>
            </div>
          </div>
          <div class="col-xl-7 col-lg-6">
            <div class="about-image-wrapper">
              <div class="row">
                <div class="col-md-5">
                  <div class="left-wrapper">
                    <div class="content-item"><h4>20 Years Experience</h4></div>
                    <div class="image-item"><img src="{{ asset('/assets/img/about/about-2/about-1.jpg') }}" alt=""></div>
                    <div class="image-item"><img src="{{ asset('/assets/img/about/about-2/about-2.jpg') }}" alt=""></div>
                  </div>
                </div>
                <div class="col-md-7">
                  <div class="right-wrapper">
                    <img src="{{ asset('/assets/img/about/about-2/about-3.jpg') }}" alt="">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
{% endblock %}