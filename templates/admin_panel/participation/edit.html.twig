{% extends 'back_base.html.twig' %}

{% block title %}Évaluer la Participation{% endblock %}

{% block body_back %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Évaluer le Participant</h1>
        <a href="{{ path('app_admin_participation_index') }}" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Retour à la liste
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-left-warning">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Informations et Évaluation</h6>
                </div>
                <div class="card-body">
                    <div class="mb-4 p-3 bg-light rounded">
                        <strong>Participant :</strong> {{ participation.utilisateur.email }}<br>
                        <strong>Formation :</strong> {{ participation.formation.titre }}
                    </div>

                    {{ form_start(form) }}
                        <div class="form-group mb-3">
                            {{ form_label(form.statut, 'Statut', {'label_attr': {'class': 'font-weight-bold text-gray-700'}}) }}
                            {{ form_widget(form.statut) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.statut) }}</div>
                        </div>

                        <div class="form-group mb-3 pl-4">
                            {{ form_widget(form.presence, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(form.presence, null, {'label_attr': {'class': 'form-check-label font-weight-bold text-gray-700'}}) }}
                        </div>

                        <div class="form-group mb-4">
                            {{ form_label(form.note, 'Note sur 20', {'label_attr': {'class': 'font-weight-bold text-gray-700'}}) }}
                            {{ form_widget(form.note) }}
                            <div class="text-danger small mt-1">{{ form_errors(form.note) }}</div>
                        </div>

                        <hr>
                        <button class="btn btn-warning shadow-sm">
                            <i class="fas fa-save mr-1"></i> Enregistrer
                        </button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
