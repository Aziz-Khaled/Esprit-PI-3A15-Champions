{% extends 'back_base.html.twig' %}

{% block title %}Modifier formation{% endblock %}

{% block body_back %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-flex align-items-center mb-4">
        <i class="fas fa-edit fa-lg text-primary mr-3"></i>
        <div>
            <h1 class="h3 mb-1 text-gray-800">Modifier la formation</h1>
            <p class="text-muted mb-0">Mettez à jour les informations de la formation.</p>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Formulaire de modification</h6>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                {% include 'admin_panel/formation/_form.html.twig' with { button_label: 'Mettre à jour' } %}
            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}
