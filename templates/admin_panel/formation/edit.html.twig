{% extends 'admin_panel/base.html.twig' %}

{% block title %}Modifier formation{% endblock %}

{% block admin_body %}
<div class="mb-4">
    <h1 class="h3 mb-1">Modifier la formation</h1>
    <p class="text-muted">Mettez à jour les informations de la formation.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        {{ form_start(form) }}
            {% include 'admin_panel/formation/_form.html.twig' with { button_label: 'Mettre à jour' } %}
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
