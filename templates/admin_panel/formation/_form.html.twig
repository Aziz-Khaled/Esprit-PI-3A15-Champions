<div class="row g-3">
    <div class="col-md-6">{{ form_row(form.titre) }}</div>
    <div class="col-md-6">{{ form_row(form.domaine) }}</div>
    <div class="col-md-6">{{ form_row(form.dateDebut) }}</div>
    <div class="col-md-6">{{ form_row(form.dateFin) }}</div>
    <div class="col-md-4">{{ form_row(form.prix) }}</div>
    <div class="col-md-4">{{ form_row(form.capaciteMax) }}</div>
    <div class="col-md-4">{{ form_row(form.statut) }}</div>
    <div class="col-12 position-relative">
        <button type="button" class="btn btn-sm btn-outline-info position-absolute" id="btn-generate-ai" style="right: 15px; top: 0; z-index: 10;">
            <i class="fas fa-robot"></i> Générer avec l'IA
        </button>
        {{ form_row(form.description) }}
    </div>
    <div class="col-12">{{ form_row(form.utilisateur) }}</div>
</div>

<div class="mt-4 d-flex justify-content-between">
    <a href="{{ path('app_admin_formation_index') }}" class="btn btn-secondary">Retour</a>
    <button type="submit" class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const btnGenerate = document.getElementById('btn-generate-ai');
    // Find the inputs. Since Symfony generates IDs like formation_titre and formation_description
    const titreInput = document.querySelector('input[id$="_titre"]');
    const descTextarea = document.querySelector('textarea[id$="_description"]');

    if (btnGenerate && titreInput && descTextarea) {
        btnGenerate.addEventListener('click', function() {
            const titre = titreInput.value.trim();
            if (!titre) {
                alert('Veuillez d\'abord saisir un titre pour la formation.');
                return;
            }

            const originalText = btnGenerate.innerHTML;
            btnGenerate.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération...';
            btnGenerate.disabled = true;

            fetch('{{ path("app_admin_formation_generate_description") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ titre: titre })
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Erreur: ' + data.error);
                } else if (data.description) {
                    descTextarea.value = data.description;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Une erreur est survenue lors de la génération.');
            })
            .finally(() => {
                btnGenerate.innerHTML = originalText;
                btnGenerate.disabled = false;
            });
        });
    }
});
</script>
