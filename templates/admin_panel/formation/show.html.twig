{% extends 'admin_panel/base.html.twig' %}

{% block title %}Détails de la formation{% endblock %}

{% block admin_body %}
<div class="mb-4">
    <h1 class="h3 mb-1">Détails de la formation</h1>
    <p class="text-muted">Informations complètes de la formation sélectionnée.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Titre</dt>
            <dd class="col-sm-9">{{ formation.titre }}</dd>

            <dt class="col-sm-3">Domaine</dt>
            <dd class="col-sm-9">{{ formation.domaine ?: '-' }}</dd>

            <dt class="col-sm-3">Date de début</dt>
            <dd class="col-sm-9">{{ formation.dateDebut ? formation.dateDebut|date('Y-m-d') : '-' }}</dd>

            <dt class="col-sm-3">Date de fin</dt>
            <dd class="col-sm-9">{{ formation.dateFin ? formation.dateFin|date('Y-m-d') : '-' }}</dd>

            <dt class="col-sm-3">Prix</dt>
            <dd class="col-sm-9">{{ formation.prix is not null ? formation.prix|number_format(2, ',', ' ') ~ ' €' : '-' }}</dd>

            <dt class="col-sm-3">Capacité maximale</dt>
            <dd class="col-sm-9">{{ formation.capaciteMax }}</dd>

            <dt class="col-sm-3">Statut</dt>
            <dd class="col-sm-9">{{ formation.statut ?: '-' }}</dd>

            <dt class="col-sm-3">Responsable</dt>
            <dd class="col-sm-9">{{ formation.utilisateur ? formation.utilisateur.email : '-' }}</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">{{ formation.description ?: '-' }}</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-secondary" href="{{ path('app_admin_formation_index') }}">Retour</a>
    <a class="btn btn-primary" href="{{ path('app_admin_formation_edit', { id: formation.idFormation }) }}">Modifier</a>
</div>
{% endblock %}
