{% extends 'admin_panel/base.html.twig' %}

{% block title %}Nouvelle formation{% endblock %}

{% block admin_body %}
<div class="mb-4">
    <h1 class="h3 mb-1">Nouvelle formation</h1>
    <p class="text-muted">Créez une nouvelle formation en remplissant le formulaire ci-dessous.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        {{ form_start(form) }}
            {% include 'admin_panel/formation/_form.html.twig' with { button_label: 'Créer la formation' } %}
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
