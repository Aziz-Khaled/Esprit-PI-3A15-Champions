{% extends 'back_base.html.twig' %}

{% block title %}Formations{% endblock %}

{% block body_back %}
<div class="container-fluid">

    <!-- Page Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-800">Formations</h1>
            <p class="text-muted mb-0">Rechercher, trier et gérer les formations.</p>
        </div>
        <a class="btn btn-primary shadow-sm" href="{{ path('app_admin_formation_new') }}">
            <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Créer une formation
        </a>
    </div>

    <!-- Filter Card -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="search" class="form-label">Titre</label>
                    <input id="search" name="q" type="search" value="{{ search }}" class="form-control" placeholder="Recherche par titre">
                </div>
                <div class="col-md-3">
                    <label for="domaine" class="form-label">Domaine</label>
                    <select id="domaine" name="domaine" class="form-control">
                        <option value="">Tous les domaines</option>
                        {% for domaineItem in domaines %}
                            <option value="{{ domaineItem }}" {{ domaineItem == domaine ? 'selected' : '' }}>{{ domaineItem }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="sort" class="form-label">Trier</label>
                    <select id="sort" name="sort" class="form-control">
                        <option value="">Date de début</option>
                        <option value="prix_asc"  {{ sort == 'prix_asc'  ? 'selected' : '' }}>Prix croissant</option>
                        <option value="prix_desc" {{ sort == 'prix_desc' ? 'selected' : '' }}>Prix décroissant</option>
                        <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Date de début décroissante</option>
                    </select>
                </div>
                <div class="col-md-2 text-right">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="fas fa-filter fa-sm mr-1"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Formations Table Card -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Formations</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light text-gray-700">
                        <tr>
                            <th class="pl-4">Titre</th>
                            <th>Domaine</th>
                            <th>Date début</th>
                            <th>Date fin</th>
                            <th>Prix</th>
                            <th>Capacité</th>
                            <th>Statut</th>
                            <th>Responsable</th>
                            <th class="text-center pr-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for formation in formations %}
                            <tr>
                                <td class="pl-4">{{ formation.titre }}</td>
                                <td>{{ formation.domaine ?: '-' }}</td>
                                <td>{{ formation.dateDebut ? formation.dateDebut|date('Y-m-d') : '-' }}</td>
                                <td>{{ formation.dateFin ? formation.dateFin|date('Y-m-d') : '-' }}</td>
                                <td>{{ formation.prix is not null ? formation.prix|number_format(2, ',', ' ') ~ ' €' : '-' }}</td>
                                <td>{{ formation.capaciteMax }}</td>
                                <td>{{ formation.statut ?: '-' }}</td>
                                <td>{{ formation.utilisateur ? formation.utilisateur.email : '-' }}</td>
                                <td class="text-center pr-4">
                                    <div class="btn-group shadow-sm">
                                        <a class="btn btn-sm btn-white border" href="{{ path('app_admin_formation_show', { id: formation.idFormation }) }}" title="Voir">
                                            <i class="fas fa-eye text-primary"></i>
                                        </a>
                                        <a class="btn btn-sm btn-white border" href="{{ path('app_admin_formation_edit', { id: formation.idFormation }) }}" title="Modifier">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <form method="post" action="{{ path('app_admin_formation_delete', { id: formation.idFormation }) }}" class="d-inline" onsubmit="return confirm('Voulez-vous supprimer cette formation ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-formation' ~ formation.idFormation) }}">
                                            <button class="btn btn-sm btn-white border" title="Supprimer">
                                                <i class="fas fa-trash text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center py-4 text-gray-500">Aucune formation trouvée.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
