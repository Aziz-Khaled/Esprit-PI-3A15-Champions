{% extends 'admin_panel/index.html.twig' %}

{# Or just copy the base layout and add this content block #}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800"><i class="fas fa-history"></i> Activity Log</h1>

    {# Date Filter Form #}
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="GET" class="form-inline">
                <label class="mr-2">From:</label>
                <input type="date" name="from" value="{{ from }}" class="form-control mr-3">
                <label class="mr-2">To:</label>
                <input type="date" name="to" value="{{ to }}" class="form-control mr-3">
                <button type="submit" class="btn btn-primary mr-2">
                    <i class="fas fa-search"></i> Filter
                </button>
                <a href="{{ path('app_admin_logs') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Reset
                </a>
            </form>
        </div>
    </div>

    {# Log Table #}
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Date & Time</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>Details</th>
                            <th>Performed By</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                        <tr>
                            <td>{{ log.id }}</td>
                            <td>{{ log.createdAt|date('d M Y H:i:s') }}</td>
                            <td>
                                <span class="badge badge-
                                    {% if 'APPROVE' in log.action %}success
                                    {% elseif 'REJECT' in log.action or 'DELETE' in log.action %}danger
                                    {% elseif 'EDIT' in log.action %}warning
                                    {% else %}primary{% endif %}">
                                    {{ log.action }}
                                </span>
                            </td>
                            <td>{{ log.entity }}</td>
                            <td>{{ log.details }}</td>
                            <td><i class="fas fa-user-shield"></i> {{ log.performedBy }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-4 text-gray-500">
                                No logs found for the selected period.
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>