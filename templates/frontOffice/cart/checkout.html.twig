{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}Checkout - Fintech Marketplace{% endblock %}

{% block body %}
<div class="row align-items-center mb-5 mt-n4">
    <div class="col-md-7">
        <h1 class="display-4 fw-black text-white mb-2">Checkout <span style="color: var(--accent)">Details</span> 📋</h1>
        <p class="text-muted lead" style="color: var(--text-3) !important;">Provide your shipping details. All amounts are settled in <strong>Bitcoin (BTC)</strong>.</p>
    </div>
</div>

<div class="row g-5 justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border) !important;">
            <div class="card-header py-4 px-5 border-0" style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border) !important;">
                <h5 class="mb-0 text-white fw-bold" style="font-family: var(--font-head);"><i class="fas fa-truck me-2" style="color: var(--accent);"></i> Shipping & Payment Information</h5>
            </div>
            <div class="card-body p-5">
                <form action="{{ path('app_cart_checkout') }}" method="post">
                    <div class="row g-4 mb-5">
                        <div class="col-md-12">
                            <label class="form-label f-label">Full Shipping Address</label>
                            <textarea name="address" class="f-input" rows="3" placeholder="Street, City, Postal Code, Country..." required></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label f-label">Phone Number</label>
                            <input type="text" name="phone" class="f-input" style="border-radius: 50px;" placeholder="+216 ... " required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label f-label">Devise</label>
                            <div class="f-input d-flex align-items-center" style="border-radius: 50px; background: rgba(0,0,0,0.3); opacity: 0.8; pointer-events: none;">
                                <i class="fab fa-bitcoin text-warning me-2"></i>
                                <span class="fw-bold text-white">Bitcoin (BTC)</span>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 rounded-4 mb-5 shadow-sm" style="background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                        <div class="d-flex justify-content-between align-items-center mb-0">
                            <div>
                                <h6 class="fw-bold text-white mb-0" style="font-family: var(--font-head);">Order Total</h6>
                                <p class="text-muted small mb-0 font-weight-bold" style="font-size: 10px;">Guaranteed by smart contract</p>
                            </div>
                            <div class="text-end">
                                <h3 class="h2 fw-bold mb-0" style="color: var(--accent); font-family: var(--font-mono);">{{ total }} BTC</h3>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_cart_index') }}" class="btn btn-link text-decoration-none px-0 font-weight-bold" style="color: var(--accent); font-size: 14px;">
                            <i class="fas fa-arrow-left me-2" style="color: var(--red);"></i> Back to Cart
                        </a>
                        <button type="submit" class="modal-btn-primary py-3 px-5" style="width: auto; margin-top: 0; border-radius: 50px;">
                            PLACE ORDER & PAY <i class="fas fa-chevron-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
       
        <div class="mt-5 text-center px-4">
            <div class="row g-3 opacity-25" style="color: var(--text-3);">
                <div class="col-md-4">
                    <i class="fas fa-shield-check fa-2x mb-2"></i>
                    <p class="small font-weight-bold mb-0">SECURE 256-BIT SSL</p>
                </div>
                <div class="col-md-4 border-start border-end border-secondary border-opacity-25">
                    <i class="fas fa-cube fa-2x mb-2"></i>
                    <p class="small font-weight-bold mb-0">BLOCKCHAIN POWERED</p>
                </div>
                <div class="col-md-4">
                    <i class="fas fa-user-shield fa-2x mb-2"></i>
                    <p class="small font-weight-bold mb-0">VERIFIED MERCHANTS</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 800; }
    .f-label {
        display: block; font-size: 11px; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: var(--text-3); margin-bottom: 7px;
    }
    .f-input {
        width: 100%; padding: 12px 20px;
        background: rgba(0,0,0,0.25) !important;
        border: 1px solid rgba(90,112,144,.3) !important;
        border-radius: 12px; color: var(--text-1) !important;
        font-size: 15px; font-family: var(--font-body); outline: none;
        transition: all .2s;
    }
    .f-input:focus {
        border-color: var(--accent) !important;
        box-shadow: 0 0 15px var(--accent-glow) !important;
        background: rgba(0,0,0,0.3) !important;
    }
    .modal-btn-primary {
        background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);
        border: none; color: #080d14;
        font-family: var(--font-head); font-weight: 700; font-size: 14px;
        letter-spacing: .04em; cursor: pointer;
        transition: all .2s;
        box-shadow: 0 8px 24px rgba(0,229,255,.2);
    }
    .modal-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,229,255,.3); }
    .letter-spacing-1 { letter-spacing: 0.1rem; }
    .shadow-glow { box-shadow: 0 0 30px rgba(0,0,0,0.3); }
</style>
{% endblock %}