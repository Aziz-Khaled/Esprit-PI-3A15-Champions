{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}Shopping Cart - Fintech Marketplace{% endblock %}

{% block body %}
<div class="row align-items-center mb-5 mt-n4">
    <div class="col-md-7">
        <h1 class="display-4 fw-black text-gray-900 mb-2">My <span class="text-primary">Cart</span> 🚀</h1>
        <p class="text-muted lead">Finalize your order and pay with your BTC assets securely.</p>
    </div>
</div>

<div class="row g-5">
    <!-- Cart List -->
    <div class="col-lg-8" id="cart-container">
        {% if items|length > 0 %}
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white border border-light">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-uppercase small font-weight-bold opacity-75 letter-spacing-1">
                            <tr>
                                <th class="ps-4 py-3 border-0">Product</th>
                                <th class="border-0">Unit Price</th>
                                <th class="border-0">Quantity</th>
                                <th class="border-0">Total</th>
                                <th class="text-end pe-4 border-0">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in items %}
                                <tr class="transition-all hover-light cart-row" data-id="{{ item.product.id }}">
                                    <td class="ps-4 py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 rounded-3 overflow-hidden shadow-sm border p-1 bg-white" style="width: 70px; height: 70px;">
                                                {% if item.product.imageUrl %}
                                                    <img src="{{ asset('uploads/products/' ~ item.product.imageUrl) }}" class="img-fluid h-100 w-100" style="object-fit: cover;">
                                                {% else %}
                                                    <i class="fas fa-box fa-2x text-blue-100"></i>
                                                {% endif %}
                                            </div>
                                            <div>
                                                <h4 class="h6 fw-bold text-dark mb-1">{{ item.product.name }}</h4>
                                                <p class="text-muted x-small font-weight-bold letter-spacing-1 mb-0">{{ item.product.brand ?: 'Fintech Asset' }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-primary fw-bold">{{ (item.product.discountPrice ?: item.product.price) }} BTC</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <button onclick="updateQty({{ item.product.id }}, 'minus')" class="btn btn-sm btn-light rounded-circle shadow-sm me-2 border hov-danger-light"><i class="fas fa-minus text-xs"></i></button>
                                            <span id="qty-val-{{ item.product.id }}" class="badge bg-white shadow-sm border text-dark px-3 py-2 rounded-pill fw-black">{{ item.quantity }}</span>
                                            <button onclick="updateQty({{ item.product.id }}, 'plus')" class="btn btn-sm btn-light rounded-circle shadow-sm ms-2 border hov-primary-light"><i class="fas fa-plus text-xs"></i></button>
                                        </div>
                                    </td>
                                    <td>
                                        <span id="subtotal-val-{{ item.product.id }}" class="text-dark fw-black">{{ item.subtotal }} BTC</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_cart_remove', {id: item.product.id}) }}" class="btn btn-light-danger btn-icon rounded-circle border shadow-sm">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
            <a href="{{ path('app_marketplace_index') }}" class="btn btn-white border rounded-pill px-4 shadow-sm font-weight-bold mb-4">
                <i class="fas fa-chevron-left me-2"></i> Continue Shopping
            </a>
        {% else %}
            <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white border-2 border-dashed">
                <div class="mb-4">
                    <i class="fas fa-shopping-cart fa-5x text-blue-100"></i>
                </div>
                <h3 class="fw-black h4 text-gray-900 mb-3">Your cart is empty...</h3>
                <p class="text-muted mb-4 opacity-75">Explore our Marketplace and find the best fintech tools!</p>
                <a href="{{ path('app_marketplace_index') }}" class="btn btn-primary rounded-pill px-5 py-2 font-weight-bold shadow-lg">Marketplace Store</a>
            </div>
        {% endif %}
    </div>

    <!-- Summary -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-lg rounded-4 p-4 sticky-top bg-white border border-light" style="top: 100px;">
            <h5 class="fw-black text-gray-900 mb-4 border-bottom pb-3">Order Summary</h5>
            
            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted font-weight-bold">Subtotal</span>
                <span id="summary-subtotal" class="text-dark fw-bold">{{ total }} BTC</span>
            </div>
            <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                <span class="text-muted font-weight-bold">Network Fees (TRC20)</span>
                <span class="text-success fw-bold">FREE ⚡</span>
            </div>
            
            <div class="d-flex justify-content-between mb-5">
                <span class="h5 fw-black text-gray-900 mb-0">Total</span>
                <div class="text-end">
                    <span id="summary-total" class="h4 fw-black text-primary mb-0 d-block">{{ total }} BTC</span>
                    <small class="text-muted x-small font-weight-bold letter-spacing-1">Approx. 0.000 ETH</small>
                </div>
            </div>
            
            {% if items|length > 0 %}
                <a href="{{ path('app_cart_checkout') }}" class="btn btn-primary w-100 py-3 rounded-pill fw-black shadow-lg shadow-primary-light transition-all hov-up text-decoration-none d-flex align-items-center justify-content-center">
                    <i class="fas fa-check-circle me-2"></i> Proceed to Checkout
                </a>
                <div class="mt-4 text-center">
                    <span class="badge bg-light text-muted x-small rounded-pill py-2 px-3 border">
                        <i class="fas fa-lock text-primary me-2 shadow-sm"></i> 100% Secure Payment via TRC20
                    </span>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function updateQty(id, action) {
        $.post('/cart/ajax/update/' + id, { action: action })
        .done(function(data) {
            if (data.removed) {
                $('.cart-row[data-id="' + id + '"]').fadeOut(300, function() {
                    $(this).remove();
                    if ($('.cart-row').length === 0) location.reload();
                });
            } else {
                $('#qty-val-' + id).text(data.quantity);
                $('#subtotal-val-' + id).text(data.subtotal + ' BTC');
            }
            
            // Global Updates
            $('#summary-subtotal').text(data.total + ' BTC');
            $('#summary-total').text(data.total + ' BTC');
            
            // Navbar badge update
            if ($('.cart-badge').length) {
                $('.cart-badge text-white').text(data.cartCount);
            }
        });
    }
</script>
{% endblock %}

<style>
    .fw-black { font-weight: 800; }
    .text-gray-900 { color: #0f172a; }
    .x-small { font-size: 0.72rem; }
    .transition-all { transition: 0.3s; }
    .letter-spacing-1 { letter-spacing: 0.05rem; }
    .hover-light:hover { background-color: #f8fafc; }
    .btn-icon { width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center; padding: 0; }
    .btn-light-danger { background-color: #fff5f5; color: #f87171; border: none; }
    .btn-light-danger:hover { background-color: #f87171; color: white !important; }
    .hov-primary-light:hover { background-color: #f0f7ff !important; color: #3b82f6 !important; }
    .hov-danger-light:hover { background-color: #fff5f5 !important; color: #ef4444 !important; }
    .shadow-primary-light { box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.45); }
    .hov-up:hover { transform: translateY(-5px); }
    .text-blue-100 { color: #dbeafe; }
    .bg-white { background: white !important; }
    .border-dashed { border-style: dashed !important; border-width: 2px !important; }
    .text-xs { font-size: 0.6rem; }
</style>
{% endblock %}