{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}Panier — Champions Store{% endblock %}

{% block body %}
<div class="page-header mb-5">
    <div>
        <div class="page-label">Order Finalization</div>
        <h1 class="page-title">My <span style="color: var(--accent)">Cart</span> 🚀</h1>
        <p class="page-sub">Review your assets before secure blockchain confirmation.</p>
    </div>
</div>

<div class="row g-5">
    <!-- Cart List -->
    <div class="col-lg-8" id="cart-container">
        {% if items|length > 0 %}
            <div class="wallet-card p-0 overflow-hidden mb-4" style="background: var(--bg-card); border: 1px solid var(--border);">
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; --bs-table-hover-bg: rgba(255,255,255,0.02);">
                        <thead class="f-label" style="background: rgba(0,0,0,0.2); font-size: 10px;">
                            <tr>
                                <th class="ps-4 py-3 border-0">ASSET</th>
                                <th class="border-0">UNIT PRICE</th>
                                <th class="border-0">QUANTITY</th>
                                <th class="border-0">SUBTOTAL</th>
                                <th class="text-end pe-4 border-0">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody style="border-top: none;">
                            {% for item in items %}
                                <tr class="cart-row transition-all" data-id="{{ item.product.id }}" style="border-bottom: 1px solid var(--border);">
                                    <td class="ps-4 py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3 rounded-3 overflow-hidden p-1" style="width: 60px; height: 60px; background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                                                {% if item.product.imageUrl %}
                                                    <img src="{{ asset('uploads/products/' ~ item.product.imageUrl) }}" class="img-fluid h-100 w-100 object-fit-cover rounded-2">
                                                {% else %}
                                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                                        <i class="fas fa-box" style="color: var(--accent); opacity: 0.2;"></i>
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <div>
                                                <h4 class="h6 fw-bold text-white mb-1" style="font-family: var(--font-body);">{{ item.product.name }}</h4>
                                                <span class="user-role" style="font-size: 9px;">{{ item.product.brand ?: 'CHAMPIONS ASSET' }}</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="tx-amount" style="color: var(--accent); font-size: 14px;">{{ (item.product.discountPrice ?: item.product.price) }} <small style="font-size: 9px;">BTC</small></span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <button onclick="updateQty({{ item.product.id }}, 'minus')" class="act-btn" style="width: 28px; height: 28px;"><i class="fas fa-minus" style="font-size: 9px;"></i></button>
                                            <span id="qty-val-{{ item.product.id }}" class="mx-3 fw-bold" style="font-family: var(--font-mono); color: var(--text-1);">{{ item.quantity }}</span>
                                            <button onclick="updateQty({{ item.product.id }}, 'plus')" class="act-btn" style="width: 28px; height: 28px;"><i class="fas fa-plus" style="font-size: 9px;"></i></button>
                                        </div>
                                    </td>
                                    <td>
                                        <span id="subtotal-val-{{ item.product.id }}" class="tx-amount" style="font-size: 14px;">{{ item.subtotal }} <small style="font-size: 9px;">BTC</small></span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_cart_remove', {id: item.product.id}) }}" class="act-btn" style="width: 34px; height: 34px; color: var(--red); border-color: var(--red-dim);">
                                            <i class="fas fa-trash-alt" style="font-size: 12px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
           
            <a href="{{ path('app_marketplace_index') }}" class="btn-outline-head py-2 px-4 text-decoration-none d-inline-block" style="font-size: 12px;">
                <i class="fas fa-chevron-left me-2"></i> CONTINUE SHOPPING
            </a>
        {% else %}
            <div class="wallet-card p-5 text-center" style="background: var(--bg-card); border: 2px dashed var(--border);">
                <div class="mb-4">
                    <i class="fas fa-shopping-cart fa-4x" style="color: var(--accent); opacity: 0.1;"></i>
                </div>
                <h3 class="fw-bold text-white mb-3" style="font-family: var(--font-head);">Your cart is empty...</h3>
                <p class="text-muted mb-4 opacity-75">Explore our Marketplace and find the best assets!</p>
                <a href="{{ path('app_marketplace_index') }}" class="modal-btn-primary py-2 px-5 text-decoration-none d-inline-block">MARKETPLACE STORE</a>
            </div>
        {% endif %}
    </div>

    <!-- Summary -->
    <div class="col-lg-4">
        <div class="wallet-card p-4 sticky-top shadow-glow" style="background: var(--bg-card); border: 1px solid var(--border); top: 100px;">
            <h5 class="f-label mb-4 border-bottom border-secondary border-opacity-10 pb-3" style="letter-spacing: 2px;">ORDER SUMMARY</h5>
           
            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted" style="font-size: 12px;">Subtotal</span>
                <span id="summary-subtotal" class="text-white fw-bold" style="font-family: var(--font-mono);">{{ total }} BTC</span>
            </div>
            <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-secondary border-opacity-10">
                <span class="text-muted" style="font-size: 12px;">Network Fees (TRC20)</span>
                <span class="text-success fw-bold" style="font-size: 12px; font-family: var(--font-mono);">FREE ⚡</span>
            </div>
           
            <div class="d-flex justify-content-between mb-5">
                <span class="h5 fw-bold text-white mb-0" style="font-family: var(--font-head);">TOTAL</span>
                <div class="text-end">
                    <span id="summary-total" class="h3 fw-bold mb-0 d-block" style="color: var(--accent); font-family: var(--font-mono);">{{ total }} BTC</span>
                    <small class="user-role" style="font-size: 9px;">SECURE CHECKOUT READY</small>
                </div>
            </div>
           
            {% if items|length > 0 %}
                <a href="{{ path('app_cart_checkout') }}" class="modal-btn-primary py-3 w-100 text-center text-decoration-none d-block shadow-glow">
                    <i class="fas fa-shield-check me-2"></i> PROCEED TO CHECKOUT
                </a>
                <div class="mt-4 text-center">
                    <span class="tx-type py-2 px-3" style="font-size: 9px;">
                        <i class="fas fa-lock me-2"></i> 100% SECURE VIA CHAMPIONS PAY
                    </span>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
    .shadow-glow { box-shadow: 0 0 20px rgba(0,229,255,0.15); }
    .cart-row:hover { background: rgba(255,255,255,0.02); }
</style>
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function updateQty(id, action) {
        $.post('{{ path("app_cart_ajax_update", {id: "ID_PLACEHOLDER"}) }}'.replace('ID_PLACEHOLDER', id), { action: action })
        .done(function(data) {
            if (data.removed) {
                $('.cart-row[data-id="' + id + '"]').fadeOut(300, function() {
                    $(this).remove();
                    if ($('.cart-row').length === 0) location.reload();
                });
            } else {
                $('#qty-val-' + id).text(data.quantity);
                $('#subtotal-val-' + id).html(data.subtotal + ' <small style="font-size: 9px;">BTC</small>');
            }
           
            $('#summary-subtotal').text(data.total + ' BTC');
            $('#summary-total').text(data.total + ' BTC');
           
            if ($('.cart-badge').length) {
                $('.cart-badge').text(data.cartCount);
            }
        });
    }
</script>
{% endblock %}