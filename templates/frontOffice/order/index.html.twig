{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}Mes Commandes — Champions Store{% endblock %}

{% block body %}
<div class="page-header mb-5">
    <div>
        <div class="page-label">Asset Management</div>
        <h1 class="page-title">Order <span style="color: var(--accent)">History</span></h1>
        <p class="page-sub">Track your assets and view your blockchain transaction receipts.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-10 mx-auto">
        {% for order in orders %}
            <div class="wallet-card border-0 mb-5 overflow-hidden shadow-glow transition-all" style="background: var(--bg-card); border: 1px solid var(--border);">
                <div class="p-4" style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border);">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div class="d-flex align-items-center">
                            <div class="act-btn me-3" style="width: 45px; height: 45px; pointer-events: none;">
                                <i class="fas fa-receipt" style="color: var(--accent);"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold text-white" style="font-family: var(--font-head);">Order #ORD-{{ order.id }}</h5>
                                <small class="user-role" style="font-size: 10px;">{{ order.orderDate|date('d F Y at H:i') }}</small>
                            </div>
                        </div>
                       
                        <div class="text-md-end d-flex flex-column flex-md-row align-items-md-center gap-2">
                            <a href="{{ path('app_order_receipt', { id: order.id }) }}" target="_blank" rel="noopener" class="btn-outline-head py-1 px-3 text-decoration-none" style="font-size: 11px;">
                                <i class="fas fa-print me-1"></i> REÇU
                            </a>
                            <span class="status-badge py-1 px-4
                                {{ order.status == 'paid' ? 'actif' :
                                   order.status == 'pending_payment' ? 'py-1 px-4' :
                                   order.status == 'cancelled' ? 'bloque' : 'actif' }}"
                                style="font-size: 10px; {{ order.status == 'pending_payment' ? 'background: var(--gold-dim); color: var(--gold); border-color: var(--gold);' : '' }}">
                                <i class="fas
                                    {{ order.status == 'paid' ? 'fa-check-circle' :
                                       order.status == 'pending_payment' ? 'fa-clock' :
                                       order.status == 'cancelled' ? 'fa-times-circle' : 'fa-info-circle' }} me-2"></i>
                                {{ order.status|upper }}
                            </span>
                        </div>
                    </div>
                </div>
               
                <div class="card-body p-4">
                    <div class="table-responsive mb-4">
                        <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; --bs-table-hover-bg: rgba(255,255,255,0.01);">
                            <thead class="f-label" style="font-size: 9px; opacity: 0.5;">
                                <tr>
                                    <th class="border-0">ITEM DESCRIPTION</th>
                                    <th class="border-0 text-center">QTY</th>
                                    <th class="border-0 text-end">UP</th>
                                    <th class="border-0 text-end">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody style="border-top: none;">
                                {% for item in order.orderItems %}
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                {% if item.product and item.product.imageUrl %}
                                                    <div class="me-3 p-1 rounded-2" style="width: 40px; height: 40px; background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                                                        <img src="{{ asset('uploads/products/' ~ item.product.imageUrl) }}" class="w-100 h-100 object-fit-cover rounded-1">
                                                    </div>
                                                {% endif %}
                                                <span class="fw-bold text-white" style="font-size: 13px;">{{ item.product ? item.product.name : 'Removed Product' }}</span>
                                            </div>
                                        </td>
                                        <td class="text-center text-white-50" style="font-family: var(--font-mono); font-size: 12px;">x{{ item.quantity }}</td>
                                        <td class="text-end text-white-50" style="font-size: 12px;">{{ item.unitPrice }} <span style="font-size: 9px;">BTC</span></td>
                                        <td class="text-end fw-bold text-white" style="font-family: var(--font-mono); font-size: 13px;">{{ item.subTotal }} <span style="font-size: 9px;">BTC</span></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                   
                    <div class="p-4 rounded-4 d-flex flex-wrap justify-content-between align-items-center" style="background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                        <div class="d-flex flex-column gap-2 mb-3 mb-md-0">
                            <span class="user-role" style="font-size: 10px;"><i class="fas fa-truck-moving me-2" style="color: var(--accent);"></i> DESTINATION: <span class="text-white opacity-75">{{ order.shippingAddress }}</span></span>
                            <span class="user-role" style="font-size: 10px;"><i class="fas fa-shield-alt me-2" style="color: var(--green);"></i> NETWORK: <span class="tx-type py-1 px-2 ms-2" style="font-size: 8px;">BITCOIN (BTC)</span></span>
                        </div>
                        <div class="text-end">
                            <span class="f-label d-block mb-1" style="font-size: 9px; opacity: 0.5;">AMOUNT PAID</span>
                            <h3 class="mb-0 fw-bold" style="color: var(--accent); font-family: var(--font-mono);">{{ order.totalAmount }} BTC</h3>
                        </div>
                    </div>
                </div>
               
                {% if order.status == 'pending_payment' %}
                <div class="p-4 pt-0 d-flex justify-content-end gap-3 flex-wrap">
                    <form action="{{ path('app_order_cancel', {id: order.id}) }}" method="POST">
                        <button type="submit" class="act-btn px-4" style="width: auto; color: var(--red); border-color: var(--red-dim);">
                            <i class="fas fa-times me-2"></i> CANCEL
                        </button>
                    </form>
                    <form action="{{ path('app_order_pay', {id: order.id}) }}" method="POST">
                        <button type="submit" class="modal-btn-primary py-2 px-5 shadow-glow" style="font-size: 12px;">
                            <i class="fas fa-wallet me-2"></i> PAY NOW WITH WALLET
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        {% else %}
            <div class="wallet-card p-5 text-center" style="background: var(--bg-card); border: 2px dashed var(--border);">
                <div class="mb-4">
                    <i class="fas fa-box-open fa-4x" style="color: var(--accent); opacity: 0.1;"></i>
                </div>
                <h3 class="fw-bold text-white mb-3" style="font-family: var(--font-head);">No orders found 📦</h3>
                <p class="text-muted mb-4 opacity-75">You haven't made any purchases on our marketplace yet.</p>
                <a href="{{ path('app_marketplace_index') }}" class="modal-btn-primary py-2 px-5 text-decoration-none d-inline-block">BROWSE MARKETPLACE</a>
            </div>
        {% endfor %}
    </div>
</div>

<style>
    .shadow-glow { box-shadow: 0 0 30px rgba(0,0,0,0.3); }
    .wallet-card:hover { transform: translateY(-5px); border-color: var(--accent-dim) !important; }
</style>
{% endblock %}