<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Marketplace Fintech{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; color: #1e293b; }
        .navbar-brand { font-weight: 700; color: #3b82f6 !important; }
        .navbar { border-bottom: 1px solid #f1f5f9; background: white !important; }
        .nav-link { font-weight: 500; color: #475569 !important; }
        .nav-link:hover { color: #3b82f6 !important; }
        .btn-primary { background-color: #3b82f6; border: none; font-weight: 500; border-radius: 8px; }
        .btn-primary:hover { background-color: #2563eb; }
        .cart-badge { background-color: #ef4444; font-size: 0.65rem; padding: 2px 6px; border-radius: 50px; position: absolute; top: 0; right: 0; transform: translate(50%, -50%); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container-fluid px-md-5 py-2">
            <a class="navbar-brand d-flex align-items-center" href="{{ path('app_marketplace_index') }}">
                <i class="fas fa-store rounded-circle bg-primary text-white p-2 me-2"></i>
                FINTECH SHOP
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="{{ path('app_marketplace_index') }}">Marketplace</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="{{ path('app_order_index') }}">My Orders</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link" href="{{ path('app_projet') }}">Dashboard</a>
                    </li>
                    <li class="nav-item mx-2 position-relative">
                        <a class="btn btn-outline-primary rounded-pill px-4" href="{{ path('app_cart_index') }}">
                            <i class="fas fa-shopping-cart me-2"></i> Cart
                            {% if app.session.get('panier')|length > 0 %}
                                <span class="cart-badge text-white font-weight-bold">{{ app.session.get('panier')|length }}</span>
                            {% endif %}
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-5">
        <div class="container-fluid px-md-5">

            {% block body %}{% endblock %}
        </div>
    </main>

    <footer class="py-5 border-top bg-light mt-auto">
        <div class="container-fluid text-center">
            <p class="text-muted small">© {{ "now"|date("Y") }} Fintech Shop Marketplace. Tous droits réservés.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>