{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}{{ product.name }} — Champions Store{% endblock %}

{% block body %}
<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-5 mt-n2">
  <ol class="breadcrumb bg-transparent p-0 small">
    <li class="breadcrumb-item"><a href="{{ path('app_marketplace_index') }}" class="text-decoration-none text-muted">Marketplace</a></li>
    <li class="breadcrumb-item active" style="color: var(--accent); font-weight: 700;" aria-current="page">{{ product.name|upper }}</li>
  </ol>
</nav>

<div class="row g-5">
    <!-- Image Column -->
    <div class="col-lg-6">
        <div class="wallet-card border-0 p-4 sticky-top" style="top: 100px;">
            <div class="d-flex align-items-center justify-content-center rounded-4 overflow-hidden" style="min-height: 450px; background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                {% if product.imageUrl %}
                    <img src="{{ product.imageUrl|slice(0, 4) == 'http' ? product.imageUrl : asset('uploads/products/' ~ product.imageUrl) }}"
                         class="img-fluid transition-all" style="max-height: 400px; object-fit: contain; filter: drop-shadow(0 0 20px rgba(0,229,255,0.1));" alt="{{ product.name }}">
                {% else %}
                    <i class="fas fa-box fa-8x" style="color: var(--accent); opacity: 0.1;"></i>
                {% endif %}
            </div>
           
            <!-- Gallery Thumbnails (Demo) -->
            <div class="d-flex gap-3 mt-4 justify-content-center">
                <div class="rounded-3 border-2 p-1 cursor-pointer" style="width: 70px; height: 70px; border: 2px solid var(--accent); background: rgba(0,229,255,0.05);">
                    <div class="w-100 h-100 rounded-2" style="background: rgba(255,255,255,0.05);"></div>
                </div>
                <div class="rounded-3 border p-1 cursor-pointer opacity-50" style="width: 70px; height: 70px; border: 1px solid var(--border); background: rgba(0,0,0,0.2);">
                    <div class="w-100 h-100 rounded-2" style="background: rgba(255,255,255,0.02);"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Info Column -->
    <div class="col-lg-6">
        <div class="ps-lg-4">
            <div class="mb-5">
                <div class="d-flex align-items-center mb-3">
                    <span class="tx-type px-3 py-1 me-3" style="font-size: 10px;">
                        {{ product.category|replace({'_': ' '})|upper }}
                    </span>
                    <div class="text-warning small d-flex align-items-center gap-1">
                        {% for i in 1..5 %}
                            <i class="fas fa-star {{ i <= product.avgRating|round ? '' : 'opacity-25' }}" style="font-size: 10px;"></i>
                        {% endfor %}
                        <span class="ms-2 text-white opacity-50" style="font-size: 11px; font-family: var(--font-mono);">({{ product.avgRating ?: '4.5' }}/5)</span>
                    </div>
                </div>
               
                <h1 class="display-5 fw-bold text-white mb-2" style="font-family: var(--font-head);">{{ product.name }}</h1>
                <p class="user-role h5 mb-4" style="color: var(--accent);">{{ product.brand ?: 'CHAMPIONS CORE' }}</p>
               
                <div class="price-section py-4 border-top border-bottom border-secondary border-opacity-10 mb-4">
                    {% if product.discountPrice and product.discountPrice > 0 %}
                        <div class="d-flex align-items-end">
                            <span class="tx-amount up h1 mb-0 me-3" style="font-size: 3rem;">{{ product.discountPrice }} <small style="font-size: 14px;">BTC</small></span>
                            <div class="mb-1">
                                <del class="text-muted d-block small">{{ product.price }} BTC</del>
                                <span class="status-badge bloque px-2 py-1" style="font-size: 10px;">-{{ (((product.price - product.discountPrice) / product.price) * 100)|round }}% PROMO</span>
                            </div>
                        </div>
                    {% else %}
                        <span class="tx-amount h1 mb-0" style="font-size: 3rem; color: var(--accent);">{{ product.price }} <small style="font-size: 14px;">BTC</small></span>
                    {% endif %}
                </div>

                <div class="description mb-5">
                    <h5 class="f-label mb-3 text-uppercase" style="letter-spacing: 2px;">Technical Specs</h5>
                    <p class="text-white-50 lead fs-6 opacity-75" style="line-height: 1.8;">{{ product.description }}</p>
                </div>

                <!-- Features Preview -->
                <div class="row g-4 mb-5 p-4 rounded-4" style="background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="act-btn me-3" style="width: 40px; height: 40px; pointer-events: none;">
                                <i class="fas fa-shipping-fast" style="color: var(--accent);"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-white" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Secure Shipping</h6>
                                <p class="mb-0 text-muted" style="font-size: 10px;">24/48h Worldwide</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="act-btn me-3" style="width: 40px; height: 40px; pointer-events: none;">
                                <i class="fas fa-shield-alt" style="color: var(--green);"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-white" style="font-size: 10px; font-weight: 700; text-transform: uppercase;">Blockchain Trust</h6>
                                <p class="mb-0 text-muted" style="font-size: 10px;">Smart Contract Insured</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="buying-actions pt-2">
                    <div class="row g-3">
                        <div class="col-md-7">
                            <a href="{{ path('app_cart_add', {id: product.id}) }}" class="modal-btn-primary py-3 w-100 text-center text-decoration-none d-block shadow-glow">
                                <i class="fas fa-cart-plus me-2"></i> ADD TO CART
                            </a>
                        </div>
                        <div class="col-md-5">
                            <a href="#" class="modal-btn-secondary py-3 w-100 text-center text-decoration-none d-block">
                                <i class="fas fa-heart me-2" style="color: var(--red);"></i> WISHLIST
                            </a>
                        </div>
                    </div>
                   
                    <div class="mt-4 text-center">
                        <p class="user-role" style="font-size: 10px;">
                            <i class="fas fa-lock text-success me-2"></i> TRANSACTIONS SECURED BY CHAMPIONS NETWORK
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AI Recommendations Section -->
    <div class="mt-5 pt-5 border-top border-secondary border-opacity-10">
        <div class="d-flex align-items-center justify-content-between mb-5">
            <div>
                <h2 class="h3 fw-bold text-white mb-1" style="font-family: var(--font-head);">AI RECOMMENDED</h2>
                <p class="user-role mb-0" style="color: var(--accent);"><i class="fas fa-magic me-2"></i> Powered by Groq Intelligence</p>
            </div>
            <a href="{{ path('app_marketplace_index') }}" class="btn-outline-head py-2 px-3 text-decoration-none" style="font-size: 11px;">
                EXPLORE ALL <i class="fas fa-long-arrow-alt-right ms-2"></i>
            </a>
        </div>

        <div class="row g-4">
            {% for rec in recommendations %}
                {% set p = rec.product %}
                <div class="col-6 col-md-3">
                    <div class="wallet-card h-100 p-2 text-center d-flex flex-column" style="background: var(--bg-card);">
                        <div class="rounded-4 d-flex align-items-center justify-content-center mb-3 overflow-hidden" style="height: 180px; background: rgba(0,0,0,0.2); border: 1px solid var(--border);">
                            <a href="{{ path('app_marketplace_product_show', {id: p.id}) }}" class="w-100 h-100 d-flex align-items-center justify-content-center">
                                {% if p.imageUrl %}
                                    <img src="{{ p.imageUrl|slice(0, 4) == 'http' ? p.imageUrl : asset('uploads/products/' ~ p.imageUrl) }}" class="img-fluid transition-all" style="max-height: 140px; object-fit: contain;">
                                {% else %}
                                    <i class="fas fa-cube fa-3x" style="color: var(--accent); opacity: 0.1;"></i>
                                {% endif %}
                            </a>
                        </div>
                        <div class="p-2 flex-grow-1 d-flex flex-column">
                            <h6 class="fw-bold text-white mb-1 text-truncate" title="{{ p.name }}">{{ p.name }}</h6>
                            <p class="tx-amount mb-3" style="font-size: 14px; color: var(--accent);">{{ p.price }} BTC</p>
                           
                            <!-- AI Reason -->
                            <div class="rounded-3 p-2 mb-3 mt-auto" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border); font-size: 10px; min-height: 60px; color: var(--text-3);">
                                <i class="fas fa-quote-left opacity-25 me-1"></i> {{ rec.reason }}
                            </div>

                            <a href="{{ path('app_marketplace_product_show', {id: p.id}) }}" class="btn-outline-head py-2 w-100 text-decoration-none" style="font-size: 10px;">VIEW ASSET</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-4">
                    <p class="text-muted small">No recommendations available at this time.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<style>
    .shadow-glow { box-shadow: 0 0 20px rgba(0,229,255,0.2); }
    .wallet-card:hover img { transform: scale(1.05); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); content: "/"; }
    .breadcrumb-item a:hover { color: var(--accent) !important; }
</style>
{% endblock %}