{% extends 'frontOffice/front_base.html.twig' %}

{% block title %}Champions Store — Premium Marketplace{% endblock %}

{% block body %}
<div class="page-header mb-5 d-flex flex-wrap justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <a href="{{ path('app_wallet_index') }}" class="act-btn me-4" style="width: 48px; height: 48px; text-decoration: none;" title="Retour au Dashboard">
            <i class="fas fa-chevron-left" style="color: var(--accent); font-size: 16px;"></i>
        </a>
        <div>
            <div class="page-label">Exclusive Access</div>
            <h1 class="page-title">Marketplace <span style="color: var(--accent)">Premium</span></h1>
            <p class="page-sub">Secure assets and high-end fintech hardware. Powered by Blockchain.</p>
        </div>
    </div>
    <div class="header-actions">
        <span class="footer-badge">
            <span class="dot"></span>
            <span id="front-product-count">{{ products|length }} PRODUITS DISPONIBLES</span>
        </span>
    </div>
</div>

<!-- ========== SEARCH + SORT + FILTER BAR ========== -->
<div class="chart-card mb-5">
    <div class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="f-label">Rechercher</label>
            <div class="position-relative">
                <input type="text" id="front-search-input" class="f-input" style="padding-left: 44px;"
                       placeholder="Produit, marque, catégorie..." autocomplete="off">
                <i class="fas fa-search position-absolute" style="left: 18px; top: 50%; transform: translateY(-50%); color: var(--text-3); opacity: 0.5;"></i>
                <button id="front-clear-btn" class="modal-close position-absolute" style="right: 10px; top: 50%; transform: translateY(-50%); display:none; width: 26px; height: 26px;">
                    <i class="fas fa-times" style="font-size: 10px;"></i>
                </button>
            </div>
        </div>
        <div class="col-lg-3 col-md-4">
            <label class="f-label">Trier par</label>
            <select id="front-sort-field" class="f-select">
                <option value="name">Nom</option>
                <option value="price">Prix</option>
                <option value="stock">Stock</option>
                <option value="category">Catégorie</option>
                <option value="brand">Marque</option>
                <option value="avgRating">Note</option>
                <option value="createdAt">Nouveauté</option>
            </select>
        </div>
        <div class="col-lg-2 col-md-4">
            <label class="f-label">Direction</label>
            <div class="d-flex gap-2">
                <button type="button" id="dir-asc-btn" class="act-btn active w-50 h-auto py-2" data-dir="ASC">
                    <i class="fas fa-arrow-up"></i>
                </button>
                <button type="button" id="dir-desc-btn" class="act-btn w-50 h-auto py-2" data-dir="DESC">
                    <i class="fas fa-arrow-down"></i>
                </button>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 text-center">
            <span id="front-search-loading" style="display:none; color: var(--accent); font-family: var(--font-mono); font-size: 12px;">
                <i class="fas fa-circle-notch fa-spin"></i> SYNCING...
            </span>
            <div id="front-live-badge" class="footer-badge w-100 justify-content-center py-2" style="background: rgba(0,230,118,.08); border-color: rgba(0,230,118,.2); color: var(--green);">
                <i class="fas fa-bolt me-1"></i> LIVE
            </div>
        </div>
    </div>
</div>

<!-- Product Grid -->
<div class="row g-4" id="front-products-grid">
    {% include 'frontOffice/marketplace/_product_cards.html.twig' %}
</div>

{# Pagination included in partial #}

<style>
    .truncate-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
    .product-card-col:hover .quick-action-overlay { opacity: 1; }
    .product-card-col:hover img { transform: scale(1.1); }
   
    .premium-pagination .pagination { display: flex; gap: 8px; list-style: none; padding: 0; }
    .premium-pagination .page-item .page-link {
        background: var(--bg-card); border: 1px solid var(--border);
        color: var(--text-2); border-radius: 10px; padding: 10px 18px;
        font-family: var(--font-mono); font-weight: 600; text-decoration: none;
        transition: all 0.2s;
    }
    .premium-pagination .page-item.active .page-link {
        background: var(--accent); color: #080d14; border-color: var(--accent);
        box-shadow: 0 0 15px rgba(0,229,255,0.3);
    }
    .premium-pagination .page-item:not(.active) .page-link:hover {
        border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,0.05);
    }

    #front-products-grid { transition: opacity 0.3s ease; }
    #front-products-grid.loading { opacity: 0.35; }

    @keyframes cardSlideIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .product-card-col { animation: cardSlideIn 0.4s ease forwards; }
   
    .act-btn.active { border-color: var(--accent); background: rgba(0,229,255,0.08); color: var(--accent); }

    /* Wishlist Heart Animation */
    @keyframes heartBeat {
        0% { transform: scale(1); }
        15% { transform: scale(1.3); }
        30% { transform: scale(1); }
        45% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }
    .animate-heart { animation: heartBeat 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
</style>
{% endblock %}

{% block javascripts %}
<script>
(function() {
    var searchInput = document.getElementById('front-search-input');
    var sortField = document.getElementById('front-sort-field');
    var ascBtn = document.getElementById('dir-asc-btn');
    var descBtn = document.getElementById('dir-desc-btn');
    var grid = document.getElementById('front-products-grid');
    var loadingIndicator = document.getElementById('front-search-loading');
    var liveBadge = document.getElementById('front-live-badge');
    var clearBtn = document.getElementById('front-clear-btn');
    var countBadge = document.getElementById('front-product-count');
    var currentDir = 'ASC';
    var currentPage = 1;
    var debounceTimer = null;

    function frontSearch(page) {
        if (page) currentPage = page;
       
        var q = searchInput.value.trim();
        var sort = sortField.value;
        var dir = currentDir;

        loadingIndicator.style.display = 'inline';
        liveBadge.style.display = 'none';
        grid.classList.add('loading');

        clearBtn.style.display = q.length > 0 ? '' : 'none';

        var url = '{{ path("app_marketplace_ajax_search") }}' +
                  '?q=' + encodeURIComponent(q) +
                  '&sortBy=' + encodeURIComponent(sort) +
                  '&sortDir=' + encodeURIComponent(dir) +
                  '&page=' + currentPage;

        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                loadingIndicator.style.display = 'none';
                liveBadge.style.display = 'inline';
                grid.classList.remove('loading');

                if (xhr.status === 200) {
                    grid.innerHTML = xhr.responseText;
                    var cardCount = grid.querySelectorAll('.product-card-col').length;
                    countBadge.innerText = cardCount + ' PRODUITS DISPONIBLES';
                    attachPaginationEvents();
                    grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        };
        xhr.send();
    }

    function attachPaginationEvents() {
        var links = grid.querySelectorAll('.premium-pagination a');
        links.forEach(function(link) {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                var urlParams = new URLSearchParams(this.getAttribute('href').split('?')[1]);
                var page = urlParams.get('page') || 1;
                frontSearch(page);
            });
        });
    }

    searchInput.addEventListener('input', function() {
        currentPage = 1;
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(frontSearch, 300);
    });

    sortField.addEventListener('change', function() {
        currentPage = 1;
        frontSearch();
    });

    ascBtn.addEventListener('click', function() {
        currentDir = 'ASC';
        currentPage = 1;
        ascBtn.classList.add('active');
        descBtn.classList.remove('active');
        frontSearch();
    });
    descBtn.addEventListener('click', function() {
        currentDir = 'DESC';
        currentPage = 1;
        descBtn.classList.add('active');
        ascBtn.classList.remove('active');
        frontSearch();
    });

    clearBtn.addEventListener('click', function() {
        searchInput.value = '';
        currentPage = 1;
        clearBtn.style.display = 'none';
        frontSearch();
    });

    attachPaginationEvents();

    searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            currentPage = 1;
            frontSearch();
        }
    });

    grid.addEventListener('click', function(e) {
        var btn = e.target.closest('.wishlist-btn-floating');
        if (btn) {
            e.preventDefault();
            e.stopPropagation();
            var productId = btn.getAttribute('data-id');
            toggleWishlist(btn, productId);
        }
    });

    function toggleWishlist(btn, id) {
        var icon = btn.querySelector('i');
        btn.style.pointerEvents = 'none';
        btn.style.opacity = '0.7';
        var url = '{{ path("app_wishlist_toggle", {id: "999999"}) }}'.replace('999999', id);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', url, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
                if (xhr.status === 200) {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.isWishlisted) {
                        icon.classList.remove('far');
                        icon.classList.add('fas', 'animate-heart');
                    } else {
                        icon.classList.remove('fas', 'animate-heart');
                        icon.classList.add('far');
                    }
                }
            }
        };
        xhr.send();
    }
})();
</script>
{% endblock %}