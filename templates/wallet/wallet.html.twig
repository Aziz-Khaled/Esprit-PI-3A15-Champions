            {% for c in all_available_currencies %}
              <option value="{{ c.id }}" data-nom="{{ c.nom }}" data-type="{{ c.typeCurrency|lower }}" data-trading="{{ c.isTrading ? 'true' : 'false' }}">{{ c.nom }} ({{ c.code|upper }})</option>
            {% endfor %}
          </select>
          <input type="hidden" name="nom_currency" id="hidden-nom-currency">
