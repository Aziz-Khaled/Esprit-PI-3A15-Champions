{% extends 'base.html.twig' %}

{% block title %}Champions — Wallet Management{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --bg-card2:     #111b2b;
    --border:       #1a2a40;
    --border-glow:  rgba(0,229,255,.15);
    --accent:       #00e5ff;
    --accent2:      #00b4cc;
    --accent-glow:  rgba(0,229,255,.18);
    --gold:         #f0b429;
    --gold-dim:     rgba(240,180,41,.10);
    --green:        #00e676;
    --green-dim:    rgba(0,230,118,.10);
    --red:          #ff1744;
    --red-dim:      rgba(255,23,68,.10);
    --text-1:       #f0f4ff;
    --text-2:       #f0f4ff;
    --text-3:       #f0f4ff;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
    --navbar-h:     64px;
    --footer-h:     220px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg-base);
    color: var(--text-1);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 3px; }

  /* ── BACKGROUND EFFECTS ── */
  .bg-grid {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(0,229,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,.03) 1px, transparent 1px);
    background-size: 52px 52px;
    animation: gridDrift 25s linear infinite;
  }
  @keyframes gridDrift {
    0%   { background-position: 0 0; }
    100% { background-position: 52px 52px; }
  }
  .bg-orb {
    position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0;
  }
  .bg-orb-1 {
    width: 600px; height: 600px; top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(0,229,255,.08) 0%, transparent 70%);
    animation: orbFloat 10s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 440px; height: 440px; bottom: -160px; right: -100px;
    background: radial-gradient(circle, rgba(240,180,41,.07) 0%, transparent 70%);
    animation: orbFloat 14s ease-in-out infinite alternate-reverse;
  }
  @keyframes orbFloat {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(28px,18px) scale(1.06); }
  }

  /* ── LAYOUT ── */
  .app-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  /* ══════════════════════════════════════════
     NAVBAR (replaces sidebar)
  ══════════════════════════════════════════ */
  .topnav {
    position: sticky;
    top: 0;
    z-index: 200;
    height: var(--navbar-h);
    background: rgba(8,13,20,.97);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    padding: 0 32px;
    gap: 0;
    overflow: hidden;
  }
  .topnav::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.25;
  }

  /* Logo */
  .topnav-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 36px;
  }
  .logo-icon {
    width: 34px; height: 34px; border-radius: 9px;
    background: linear-gradient(135deg, #1de9b6, #00b4cc);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px; color: #080d14;
    font-family: var(--font-head);
    box-shadow: 0 0 16px rgba(0,229,255,.3);
    flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-head); font-size: 18px; font-weight: 700;
    background: linear-gradient(90deg, var(--text-1), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }

  /* Nav links */
  .topnav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .topnav-links::-webkit-scrollbar { display: none; }

  .nav-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 10px;
    text-decoration: none; color: var(--text-1);
    font-size: 14px; font-weight: 500;
    transition: all .2s ease; position: relative;
    white-space: nowrap;
    background: none; border: none; cursor: pointer;
    font-family: var(--font-body); text-align: left;
    flex-shrink: 0;
  }
  .nav-btn i { font-size: 13px; flex-shrink: 0; }
  .nav-btn:hover { color: var(--text-1); background: rgba(255,255,255,.05); }
  .nav-btn.active {
    color: var(--accent);
    background: rgba(0,229,255,.08);
    border: 1px solid rgba(0,229,255,.15);
  }
  .nav-btn.active i { color: var(--accent); }
  .nav-btn .nav-badge {
    padding: 1px 7px; border-radius: 20px;
    background: rgba(0,229,255,.12); color: var(--accent);
    font-size: 10.5px; font-weight: 700; font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .nav-btn.danger { color: var(--red); }
  .nav-btn.danger:hover { background: rgba(255,23,68,.08); color: var(--red); }

  /* Divider */
  .topnav-sep {
    width: 1px; height: 24px;
    background: var(--border);
    margin: 0 8px;
    flex-shrink: 0;
  }

  /* Right side user area */
  .topnav-right {
    display: flex; align-items: center; gap: 10px;
    flex-shrink: 0;
    margin-left: 16px;
  }
  .user-card {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 12px; border-radius: 10px;
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    cursor: pointer; transition: border-color .2s;
  }
  .user-card:hover { border-color: rgba(0,229,255,.2); }
  .user-avatar {
    width: 28px; height: 28px; border-radius: 8px;
    background: linear-gradient(135deg, rgba(0,229,255,.2), rgba(0,180,204,.2));
    border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--accent); flex-shrink: 0;
  }
  .user-info { line-height: 1.25; }
  .user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }
  .user-role { font-size: 10.5px; color: var(--text-3); font-family: var(--font-mono); }

  /* ── MAIN CONTENT ── */
  .main-content {
    flex: 1;
    padding: 36px 48px 60px;
    display: flex; flex-direction: column; gap: 28px;
  }

  /* ── PAGE HEADER ── */
  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 20px;
    flex-wrap: wrap;
  }
  .page-label {
    font-size: 12px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 6px;
  }
  .page-title {
    font-family: var(--font-head); font-size: 32px; font-weight: 800;
    line-height: 1.1; letter-spacing: -.02em; margin-bottom: 6px;
  }
  .page-sub { font-size: 15px; color: var(--text-2); }
  .header-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  /* ── BUTTONS ── */
  .btn-primary-head {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 22px; border-radius: 10px; font-size: 15px; font-weight: 600;
    font-family: var(--font-body);
    background: var(--accent); color: #080d14; border: none;
    cursor: pointer; transition: opacity .2s, transform .15s;
    text-decoration: none; white-space: nowrap;
  }
  .btn-primary-head:hover { opacity: .88; transform: translateY(-1px); }
  .btn-outline-head {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 20px; border-radius: 10px; font-size: 15px; font-weight: 600;
    font-family: var(--font-body);
    background: transparent; color: var(--text-1);
    border: 1px solid var(--border); cursor: pointer;
    transition: border-color .2s, background .2s;
    text-decoration: none; white-space: nowrap;
  }
  .btn-outline-head:hover { border-color: var(--accent); background: rgba(0,229,255,.06); color: var(--accent); }
  .btn-ghost-head {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; border-radius: 9px; font-size: 15px; font-weight: 500;
    font-family: var(--font-body);
    background: transparent; color: var(--text-2); border: 1px solid var(--border);
    cursor: pointer; transition: all .2s; text-decoration: none;
  }
  .btn-ghost-head:hover { color: var(--text-1); background: rgba(255,255,255,.04); }

  /* ── FLASH MESSAGES ── */
  .flash-msg {
    padding: 14px 18px; border-radius: 12px; font-size: 15px; font-weight: 500;
    display: flex; align-items: center; gap: 10px;
    animation: fadeSlide .3s ease both;
  }
  @keyframes fadeSlide { from { opacity:0; transform: translateY(-6px); } to { opacity:1; transform: translateY(0); } }
  .flash-msg.success { background: rgba(0,230,118,.1); border: 1px solid rgba(0,230,118,.25); color: var(--green); }
  .flash-msg.error   { background: rgba(255,23,68,.1);  border: 1px solid rgba(255,23,68,.25);  color: var(--red); }
  .flash-close { margin-left: auto; cursor: pointer; opacity: .6; font-size: 16px; background: none; border: none; color: inherit; }

  /* ── STATS ROW ── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius); padding: 22px 24px;
    position: relative; overflow: hidden;
    transition: border-color .25s, transform .2s;
  }
  .stat-card:hover { border-color: rgba(0,229,255,.2); transform: translateY(-1px); }
  .stat-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .stat-card.cyan::before  { background: linear-gradient(90deg, var(--accent), transparent); }
  .stat-card.gold::before  { background: linear-gradient(90deg, var(--gold), transparent); }
  .stat-card.green::before { background: linear-gradient(90deg, var(--green), transparent); }
  .stat-card.red::before   { background: linear-gradient(90deg, var(--red), transparent); }
  .stat-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; margin-bottom: 14px;
  }
  .stat-icon.cyan  { background: rgba(0,229,255,.1);  color: var(--accent); }
  .stat-icon.gold  { background: rgba(240,180,41,.1); color: var(--gold); }
  .stat-icon.green { background: rgba(0,230,118,.1);  color: var(--green); }
  .stat-icon.red   { background: rgba(255,23,68,.1);  color: var(--red); }
  .stat-label { font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); margin-bottom: 6px; }
  .stat-value { font-family: var(--font-head); font-size: 28px; font-weight: 700; color: var(--text-1); }

  /* ── CHART CARD ── */
  .chart-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius); padding: 28px;
    position: relative; overflow: hidden;
  }
  .chart-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.4;
  }
  .card-header-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
  }
  .card-label-top {
    font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 4px;
  }
  .card-title-text {
    font-family: var(--font-head); font-size: 20px; font-weight: 700; color: var(--text-1);
  }
  .chart-layout { display: flex; align-items: center; gap: 36px; }
  .chart-wrap { flex-shrink: 0; width: 200px; height: 200px; position: relative; }
  .chart-center-label {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .chart-center-label .cl-num {
    font-family: var(--font-head); font-size: 22px; font-weight: 700; color: var(--text-1);
  }
  .chart-center-label .cl-sub { font-size: 13px; color: var(--text-3); margin-top: 2px; }
  .legend-grid { display: flex; flex-wrap: wrap; gap: 12px; flex: 1; }
  .legend-item {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.03); border: 1px solid var(--border);
    border-radius: 9px; padding: 9px 14px; min-width: 130px;
  }
  .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
  .legend-name { font-size: 13.5px; font-weight: 600; color: var(--text-1); }
  .legend-val  { font-size: 12px; color: var(--text-3); font-family: var(--font-mono); margin-top: 1px; }

  /* ── WALLET COLUMNS ── */
  .wallets-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .wallet-column {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .wallet-col-header {
    display: flex; align-items: center; gap: 10px;
    padding: 18px 22px 16px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .wallet-col-header::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  }
  .col-fiat    .wallet-col-header::after { background: linear-gradient(90deg, #3b82f6, transparent); }
  .col-trading .wallet-col-header::after { background: linear-gradient(90deg, var(--green), transparent); }
  .col-crypto  .wallet-col-header::after { background: linear-gradient(90deg, var(--gold), transparent); }
  .col-icon {
    width: 32px; height: 32px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center; font-size: 14px;
  }
  .col-fiat    .col-icon { background: rgba(59,130,246,.15); color: #3b82f6; }
  .col-trading .col-icon { background: rgba(0,230,118,.1);  color: var(--green); }
  .col-crypto  .col-icon { background: rgba(240,180,41,.1); color: var(--gold); }
  .col-title { font-family: var(--font-head); font-size: 16px; font-weight: 700; }
  .col-fiat    .col-title { color: #3b82f6; }
  .col-trading .col-title { color: var(--green); }
  .col-crypto  .col-title { color: var(--gold); }
  .col-count {
    margin-left: auto; font-size: 12px; font-family: var(--font-mono);
    color: var(--text-3); background: rgba(255,255,255,.04);
    padding: 3px 9px; border-radius: 20px; border: 1px solid var(--border);
  }
  .wallet-col-body { padding: 16px; display: flex; flex-direction: column; gap: 12px; }

  /* ── WALLET CARD ── */
  .wallet-card {
    background: var(--bg-card2);
    border: 1px solid var(--border);
    border-radius: 14px; padding: 18px;
    position: relative; overflow: hidden;
    transition: border-color .25s, transform .2s;
  }
  .wallet-card:hover { border-color: rgba(0,229,255,.15); transform: translateY(-1px); }
  .wallet-card::before {
    content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 3px;
    border-radius: 0 14px 14px 0;
  }
  .col-fiat    .wallet-card::before { background: linear-gradient(180deg, #3b82f6, #2563eb); }
  .col-trading .wallet-card::before { background: linear-gradient(180deg, var(--green), #059669); }
  .col-crypto  .wallet-card::before { background: linear-gradient(180deg, var(--gold), #d97706); }

  .wallet-card-top {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 14px;
  }
  .rib-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 4px; }
  .rib-value { font-family: var(--font-mono); font-size: 14.5px; font-weight: 600; color: var(--text-1); }
  .status-badge {
    padding: 4px 11px; border-radius: 20px; font-size: 11px; font-weight: 700;
    font-family: var(--font-mono); letter-spacing: .06em;
  }
  .status-badge.actif  { background: rgba(0,230,118,.12); color: var(--green); border: 1px solid rgba(0,230,118,.2); }
  .status-badge.bloque { background: rgba(255,23,68,.12);  color: var(--red);   border: 1px solid rgba(255,23,68,.2); }

  /* ── BALANCES ── */
  .balances-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .balance-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 12px; border-radius: 9px;
    background: rgba(0,0,0,.2); border: 1px solid rgba(26,42,64,.6);
    font-size: 14px; position: relative; overflow: hidden;
    transition: all .2s ease;
  }
  .balance-row.empty:hover { background: rgba(255,23,68,.08); border-color: rgba(255,23,68,.2); }
  .balance-currency { color: var(--text-2); font-weight: 500; }
  .balance-amount   { font-weight: 600; color: var(--text-1); font-family: var(--font-mono); }
  .balance-amount.zero { color: var(--text-3); }
  .delete-hover {
    position: absolute; inset: 0;
    background: rgba(255,23,68,.85); color: white;
    display: flex; align-items: center; justify-content: center;
    gap: 6px; font-size: 12.5px; font-weight: 700;
    opacity: 0; transition: opacity .2s; text-decoration: none;
  }
  .balance-row.empty:hover .delete-hover { opacity: 1; }
  .no-assets {
    text-align: center; padding: 12px; border-radius: 9px;
    background: rgba(0,0,0,.15); border: 1px dashed rgba(26,42,64,.8);
    font-size: 13.5px; color: var(--text-3);
  }

  /* ── ACTION BUTTONS ── */
  .card-actions { display: flex; align-items: center; gap: 6px; }
  .act-btn {
    width: 32px; height: 32px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; cursor: pointer; border: 1px solid var(--border);
    background: rgba(255,255,255,.03); color: var(--text-2);
    transition: all .2s; text-decoration: none;
  }
  .act-btn:hover        { color: var(--text-1); border-color: rgba(0,229,255,.2); background: rgba(0,229,255,.06); }
  .act-btn.add:hover    { color: var(--green); border-color: rgba(0,230,118,.25); background: rgba(0,230,118,.08); }
  .act-btn.history:hover{ color: var(--accent); border-color: rgba(0,229,255,.25); background: rgba(0,229,255,.08); }
  .act-btn.edit:hover   { color: var(--gold); border-color: rgba(240,180,41,.25); background: rgba(240,180,41,.08); }
  .act-btn.del:hover    { color: var(--red);  border-color: rgba(255,23,68,.25);  background: rgba(255,23,68,.08); }
  .act-btn.recharge:hover { color: var(--accent); border-color: rgba(0,229,255,.25); background: rgba(0,229,255,.08); }
  .act-btn.del[disabled]  { opacity: .3; cursor: not-allowed; pointer-events: none; }

  /* ── MODALS ── */
  .modal-backdrop-custom {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(4,8,16,.85); backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    padding: 20px; animation: fadeIn .2s ease both;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .modal-box {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 22px; width: 100%; max-width: 460px;
    position: relative; overflow: hidden;
    box-shadow: 0 40px 100px rgba(0,0,0,.7);
    animation: modalIn .3s cubic-bezier(.22,1,.36,1) both;
  }
  .modal-box.lg { max-width: 640px; }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(16px) scale(.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .modal-box::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.5;
  }
  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 28px 20px; border-bottom: 1px solid var(--border);
  }
  .modal-title {
    font-family: var(--font-head); font-size: 20px; font-weight: 700;
    display: flex; align-items: center; gap: 10px;
  }
  .modal-title-icon {
    width: 32px; height: 32px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center; font-size: 14px;
  }
  .modal-close {
    width: 30px; height: 30px; border-radius: 8px;
    background: rgba(255,255,255,.05); border: 1px solid var(--border);
    color: var(--text-2); cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center; transition: all .2s;
  }
  .modal-close:hover { background: rgba(255,23,68,.1); border-color: rgba(255,23,68,.25); color: var(--red); }
  .modal-body { padding: 24px 28px 28px; }

  /* ── FORM ELEMENTS ── */
  .field { margin-bottom: 18px; }
  .f-label {
    display: block; font-size: 12px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--text-3); margin-bottom: 7px;
  }
  .f-input, .f-select {
    width: 100%; padding: 12px 15px;
    background: rgba(0,0,0,.25);
    border: 1px solid rgba(90,112,144,.3);
    border-radius: 10px; color: var(--text-1);
    font-size: 15px; font-family: var(--font-body); outline: none;
    transition: border-color .2s, box-shadow .2s;
    -webkit-appearance: none;
  }
  .f-input:focus, .f-select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0,229,255,.1);
  }
  .f-select option { background: #111b2b; }
  .f-input[disabled], .f-input[readonly] { opacity: .5; cursor: not-allowed; }
  .modal-btn-primary {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);
    border: none; border-radius: 11px; color: #080d14;
    font-family: var(--font-head); font-weight: 700; font-size: 15px;
    letter-spacing: .04em; cursor: pointer;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 8px 24px rgba(0,229,255,.2); margin-top: 8px;
  }
  .modal-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 12px 30px rgba(0,229,255,.3); }
  .modal-btn-secondary {
    width: 100%; padding: 13px; margin-top: 8px;
    background: transparent; border: 1px solid var(--border);
    border-radius: 11px; color: var(--text-2);
    font-family: var(--font-body); font-weight: 600; font-size: 15px;
    cursor: pointer; transition: all .2s;
  }
  .modal-btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* ── HISTORY TABLE ── */
  .history-table { width: 100%; border-collapse: collapse; }
  .history-table th {
    text-align: left; padding: 11px 14px;
    font-size: 11px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--text-3);
    border-bottom: 1px solid var(--border);
  }
  .history-table th:last-child { text-align: right; }
  .history-table td { padding: 14px 14px; border-bottom: 1px solid rgba(26,42,64,.4); font-size: 14px; }
  .history-table td:last-child { text-align: right; }
  .history-table tr:last-child td { border-bottom: none; }
  .history-table tr:hover td { background: rgba(0,229,255,.025); }
  .tx-type {
    display: inline-block; padding: 3px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: .06em;
    font-family: var(--font-mono); text-transform: uppercase;
    background: rgba(0,229,255,.08); color: var(--accent);
    border: 1px solid rgba(0,229,255,.12);
  }
  .tx-amount.up { color: var(--green); font-weight: 700; font-family: var(--font-mono); }
  .tx-amount.dn { color: var(--red);   font-weight: 700; font-family: var(--font-mono); }
  .tx-date    { color: var(--text-3); font-family: var(--font-mono); font-size: 13px; }
  .tx-counter { color: var(--text-2); font-size: 13px; }
  .history-rib {
    font-family: var(--font-mono); font-size: 13px; color: var(--text-3);
    background: rgba(0,0,0,.2); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 13px; margin-bottom: 18px;
  }
  .spinner {
    width: 36px; height: 36px; border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: var(--accent); border-right-color: var(--gold);
    animation: spin 1s linear infinite; margin: 24px auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── EMPTY STATE ── */
  .empty-col {
    text-align: center; padding: 28px 16px;
    border: 1px dashed rgba(26,42,64,.8);
    border-radius: 12px; color: var(--text-3); font-size: 14px;
  }
  .empty-col i { font-size: 26px; margin-bottom: 8px; opacity: .4; display: block; }

  /* ── TICKER ── */
  .ticker-wrap {
    width: 100%;
    background: rgba(8,13,20,.95); border-top: 1px solid var(--border);
    height: 38px; overflow: hidden;
    flex-shrink: 0;
  }
  .ticker-track {
    display: flex; align-items: center; height: 100%;
    white-space: nowrap;
    animation: tickerScroll 35s linear infinite;
    width: max-content;
  }
  .ticker-item {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 0 28px; font-size: 13px; font-family: var(--font-mono); color: var(--text-2);
    border-right: 1px solid var(--border);
  }
  .ticker-item .sym { color: var(--accent); font-weight: 600; }
  .ticker-item .up  { color: var(--green); }
  .ticker-item .dn  { color: var(--red); }
  @keyframes tickerScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── CREDIT CARD ── */
  .credit-card-champions-pro {
    width: 100%; max-width: 420px; height: 250px;
    border-radius: 18px; padding: 24px 28px;
    position: relative; color: white; overflow: hidden;
    display: flex; flex-direction: column; justify-content: space-between;
    margin: 0 auto;
    background: linear-gradient(135deg, #0e2038 0%, #0a1628 40%, #0d1d35 70%, #061020 100%);
    box-shadow: 0 2px 0 rgba(0,229,255,.08) inset, 0 25px 60px rgba(0,0,0,.6);
    cursor: default; user-select: none;
  }
  .card-texture {
    position: absolute; inset: 0; border-radius: 18px;
    background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,229,255,.008) 2px, rgba(0,229,255,.008) 4px);
    pointer-events: none; z-index: 0;
  }
  .card-holo {
    position: absolute; inset: 0; border-radius: 18px;
    background: radial-gradient(ellipse at 50% 50%, rgba(0,229,255,.06) 0%, rgba(240,180,41,.04) 35%, transparent 80%);
    pointer-events: none; z-index: 0;
  }
  .card-bottom-band {
    position: absolute; bottom: 0; left: 0; right: 0; height: 35%;
    background: linear-gradient(to top, rgba(0,0,0,.3) 0%, transparent 100%);
    border-radius: 0 0 18px 18px; pointer-events: none; z-index: 0;
  }
  .card-gloss-effect {
    position: absolute; top: 0; left: 0; right: 0; height: 55%;
    border-radius: 18px 18px 60% 60%;
    background: linear-gradient(180deg, rgba(0,229,255,.07) 0%, transparent 100%);
    pointer-events: none; z-index: 0;
  }
  .card-edge {
    position: absolute; inset: 0; border-radius: 18px;
    border: 1px solid rgba(0,229,255,.15); pointer-events: none; z-index: 1;
  }
  .card-chip-pro {
    width: 48px; height: 36px;
    background: linear-gradient(135deg, #e8c84a 0%, #c8a020 30%, #f0d870 55%, #b89010 80%, #e0bc3a 100%);
    border-radius: 6px; position: relative;
    box-shadow: 0 1px 3px rgba(0,0,0,.5); overflow: hidden; flex-shrink: 0;
  }
  .card-chip-pro::before { content: ''; position: absolute; inset: 3px; border: 1px solid rgba(0,0,0,.2); border-radius: 3px; }
  .chip-line-v  { position: absolute; top: 3px; bottom: 3px; left: 50%; transform: translateX(-50%); width: 1px; background: rgba(0,0,0,.15); }
  .chip-line-h1 { position: absolute; top: 33%; left: 3px; right: 3px; height: 1px; background: rgba(0,0,0,.15); }
  .chip-line-h2 { position: absolute; top: 60%; left: 3px; right: 3px; height: 1px; background: rgba(0,0,0,.15); }
  .chip-shine   { position: absolute; top: 2px; left: 3px; right: 3px; height: 40%; background: linear-gradient(180deg, rgba(255,255,255,.35) 0%, transparent 100%); border-radius: 3px 3px 0 0; }
  .contactless-icon { display: flex; align-items: center; margin-left: 10px; }
  .nfc-arcs { display: flex; flex-direction: column; gap: 2.5px; }
  .nfc-arc { border: 1.5px solid rgba(255,255,255,.55); border-left: none; border-top: none; border-bottom: none; border-radius: 0 50% 50% 0; height: 6px; width: 5px; }
  .nfc-arc:nth-child(2) { height: 10px; width: 8px; }
  .nfc-arc:nth-child(3) { height: 14px; width: 11px; }
  .card-header-pro { display: flex; align-items: center; position: relative; z-index: 2; }
  .card-number-pro {
    font-family: var(--font-mono); font-size: 1.42rem; letter-spacing: 2.5px;
    display: flex; gap: 14px; color: rgba(255,255,255,.92); position: relative; z-index: 2;
  }
  .card-footer-pro { display: flex; justify-content: space-between; align-items: flex-end; position: relative; z-index: 2; }
  .card-label-small { font-size: 0.58rem; color: rgba(255,255,255,.45); letter-spacing: 1.5px; text-transform: uppercase; display: block; margin-bottom: 3px; }
  .card-value { font-size: 0.92rem; font-weight: 600; letter-spacing: 1px; color: rgba(255,255,255,.92); }
  .card-footer-right { display: flex; align-items: flex-end; gap: 22px; }
  .card-brand-pro { display: flex; flex-direction: column; align-items: flex-end; }
  .visa-text { font-family: "Arial Black", Impact, sans-serif; font-size: 1.9rem; font-style: italic; font-weight: 900; color: white; line-height: 1; letter-spacing: -1px; text-shadow: 0 0 12px rgba(0,229,255,.4); }
  .visa-decorator { height: 2.5px; width: 110%; background: linear-gradient(90deg, var(--accent), var(--gold)); margin-top: -3px; border-radius: 2px; box-shadow: 0 0 4px rgba(0,229,255,.5); }

  /* ════════════════════════════════════════
     FOOTER
  ════════════════════════════════════════ */
  .site-footer {
    background: rgba(8,13,20,.98);
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 10;
    flex-shrink: 0;
  }
  .site-footer::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.35;
  }
  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 48px 28px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
  }

  /* Brand column */
  .footer-brand {}
  .footer-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; margin-bottom: 14px;
  }
  .footer-tagline {
    font-size: 13.5px;
    color: var(--text-3);
    line-height: 1.65;
    max-width: 260px;
    margin-bottom: 20px;
  }
  .footer-socials {
    display: flex; gap: 10px;
  }
  .social-btn {
    width: 34px; height: 34px; border-radius: 9px;
    background: rgba(255,255,255,.04); border: 1px solid var(--border);
    color: var(--text-3); font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; transition: all .2s;
  }
  .social-btn:hover { color: var(--accent); border-color: rgba(0,229,255,.25); background: rgba(0,229,255,.07); }

  /* Link columns */
  .footer-col-title {
    font-size: 11px; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 14px;
  }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .footer-links li a {
    font-size: 14px; color: var(--text-3); text-decoration: none;
    transition: color .2s;
  }
  .footer-links li a:hover { color: var(--text-1); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 18px 48px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; flex-wrap: wrap;
    max-width: 1400px; margin: 0 auto;
  }
  .footer-copy {
    font-size: 13px; color: var(--text-3); font-family: var(--font-mono);
  }
  .footer-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px; border-radius: 20px;
    background: rgba(0,229,255,.07); border: 1px solid rgba(0,229,255,.15);
    font-size: 11.5px; font-weight: 600; color: var(--accent);
    font-family: var(--font-mono);
  }
  .footer-badge .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: .3; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .wallets-grid { grid-template-columns: 1fr 1fr; }
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 900px) {
    .main-content { padding: 24px 20px 40px; }
    .wallets-grid { grid-template-columns: 1fr; }
    .chart-layout { flex-direction: column; }
    .topnav { padding: 0 16px; }
    .topnav-links .nav-btn span:not(.nav-badge) { display: none; }
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 24px; }
    .footer-bottom { padding: 14px 20px; }
    .footer-inner { padding: 28px 20px 20px; }
  }
  @media (max-width: 600px) {
    .stats-row { grid-template-columns: 1fr 1fr; }
    .header-actions { flex-direction: column; align-items: stretch; }
    .footer-inner { grid-template-columns: 1fr; }
    .topnav { gap: 0; }
    .topnav-logo { margin-right: 12px; }
  }
</style>
{% endblock %}

{% macro render_wallet(wallet, colClass) %}
  <div class="wallet-card">
    <div class="wallet-card-top">
      <div>
        <div class="rib-label">Account Number</div>
        <div class="rib-value">{{ wallet.rib }}</div>
      </div>
      <span class="status-badge {{ wallet.statut }}">{{ wallet.statut|upper }}</span>
    </div>

    <div class="balances-list">
      {% for wc in wallet.walletCurrencys %}
        {% set isEmpty = (wc.solde == 0) %}
        <div class="balance-row {{ isEmpty ? 'empty' : '' }}">
          <span class="balance-currency">{{ wc.nomCurrency }}</span>
          <span class="balance-amount {{ isEmpty ? 'zero' : '' }}">{{ wc.solde|number_format(2) }}</span>
          {% if isEmpty %}
            <a href="{{ path('app_wallet_currency_delete', {'id': wc.idWalletCurrency}) }}"
               class="delete-hover"
               onclick="return confirm('Remove {{ wc.nomCurrency }} from wallet?')">
              <i class="fas fa-trash"></i> DELETE
            </a>
          {% endif %}
        </div>
      {% else %}
        <div class="no-assets">No assets configured</div>
      {% endfor %}
    </div>

    <div class="card-actions">
      {% if wallet.typeWallet|lower == 'fiat' %}
        <button class="act-btn recharge"
                onclick="document.getElementById('recharge_wallet_id').value='{{ wallet.idWallet }}'; openModal('rechargeModal')"
                title="Recharge">
          <i class="fas fa-bolt"></i>
        </button>
      {% endif %}
      <button class="act-btn add"
              onclick='openModal("addCurrencyModal"); setAddCurrencyWallet("{{ wallet.idWallet }}", "{{ wallet.typeWallet|lower }}")'
              title="Add asset">
        <i class="fas fa-plus"></i>
      </button>
      <button class="act-btn history"
              onclick='openModal("historyModal"); loadHistory("{{ wallet.idWallet }}", "{{ wallet.rib }}")'
              title="Transaction history">
        <i class="fas fa-history"></i>
      </button>
      <button class="act-btn edit"
              onclick='openModal("editModal"); setEditWallet("{{ wallet.idWallet }}", "{{ wallet.typeWallet }}", "{{ wallet.statut }}")'
              title="Edit">
        <i class="fas fa-pen"></i>
      </button>
      <form method="post" action="{{ path('app_wallet_delete', {'id': wallet.idWallet}) }}" style="margin:0"
            onsubmit="return confirm('Delete this wallet?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ wallet.idWallet) }}">
        <button type="submit" class="act-btn del" title="Delete"
                {{ wallet.walletCurrencys is not empty ? 'disabled' : '' }}>
          <i class="fas fa-trash"></i>
        </button>
      </form>
    </div>
  </div>
{% endmacro %}

{% block body %}
{% import _self as ui %}

<div class="bg-grid"></div>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>

<div class="app-shell">

  <!-- ══ NAVBAR ══ -->
  <nav class="topnav">

    <a class="topnav-logo" href="#">
      <div class="logo-icon">C</div>
      <div class="logo-text">Champions</div>
    </a>

    <div class="topnav-links">
      <a href="#" class="nav-btn"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
      <a href="{{ path('app_wallet_index') }}" class="nav-btn active">
        <i class="fas fa-wallet"></i> <span>My Wallets</span>
        <span class="nav-badge">{{ wallets|length }}</span>
      </a>
      <a href="{{ path('app_trading_dashboard') }}" class="nav-btn">
        <i class="fas fa-chart-line"></i> <span>Trades</span>
      </a>
      <a href="{{ path('app_marketplace_index') }}" class="nav-btn"><i class="fas fa-shopping-cart"></i> <span>Marketplace</span></a>
      <a href="{{ path('app_credit_index') }}" class="nav-btn"><i class="fas fa-hand-holding-usd"></i> <span>Credit</span></a>
      <a href="{{ path('app_projet_index') }}" class="nav-btn"><i class="fas fa-graduation-cap"></i> <span>Projects</span></a>

      <div class="topnav-sep"></div>

      <button class="nav-btn" onclick="openModal('transactionModal')">
        <i class="fas fa-exchange-alt"></i> <span>Transfer</span>
      </button>
      <button class="nav-btn" onclick="openModal('convertModal')">
        <i class="fas fa-sync-alt"></i> <span>Convert</span>
      </button>
      <button class="nav-btn" onclick="openModal('cardRealistModal')">
        <i class="fas fa-credit-card"></i> <span>My Card</span>
      </button>
      <a href="{{ path('app_wallet_export_pdf') }}" class="nav-btn">
        <i class="fas fa-file-pdf"></i> <span>Statement</span>
      </a>
    </div>

    <div class="topnav-right">
      <a href="#" class="nav-btn danger" style="padding:8px 12px"><i class="fas fa-sign-out-alt"></i></a>
      <div class="user-card">
        <div class="user-avatar"><i class="fas fa-user"></i></div>
        <div class="user-info">
          <div class="user-name">My Account</div>
          <div class="user-role">ACTIVE</div>
        </div>
      </div>
    </div>

  </nav>

  <!-- ══ TICKER ══ -->
  <div class="ticker-wrap">
    <div class="ticker-track">
      {% set ticks = [
        {sym:'BTC/USD', price:'67,412.50', change:'+2.34%', up:true},
        {sym:'ETH/USD', price:'3,521.80',  change:'+1.87%', up:true},
        {sym:'SOL/USD', price:'152.45',    change:'-0.62%', up:false},
        {sym:'BNB/USD', price:'578.20',    change:'+0.94%', up:true},
        {sym:'XRP/USD', price:'0.6120',    change:'-1.10%', up:false},
        {sym:'ADA/USD', price:'0.4530',    change:'+3.21%', up:true},
        {sym:'DOGE/USD',price:'0.1620',    change:'+5.44%', up:true},
        {sym:'AVAX/USD',price:'38.91',     change:'-2.15%', up:false},
        {sym:'LINK/USD',price:'14.72',     change:'+1.23%', up:true},
      ] %}
      {% for t in ticks %}{% for i in 1..2 %}
        <span class="ticker-item">
          <span class="sym">{{ t.sym }}</span>
          {{ t.price }}
          <span class="{{ t.up ? 'up' : 'dn' }}">{{ t.change }}</span>
        </span>
      {% endfor %}{% endfor %}
    </div>
  </div>

  <!-- ══ MAIN ══ -->
  <main class="main-content">

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="flash-msg {{ (label == 'error' or label == 'danger') ? 'error' : 'success' }}">
          <i class="fas {{ (label == 'error' or label == 'danger') ? 'fa-exclamation-circle' : 'fa-check-circle' }}"></i>
          {{ message }}
          <button class="flash-close" onclick="this.parentElement.remove()">×</button>
        </div>
      {% endfor %}
    {% endfor %}

    <!-- PAGE HEADER -->
    <div class="page-header">
      <div>
        <div class="page-label">Portfolio</div>
        <div class="page-title">My Wallets</div>
        <div class="page-sub">Monitor and manage your digital assets across all platforms.</div>
      </div>
      <div class="header-actions">
        <button class="btn-outline-head" onclick="openModal('addWalletModal')">
          <i class="fas fa-plus"></i> New Wallet
        </button>
      </div>
    </div>

    <!-- STATS ROW -->
    <div class="stats-row">
      <div class="stat-card cyan">
        <div class="stat-icon cyan"><i class="fas fa-wallet"></i></div>
        <div class="stat-label">Total Wallets</div>
        <div class="stat-value">{{ wallets|length }}</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon green"><i class="fas fa-university"></i></div>
        <div class="stat-label">Fiat Accounts</div>
        <div class="stat-value">{{ wallets|filter(w => w.typeWallet|lower == 'fiat')|length }}</div>
      </div>
      <div class="stat-card gold">
        <div class="stat-icon gold"><i class="fab fa-bitcoin"></i></div>
        <div class="stat-label">Crypto Wallets</div>
        <div class="stat-value">{{ wallets|filter(w => w.typeWallet|lower == 'crypto')|length }}</div>
      </div>
      <div class="stat-card red">
        <div class="stat-icon red"><i class="fas fa-bolt"></i></div>
        <div class="stat-label">Trading Desks</div>
        <div class="stat-value">{{ wallets|filter(w => w.typeWallet|lower == 'trading')|length }}</div>
      </div>
    </div>

    <!-- PORTFOLIO CHART -->
    <div class="chart-card">
      <div class="card-header-row">
        <div>
          <div class="card-label-top">Analytics</div>
          <div class="card-title-text">Portfolio Allocation</div>
        </div>
      </div>
