<!-- ADD CURRENCY -->
<div id="addCurrencyModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'addCurrencyModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,230,118,.1);color:var(--green)"><i class="fas fa-coins"></i></div>Add Asset</div>
