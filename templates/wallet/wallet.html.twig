<!-- RECHARGE -->
<div id="rechargeModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'rechargeModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,229,255,.1);color:var(--accent)"><i class="fas fa-bolt"></i></div>Recharge Wallet</div>
      <button class="modal-close" onclick="closeModal('rechargeModal')">×</button>
    </div>
    <div class="modal-body">
      <form action="{{ path('app_wallet_recharge') }}" method="POST">
        <input type="hidden" name="wallet_id" id="recharge_wallet_id">
        <div class="field"><label class="f-label">Select Currency</label>
          <select name="currency_id" class="f-select">
            {% for currency in all_available_currencies %}{% if currency.typeCurrency == 'fiat' %}
              <option value="{{ currency.id }}">{{ currency.nom }}</option>
            {% endif %}{% endfor %}
          </select>
        </div>
        <div class="field"><label class="f-label">Amount</label>
          <input type="number" name="amount" step="0.01" class="f-input" placeholder="0.00" required>
        </div>
        <button type="submit" class="modal-btn-primary"><i class="fas fa-paper-plane" style="margin-right:7px"></i>Send Verification Code</button>
      </form>
    </div>
  </div>
</div>

<!-- VERIFY CODE -->
<div id="verifyCodeModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'verifyCodeModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(240,180,41,.1);color:var(--gold)"><i class="fas fa-shield-alt"></i></div>Security Check</div>
      <button class="modal-close" onclick="closeModal('verifyCodeModal')">×</button>
