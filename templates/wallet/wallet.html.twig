<!-- TRANSFER -->
<div id="transactionModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'transactionModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,229,255,.1);color:var(--accent)"><i class="fas fa-exchange-alt"></i></div>New Transfer</div>
      <button class="modal-close" onclick="closeModal('transactionModal')">×</button>
    </div>
    <div class="modal-body">
      {{ form_start(transactionForm, {'action': path('app_transaction_execute')}) }}
        {{ form_widget(transactionForm.type) }}
        <div class="field"><label class="f-label">Source RIB</label>
          {{ form_widget(transactionForm.ribSource, {'attr': {'class': 'f-input', 'placeholder': 'Enter source RIB'}}) }}
          <div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(transactionForm.ribSource) }}</div>
        </div>
        <div class="field"><label class="f-label">Destination RIB</label>
          {{ form_widget(transactionForm.ribDestination, {'attr': {'class': 'f-input', 'placeholder': 'Enter destination RIB'}}) }}
          <div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(transactionForm.ribDestination) }}</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="field"><label class="f-label">Amount</label>
            {{ form_widget(transactionForm.montant, {'attr': {'class': 'f-input', 'placeholder': '0.00'}}) }}
            <div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(transactionForm.montant) }}</div>
          </div>
          <div class="field"><label class="f-label">Currency</label>
            {{ form_widget(transactionForm.currency, {'attr': {'class': 'f-select'}}) }}
            <div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(transactionForm.currency) }}</div>
          </div>
        </div>
        <button type="submit" class="modal-btn-primary"><i class="fas fa-paper-plane" style="margin-right:7px"></i>Confirm Transfer</button>
      {{ form_end(transactionForm) }}
    </div>
  </div>
</div>

