                            <span class="text-muted small">You will get approximately:</span>
                            <h3 id="preview_val" class="fw-bold text-primary mb-0">0.00</h3>
                        </div>

                        <button type="button" id="btn_calc" class="btn btn-primary w-100 py-2 fw-bold rounded-3">Get Live Rate</button>
                    </div>

