    <div class="modal-body" style="text-align:center">
      <form action="{{ path('app_wallet_recharge_confirm') }}" method="POST">
        <p style="color:var(--text-2);margin-bottom:20px;font-size:14px">A 6-digit code has been sent to your email. Enter it to authorize the transaction.</p>
        <input type="text" name="verification_code" class="f-input"
               style="text-align:center;letter-spacing:10px;font-size:1.8rem;font-family:var(--font-mono)"
               placeholder="000000" maxlength="6" required>
        <button type="submit" class="modal-btn-primary" style="margin-top:20px"><i class="fas fa-check" style="margin-right:7px"></i>Verify & Confirm</button>
      </form>
    </div>
  </div>
</div>

<!-- CONVERT -->
<div id="convertModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'convertModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,230,118,.1);color:var(--green)"><i class="fas fa-sync-alt"></i></div>Asset Exchange</div>
      <button class="modal-close" onclick="closeModal('convertModal')">×</button>
    </div>
    <div class="modal-body">
      <form action="{{ path('app_wallet_convert') }}" method="POST">
        <div id="conv-step1">
          <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:end;margin-bottom:16px">
            <div class="field" style="margin:0"><label class="f-label">From</label>
              <select id="api_from" class="f-select">{% for currency in all_available_currencies %}<option value="{{ currency.nom }}">{{ currency.nom }}</option>{% endfor %}</select>
            </div>
            <div style="padding-bottom:10px;color:var(--text-3)"><i class="fas fa-random"></i></div>
            <div class="field" style="margin:0"><label class="f-label">To</label>
              <select id="api_to" class="f-select">{% for currency in all_available_currencies %}<option value="{{ currency.nom }}">{{ currency.nom }}</option>{% endfor %}</select>
            </div>
          </div>
          <div class="field"><label class="f-label">Amount</label>
            <input type="number" id="api_amount" name="amount_from" class="f-input" placeholder="0.00">
          </div>
          <div id="result_preview" style="display:none;background:rgba(0,229,255,.05);border:1px solid rgba(0,229,255,.15);border-radius:10px;padding:16px;text-align:center;margin-bottom:16px">
            <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">You will receive approximately</div>
            <div id="preview_val" style="font-family:var(--font-head);font-size:22px;color:var(--accent);font-weight:700">0.00</div>
          </div>
          <button type="button" id="btn_calc" class="modal-btn-primary">Get Live Rate</button>
        </div>
        <div id="conv-step2" style="display:none">
          <div class="field"><label class="f-label">Source Wallet (RIB)</label>
            <select name="wallet_source" class="f-select">{% for wallet in wallets %}<option value="{{ wallet.idWallet }}">{{ wallet.rib }}</option>{% endfor %}</select>
          </div>
          <div class="field"><label class="f-label">Destination Wallet (RIB)</label>
            <select name="wallet_destination" class="f-select">{% for wallet in wallets %}<option value="{{ wallet.idWallet }}">{{ wallet.rib }}</option>{% endfor %}</select>
          </div>
          <input type="hidden" name="currency_from_name" id="hidden_from">
          <input type="hidden" name="currency_to_name" id="hidden_to">
          <button type="submit" class="modal-btn-primary"><i class="fas fa-check" style="margin-right:7px"></i>Execute Transaction</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- CARD VIEW -->
<div id="cardRealistModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'cardRealistModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,229,255,.1);color:var(--accent)"><i class="fas fa-credit-card"></i></div>My Card</div>
      <button class="modal-close" onclick="closeModal('cardRealistModal')">×</button>
    </div>
    <div class="modal-body">
      {% if creditCard %}
        <div class="credit-card-champions-pro">
          <div class="card-texture"></div><div class="card-holo"></div><div class="card-bottom-band"></div><div class="card-gloss-effect"></div><div class="card-edge"></div>
          <div class="card-header-pro">
            <div class="card-chip-pro"><div class="chip-shine"></div><div class="chip-line-v"></div><div class="chip-line-h1"></div><div class="chip-line-h2"></div></div>
            <div class="contactless-icon"><div class="nfc-arcs"><div class="nfc-arc"></div><div class="nfc-arc"></div><div class="nfc-arc"></div></div></div>
          </div>
          <div class="card-number-pro"><span>****</span><span>****</span><span>****</span><span>{{ creditCard.last4Digits }}</span></div>
          <div class="card-footer-pro">
            <div><span class="card-label-small">Card Holder</span><span class="card-value">{{ creditCard.cardHolderName|upper }}</span></div>
            <div class="card-footer-right">
              <div><span class="card-label-small">Expires</span><span class="card-value">{{ creditCard.expiryMonth|format('%02d') }}/{{ creditCard.expiryYear|slice(-2) }}</span></div>
              <div class="card-brand-pro"><span class="visa-text">VISA</span><div class="visa-decorator"></div></div>
            </div>
          </div>
        </div>
        <div style="display:flex;gap:10px;justify-content:center;margin-top:20px">
          <button type="button" class="modal-btn-secondary" style="width:auto;padding:10px 22px;margin:0" onclick="closeModal('cardRealistModal'); openModal('editCardPopUp')">
            <i class="fas fa-pen" style="margin-right:6px"></i>Edit Card
          </button>
          <form method="post" action="{{ path('app_card_delete', {'id': creditCard.id}) }}" onsubmit="return confirm('Delete this card permanently?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ creditCard.id) }}">
            <button type="submit" class="modal-btn-secondary" style="width:auto;padding:10px 22px;margin:0;border-color:rgba(255,23,68,.3);color:var(--red)">
              <i class="fas fa-trash-alt" style="margin-right:6px"></i>Delete
            </button>
          </form>
        </div>
      {% else %}
        <div style="text-align:center;padding:30px 0">
          <i class="fas fa-credit-card" style="font-size:48px;color:var(--text-3);opacity:.3;margin-bottom:16px;display:block"></i>
          <div style="font-family:var(--font-head);font-size:18px;margin-bottom:8px">No Active Card</div>
          <p style="color:var(--text-2);font-size:14px;margin-bottom:20px">You haven't linked a card to your account yet.</p>
          <button type="button" class="modal-btn-primary" style="width:auto;display:inline-flex;padding:12px 24px" onclick="closeModal('cardRealistModal'); openModal('addCardModal')">
            <i class="fas fa-plus-circle" style="margin-right:7px"></i>Add a Card
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<!-- EDIT CARD -->
<div id="editCardPopUp" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'editCardPopUp')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(240,180,41,.1);color:var(--gold)"><i class="fas fa-edit"></i></div>Update Card</div>
      <button class="modal-close" onclick="closeModal('editCardPopUp')">×</button>
    </div>
    <div class="modal-body">
      {% if creditCard and cardForm is defined %}
        {{ form_start(cardForm, {'action': path('app_card_edit', {'id': creditCard.id}), 'method': 'POST', 'attr': {'novalidate': 'novalidate'}}) }}
          <div class="field"><label class="f-label">Card Holder Name</label>{{ form_widget(cardForm.cardHolderName, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(cardForm.cardHolderName) }}</div></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="field"><label class="f-label">Expiry Month</label>{{ form_widget(cardForm.expiryMonth, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(cardForm.expiryMonth) }}</div></div>
            <div class="field"><label class="f-label">Expiry Year</label>{{ form_widget(cardForm.expiryYear, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(cardForm.expiryYear) }}</div></div>
          </div>
          <button type="submit" class="modal-btn-primary">Save Changes</button>
        {{ form_end(cardForm) }}
      {% endif %}
    </div>
  </div>
</div>

<!-- ADD CARD -->
<div id="addCardModal" class="modal-backdrop-custom" style="display:none" onclick="closeModalBg(event,'addCardModal')">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title"><div class="modal-title-icon" style="background:rgba(0,229,255,.1);color:var(--accent)"><i class="fas fa-plus-circle"></i></div>Register New Card</div>
      <button class="modal-close" onclick="closeModal('addCardModal')">×</button>
    </div>
    <div class="modal-body">
      {% if newCardForm is defined %}
        {{ form_start(newCardForm, {'action': path('app_card_new'), 'method': 'POST', 'attr': {'novalidate': 'novalidate'}}) }}
          <div class="field"><label class="f-label">Card Number (16 digits)</label>{{ form_widget(newCardForm.fullNumber, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(newCardForm.fullNumber) }}</div></div>
          <div class="field"><label class="f-label">Card Holder Name</label>{{ form_widget(newCardForm.cardHolderName, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(newCardForm.cardHolderName) }}</div></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="field"><label class="f-label">Expiry Month</label>{{ form_widget(newCardForm.expiryMonth, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(newCardForm.expiryMonth) }}</div></div>
            <div class="field"><label class="f-label">Expiry Year</label>{{ form_widget(newCardForm.expiryYear, {'attr': {'class': 'f-input'}}) }}<div style="color:var(--red);font-size:11.5px;margin-top:4px">{{ form_errors(newCardForm.expiryYear) }}</div></div>
          </div>
          <button type="submit" class="modal-btn-primary"><i class="fas fa-link" style="margin-right:7px"></i>Link Card</button>
        {{ form_end(newCardForm) }}
      {% endif %}
    </div>
  </div>
</div>

<!-- ════════════════ SCRIPTS ════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
/* ── MODAL SYSTEM ── */
function openModal(id)  { document.getElementById(id).style.display = 'flex'; document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }
function closeModalBg(e, id) { if (e.target === e.currentTarget) closeModal(id); }

/* ── WALLET HELPERS ── */
function setAddCurrencyWallet(id, type) {
  document.getElementById('form-add-currency').action = '/wallet/' + id + '/add-currency';
  const sel = document.getElementById('select-currency');
  [...sel.options].forEach(opt => {
    const cType = opt.getAttribute('data-type');
    const isTr  = opt.getAttribute('data-trading');
    const vis   = (type === 'trading') ? (cType === 'crypto' && isTr === 'true') : (cType === type);
    opt.style.display = vis ? '' : 'none';
    opt.disabled = !vis;
  });
  const first = [...sel.options].find(o => !o.disabled);
  if (first) { sel.value = first.value; updateNom(sel); }
}
function updateNom(sel) {
  const opt = sel.options[sel.selectedIndex];
  document.getElementById('hidden-nom-currency').value = opt ? opt.getAttribute('data-nom') : '';
}
function setEditWallet(id, type, statut) {
  document.getElementById('edit-form').action   = '/wallet/' + id + '/edit';
  document.getElementById('modal-type').value   = type.toUpperCase();
  document.getElementById('modal-statut').value = statut;
}

/* ── HISTORY ── */
function loadHistory(id, rib) {
  document.getElementById('history-rib-display').textContent = 'Wallet: ' + rib;
  const tbody   = document.getElementById('history-table-body');
  const spinner = document.getElementById('history-spinner');
  tbody.innerHTML = '';
  spinner.style.display = 'block';
  fetch('/wallet/' + id + '/history-json')
    .then(r => r.json())
    .then(data => {
      spinner.style.display = 'none';
      if (!data.length) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-3);padding:24px">No transactions found.</td></tr>'; return; }
      tbody.innerHTML = data.map(tx => {
        const isOut = tx.direction === 'out';
        return `<tr>
          <td class="tx-date">${tx.date}</td>
          <td><span class="tx-type">${tx.type}</span></td>
          <td class="tx-counter">${tx.counterparty}</td>
          <td class="tx-amount ${isOut ? 'dn' : 'up'}">${isOut ? '−' : '+'}${tx.amount} ${tx.currency}</td>
        </tr>`;
      }).join('');
    })
    .catch(() => {
      spinner.style.display = 'none';
      tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--red)">Error loading history.</td></tr>';
    });
}

/* ── CONVERT ── */
document.getElementById('btn_calc').addEventListener('click', function() {
  const from = document.getElementById('api_from').value;
  const to   = document.getElementById('api_to').value;
  const amount = document.getElementById('api_amount').value;
  const btn = this;
  if (!amount || amount <= 0) return alert('Please enter a valid amount.');
  btn.textContent = 'Fetching live rate…'; btn.disabled = true;
  fetch('{{ path('app_wallet_get_rate') }}?from=' + from + '&to=' + to + '&amount=' + amount)
    .then(r => { if (!r.ok) throw new Error(); return r.json(); })
    .then(data => {
      if (data.error) { alert('Error: ' + data.error); btn.textContent = 'Get Live Rate'; btn.disabled = false; return; }
      document.getElementById('preview_val').textContent = data.result.toFixed(4) + ' ' + to;
      document.getElementById('result_preview').style.display = 'block';
      btn.textContent = 'Next: Select Wallets'; btn.disabled = false;
      btn.onclick = () => {
        document.getElementById('conv-step1').style.display = 'none';
        document.getElementById('conv-step2').style.display = 'block';
        document.getElementById('hidden_from').value = from;
        document.getElementById('hidden_to').value = to;
      };
    })
    .catch(() => { alert('Connection error.'); btn.textContent = 'Get Live Rate'; btn.disabled = false; });
});

/* ── AUTO-OPEN VERIFY MODAL ── */
document.addEventListener('DOMContentLoaded', () => {
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('verify')) openModal('verifyCodeModal');
});

/* ── CHART ── */
document.addEventListener('DOMContentLoaded', () => {
  const canvas = document.getElementById('walletChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  fetch('{{ path('app_wallet_chart_data') }}')
    .then(r => r.json())
    .then(data => {
      if (!data || !data.length) {
        document.getElementById('chart-legend').innerHTML = '<span style="color:var(--text-3);font-size:13px">No balance data yet.</span>';
        return;
      }
      const colors = ['#00e5ff', '#00e676', '#f0b429', '#3b82f6', '#ff1744', '#8b5cf6'];
      document.getElementById('chart-total').textContent = data.length;
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: data.map(d => d.name),
          datasets: [{ data: data.map(d => parseFloat(d.total)), backgroundColor: colors.map(c => c + '22'), borderColor: colors, borderWidth: 2, hoverOffset: 8 }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, cutout: '72%' }
      });
      document.getElementById('chart-legend').innerHTML = data.map((item, i) => `
        <div class="legend-item">
          <div class="legend-dot" style="background:${colors[i % colors.length]}"></div>
          <div><div class="legend-name">${item.name}</div><div class="legend-val">${parseFloat(item.total).toFixed(2)}</div></div>
        </div>`).join('');
    })
    .catch(err => console.error('Chart error:', err));
});
</script>
{% endblock %}
