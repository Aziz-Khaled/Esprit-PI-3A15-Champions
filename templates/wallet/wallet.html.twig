                            <select name="wallet_destination" class="form-select border-2">
                                {% for wallet in wallets %}
                                    <option value="{{ wallet.idWallet }}">{{ wallet.rib }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <input type="hidden" name="currency_from_name" id="hidden_from">
                        <input type="hidden" name="currency_to_name" id="hidden_to">
                    </div>
                </div>

                <div class="modal-footer border-0 pb-4 px-4">
                    <button type="submit" id="btn_final" class="btn w-100 py-3 text-white fw-bold rounded-3 d-none" 
                            style="background: var(--primary-gradient); border:none;">
                        Execute & Seal Transaction
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('btn_calc').addEventListener('click', function() {
    const from = document.getElementById('api_from').value;
    const to = document.getElementById('api_to').value;
    const amount = document.getElementById('api_amount').value;
    const btn = this;

    if(!amount || amount <= 0) return alert("Please enter a valid amount.");

    const originalText = btn.innerText;
    btn.innerText = "Fetching live rate...";
    btn.disabled = true;

    const url = "{{ path('app_wallet_get_rate') }}?from=" + from + "&to=" + to + "&amount=" + amount;

    fetch(url)
        .then(res => {
            if (!res.ok) throw new Error('Service unavailable');
            return res.json();
        })
        .then(data => {
            if (data.error) {
                alert("Error: " + data.error);
                btn.innerText = originalText;
                btn.disabled = false;
            } else {
                document.getElementById('preview_val').innerText = data.result.toFixed(4) + " " + to;
                document.getElementById('result_preview').classList.remove('d-none');
                
                btn.innerText = "Next: Select Wallets";
                btn.disabled = false;
                btn.classList.replace('btn-primary', 'btn-success');
                
                // On attache l'événement pour passer à l'étape 2
                btn.onclick = function() {
                    document.getElementById('step1').classList.add('d-none');
                    document.getElementById('step2').classList.remove('d-none');
                    document.getElementById('btn_final').classList.remove('d-none');
                    document.getElementById('hidden_from').value = from;
                    document.getElementById('hidden_to').value = to;
                };
            }
        })
        .catch(err => {
            alert("Connection error. Please try again.");
            btn.innerText = originalText;
            btn.disabled = false;
        });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // --- 1. LOGIQUE DE VÉRIFICATION PAR MAIL (POPUP AUTO) ---
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('verify')) {
            const verifyModalElement = document.getElementById('verifyCodeModal');
            if (verifyModalElement) {
                const verifyModal = new bootstrap.Modal(verifyModalElement);
                verifyModal.show();
            }
        }

        // --- 2. GESTION DU GRAPHIQUE ---
        const canvas = document.getElementById('walletChart');
        if (canvas) {
            const ctx = canvas.getContext('2d');
            
            fetch('{{ path('app_wallet_chart_data') }}')
                .then(response => response.json())
                .then(data => {
                    if (!data || data.length === 0) {
                        const legendDiv = document.getElementById('chart-legend');
                        if (legendDiv) legendDiv.innerHTML = '<span class="text-muted small italic">No balance data available yet.</span>';
                        return;
                    }

                    const labels = data.map(item => item.name);
                    const values = data.map(item => item.total);
                    
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: labels,
                            datasets: [{
                                data: values,
                                backgroundColor: ['#6366f1', '#10b981', '#f59e0b', '#3b82f6', '#f43f5e', '#8b5cf6'],
                                borderWidth: 0,
                                hoverOffset: 10
                            }]
                        },
                        options: {
                            responsive: true, maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            cutout: '70%'
                        }
                    });

                    const legendDiv = document.getElementById('chart-legend');
                    if (legendDiv) {
                        legendDiv.innerHTML = ''; 
                        const colors = ['#6366f1', '#10b981', '#f59e0b', '#3b82f6', '#f43f5e', '#8b5cf6'];
                        
                        data.forEach((item, index) => {
                            const color = colors[index % colors.length];
                            legendDiv.innerHTML += `
                                <div class="d-flex align-items-center">
                                    <div style="width: 12px; height: 12px; background: ${color}; border-radius: 3px; margin-right: 8px;"></div>
                                    <span class="small fw-bold">${item.name}</span>
                                    <span class="small text-muted ms-2">${parseFloat(item.total).toFixed(2)}</span>
                                </div>
                            `;
                        });
                    }
                });
        }

        // --- 3. LOGIQUE RECHARGE MODAL (SET WALLET ID) ---
        const rechargeModal = document.getElementById('rechargeModal');
        if (rechargeModal) {
            rechargeModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const walletId = button.getAttribute('data-id');
                const inputId = document.getElementById('recharge_wallet_id');
                if (inputId) inputId.value = walletId;
            });
        }

        // --- 4. LOGIQUE HISTORY MODAL ---
        const historyModal = document.getElementById('historyModal');
        if (historyModal) {
            historyModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const walletId = button.getAttribute('data-id');
                const rib = button.getAttribute('data-rib');
                const tableBody = document.getElementById('history-table-body');
                const loader = document.getElementById('history-loader');
                const ribTitle = document.getElementById('history-rib-title');

                if (ribTitle) ribTitle.innerText = "Wallet: " + rib;
                if (tableBody) tableBody.innerHTML = '';
                if (loader) loader.classList.remove('d-none');

                fetch(`/wallet/${walletId}/history-json`)
                    .then(response => response.json())
                    .then(data => {
                        if (loader) loader.classList.add('d-none');
                        if (!tableBody) return;

                        if (data.length === 0) {
                            tableBody.innerHTML = '<tr><td colspan="4" class="text-center py-3">No transactions found.</td></tr>';
                            return;
                        }
                        data.forEach(tx => {
                            const isOut = tx.direction === 'out'; 
                            const amountClass = isOut ? 'text-danger' : 'text-success';
                            const prefix = isOut ? '-' : '+';

                            tableBody.innerHTML += `
                                <tr>
                                    <td class="small">${tx.date}</td>
                                    <td><span class="badge bg-light text-dark text-uppercase" style="font-size:0.7rem;">${tx.type}</span></td>
                                    <td class="small text-muted">${tx.counterparty}</td>
                                    <td class="text-end fw-bold ${amountClass}">${prefix}${tx.amount} ${tx.currency}</td>
                                </tr>
                            `;
                        });
                    })
                    .catch(() => {
                        if (loader) loader.classList.add('d-none');
                        if (tableBody) tableBody.innerHTML = '<tr><td colspan="4" class="text-center text-danger">Error loading history.</td></tr>';
                    });
            });
        }

        // --- 5. LOGIQUE DES AUTRES MODALES (Add Currency / Edit) ---
        const addCurrencyModal = document.getElementById('addCurrencyModal');
        if (addCurrencyModal) {
            addCurrencyModal.addEventListener('show.bs.modal', function (event) {
                const btn = event.relatedTarget;
                const walletId = btn.getAttribute('data-id');
                const walletType = btn.getAttribute('data-type'); 
                const form = document.getElementById('form-add-currency');
                if (form) form.action = '/wallet/' + walletId + '/add-currency';
                
                const select = document.getElementById('select-currency');
                if (select) {
                    [...select.options].forEach(opt => {
                        const cType = opt.getAttribute('data-type');
                        const isTrading = opt.getAttribute('data-trading');
                        let visible = (walletType === 'trading') ? (cType === 'crypto' && isTrading === 'true') : (cType === walletType);
                        opt.style.display = visible ? 'block' : 'none';
                        opt.disabled = !visible;
                    });
                    const first = [...select.options].find(o => !o.disabled);
                    if (first) { select.value = first.value; updateNom(select); }
                }
            });
        }

        const editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const typeInput = document.getElementById('modal-type');
                const statutInput = document.getElementById('modal-statut');
                const form = document.getElementById('edit-form');
                
                if (typeInput) typeInput.value = button.getAttribute('data-type').toUpperCase();
                if (statutInput) statutInput.value = button.getAttribute('data-statut');
                if (form) form.action = '/wallet/' + id + '/edit';
            });
        }
    });

    function updateNom(select) {
        const selected = select.options[select.selectedIndex];
        const input = document.getElementById('hidden-nom-currency');
        if (input) input.value = selected ? selected.getAttribute('data-nom') : '';
    }
</script>
{% endblock %}