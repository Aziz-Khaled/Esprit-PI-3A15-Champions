        { icon:'D', bg:'#c2a633', sym:'DOGE', name:'Dogecoin',  price:'$0.1620',    change:'+5.44%',  up:true,  vol:'$1.9B',  cap:'$23B'   },
        { icon:'A', bg:'#0d1e2d', sym:'ADA',  name:'Cardano',   price:'$0.4530',    change:'+3.21%',  up:true,  vol:'$0.9B',  cap:'$16B'   },
