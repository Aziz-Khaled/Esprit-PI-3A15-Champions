<div class="form-group" id="limitPriceGroup" style="display:none;">
    <label>TARGET PRICE ($)</label>
    <input type="number" id="targetPrice" placeholder="Execute when price reaches...">
</div>
        <div class="form-group">
          <label>QUANTITY</label>
          <input type="number" id="qtyInput" placeholder="e.g. 0.5" min="0" step="any">
          <div class="qty-hint">Max recommended: <span id="maxQty">--</span></div>
