{% extends 'base.html.twig' %}

{% block title %}CryptoTrade – Dashboard{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary:    #0b0e11;
    --bg-secondary:  #161a1e;
    --bg-card:       #1e2329;
    --bg-hover:      #252b33;
    --border:        #2b3139;
    --accent-green:  #0ecb81;
    --accent-red:    #f6465d;
    --accent-yellow: #f0b90b;
    --text-primary:  #eaecef;
    --text-secondary:#848e9c;
    --text-dim:      #474d57;
    --font-mono:     'Space Mono', monospace;
    --font-body:     'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 13px;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ══ TOPBAR — style Binance ══ */
  .topbar {
    display: flex;
    align-items: center;
    padding: 0 20px;
    height: 56px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    z-index: 100;
    gap: 0;
  }

  .topbar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    color: var(--accent-yellow);
    text-decoration: none;
    margin-right: 24px;
    flex-shrink: 0;
  }
  .topbar-logo svg { width: 24px; height: 24px; }

  /* Nav links */
  .topbar-nav {
    display: flex;
    align-items: center;
    height: 100%;
    flex: 1;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 100%;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    position: relative;
    transition: color .18s;
    white-space: nowrap;
    text-decoration: none;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%; right: 50%;
    height: 2px;
    background: var(--accent-yellow);
    border-radius: 2px 2px 0 0;
    transition: left .22s, right .22s;
  }
  .nav-link:hover { color: var(--text-primary); }
  .nav-link:hover::after { left: 18px; right: 18px; }
  .nav-link.active { color: var(--text-primary); font-weight: 600; }
  .nav-link.active::after { left: 18px; right: 18px; }
  .nav-link svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; flex-shrink: 0; }

  /* Right side */
  .topbar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

  .topbar-sep { width: 1px; height: 22px; background: var(--border); margin: 0 8px; flex-shrink: 0; }

  .balance-badge {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 13px;
    transition: border-color .2s;
  }
  .balance-badge:hover { border-color: var(--accent-yellow); }
  .balance-badge .val { font-family: var(--font-mono); font-weight: 700; color: var(--accent-green); }

  .btn-admin {
    display: flex; align-items: center; gap: 6px;
    padding: 7px 16px;
    background: var(--accent-yellow);
    border: none; border-radius: 6px;
    color: #000; font-size: 13px; font-weight: 700;
    cursor: pointer; font-family: var(--font-body);
    transition: opacity .18s; text-decoration: none;
  }
  .btn-admin:hover { opacity: .88; }

  .icon-btn {
    width: 34px; height: 34px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px; background: transparent; border: none;
    color: var(--text-secondary); cursor: pointer;
    transition: background .18s, color .18s;
  }
  .icon-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
  .icon-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; }

  /* ══ TICKER ══ */
  .ticker-bar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    height: 30px; display: flex; align-items: center;
    overflow: hidden; flex-shrink: 0;
  }
  .ticker-inner {
    display: flex; gap: 40px;
    animation: ticker-scroll 30s linear infinite;
    white-space: nowrap; padding-left: 20px;
  }
  @keyframes ticker-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .ticker-item { display: flex; align-items: center; gap: 8px; font-size: 12px; }
  .ticker-item .sym  { color: var(--text-secondary); font-weight: 600; }
  .ticker-item .pr   { font-family: var(--font-mono); color: var(--text-primary); }
  .ticker-item .chg.up   { color: var(--accent-green); }
  .ticker-item .chg.down { color: var(--accent-red); }

  /* ══ VIEWS ══ */
  .view { display: none; flex: 1; overflow: hidden; }
  .view.active { display: flex; }

  /* ══ DASHBOARD VIEW ══ */
  #view-dashboard { flex-direction: row; }
  .main-grid {
    display: grid;
    grid-template-columns: 200px 1fr 280px;
    flex: 1; overflow: hidden;
  }

  /* LEFT */
  .markets-panel {
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .panel-header {
    padding: 10px 14px; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--text-secondary); border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .search-box { padding: 8px 12px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .search-box input {
    width: 100%; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 5px; padding: 5px 10px; color: var(--text-primary);
    font-size: 12px; font-family: var(--font-body); outline: none; transition: border-color .2s;
  }
  .search-box input:focus { border-color: var(--accent-yellow); }
  .search-box input::placeholder { color: var(--text-dim); }
  .market-list { overflow-y: auto; flex: 1; }
  .market-list::-webkit-scrollbar { width: 3px; }
  .market-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .market-item {
    display: flex; align-items: center; padding: 9px 14px;
    cursor: pointer; border-left: 2px solid transparent; transition: background .15s;
  }
  .market-item:hover, .market-item.active { background: var(--bg-hover); }
  .market-item.active { border-left-color: var(--accent-yellow); }
  .market-sym  { font-family: var(--font-mono); font-weight: 700; font-size: 12px; }
  .market-base { color: var(--text-secondary); font-size: 10px; }
  .market-right { margin-left: auto; text-align: right; }
  .market-price { font-family: var(--font-mono); font-size: 12px; }
  .market-chg   { font-size: 11px; }
  .market-chg.up   { color: var(--accent-green); }
  .market-chg.down { color: var(--accent-red); }

  /* CENTER */
  .chart-panel {
    background: var(--bg-primary);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .price-strip {
    display: flex; align-items: center; gap: 20px;
    padding: 6px 14px; background: var(--bg-secondary);
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .pair-price-big { font-family: var(--font-mono); font-size: 20px; font-weight: 700; }
  .pair-price-big.up   { color: var(--accent-green); }
  .pair-price-big.down { color: var(--accent-red); }
  .pair-stat { display: flex; flex-direction: column; gap: 1px; }
  .pair-stat span:first-child { color: var(--text-secondary); font-size: 10px; }
  .pair-stat span:last-child  { font-size: 12px; font-weight: 500; }
  .chart-toolbar {
    display: flex; align-items: center; gap: 4px;
    padding: 8px 14px; background: var(--bg-secondary);
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .interval-btn {
    padding: 4px 10px; background: transparent; border: none;
    border-radius: 4px; color: var(--text-secondary); font-size: 12px;
    cursor: pointer; transition: all .15s; font-family: var(--font-body);
  }
  .interval-btn:hover, .interval-btn.active { background: var(--bg-card); color: var(--text-primary); }
  .interval-btn.active { color: var(--accent-yellow); }
  #tradingview-widget { flex: 1; }

  /* RIGHT */
  .right-panel {
    background: var(--bg-secondary);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .order-form { padding: 14px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .order-tabs { display: flex; margin-bottom: 14px; }
  .order-tab {
    flex: 1; padding: 8px; text-align: center; font-size: 13px; font-weight: 600;
    cursor: pointer; border: 1px solid var(--border); background: var(--bg-card);
    color: var(--text-secondary); transition: all .2s;
  }
  .order-tab:first-child { border-radius: 4px 0 0 4px; }
  .order-tab:last-child  { border-radius: 0 4px 4px 0; }
  .order-tab.buy.active  { background: var(--accent-green); border-color: var(--accent-green); color: #000; }
  .order-tab.sell.active { background: var(--accent-red);   border-color: var(--accent-red);   color: #fff; }
  .form-group { margin-bottom: 10px; }
  .form-group label { display: block; font-size: 11px; color: var(--text-secondary); margin-bottom: 4px; }
  .form-group select, .form-group input {
    width: 100%; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 5px; padding: 8px 10px; color: var(--text-primary);
    font-size: 13px; font-family: var(--font-body); outline: none; transition: border-color .2s;
  }
  .form-group select:focus, .form-group input:focus { border-color: var(--accent-yellow); }
  .qty-hint { font-size: 11px; color: var(--text-secondary); margin-top: 3px; }
  .qty-hint span { color: var(--accent-yellow); font-family: var(--font-mono); }
  .btn-trade {
    width: 100%; padding: 10px; border: none; border-radius: 5px;
    font-size: 13px; font-weight: 700; cursor: pointer;
    transition: opacity .2s, transform .1s; letter-spacing: .04em; font-family: var(--font-body);
  }
  .btn-trade:hover  { opacity: .88; }
  .btn-trade:active { transform: scale(.98); }
  .btn-trade.buy  { background: var(--accent-green); color: #000; }
  .btn-trade.sell { background: var(--accent-red);   color: #fff; }
  .risk-badge {
    display: flex; align-items: center; gap: 6px;
    padding: 7px 10px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: 5px;
    font-size: 11px; margin-top: 8px;
  }
  .risk-badge .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .risk-badge.low  .dot { background: var(--accent-green); }
  .risk-badge.med  .dot { background: var(--accent-yellow); }
  .risk-badge.high .dot { background: var(--accent-red); }
  .news-section { display: flex; flex-direction: column; overflow: hidden; flex: 1; }
  .news-list { overflow-y: auto; flex: 1; }
  .news-list::-webkit-scrollbar { width: 3px; }
  .news-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .news-item {
    padding: 10px 14px; border-bottom: 1px solid var(--border);
    cursor: pointer; transition: background .15s;
    text-decoration: none; display: block;
  }
  .news-item:hover { background: var(--bg-hover); }
  .news-item-title { font-size: 12px; color: var(--text-primary); line-height: 1.4; margin-bottom: 4px; }
  .news-item-meta  { font-size: 10px; color: var(--text-secondary); }

  /* ══ BOT VIEW ══ */
  #view-bot { flex-direction: column; background: var(--bg-primary); }
  .bot-container {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 40px; gap: 28px; overflow-y: auto;
  }
  .bot-hero { text-align: center; max-width: 560px; }
  .bot-icon-wrap {
    width: 72px; height: 72px;
    background: rgba(240,185,11,.1); border: 1px solid rgba(240,185,11,.25);
    border-radius: 20px; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
  }
  .bot-hero h2 { font-family: var(--font-mono); font-size: 22px; font-weight: 700; margin-bottom: 10px; }
  .bot-hero p  { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
  .bot-status-row {
    display: flex; align-items: center; gap: 32px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 24px;
    width: 100%; max-width: 700px;
  }
  .bot-stat { text-align: center; }
  .bot-stat .val { font-family: var(--font-mono); font-size: 18px; font-weight: 700; color: var(--accent-yellow); }
  .bot-stat .lbl { font-size: 11px; color: var(--text-secondary); margin-top: 3px; }
  .bot-toggle {
    margin-left: auto; display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 600; color: var(--text-primary);
  }
  .toggle-switch {
    width: 42px; height: 22px; background: var(--border);
    border-radius: 11px; position: relative; cursor: pointer; transition: background .2s;
  }
  .toggle-switch.on { background: var(--accent-green); }
  .toggle-switch::after {
    content: ''; position: absolute; top: 3px; left: 3px;
    width: 16px; height: 16px; background: #fff; border-radius: 50%; transition: transform .2s;
  }
  .toggle-switch.on::after { transform: translateX(20px); }
  .bot-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; width: 100%; max-width: 700px; }
  .bot-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px 18px; cursor: pointer;
    transition: border-color .2s, transform .15s; text-align: center;
  }
  .bot-card:hover { border-color: var(--accent-yellow); transform: translateY(-2px); }
  .bot-card-icon { font-size: 26px; margin-bottom: 10px; }
  .bot-card h3 { font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .bot-card p  { font-size: 11px; color: var(--text-secondary); line-height: 1.5; }

  /* ══ CHATBOT VIEW ══ */
  #view-chatbot { flex-direction: column; background: var(--bg-primary); }
  .chat-full-wrap {
    flex: 1; display: flex; flex-direction: column;
    max-width: 780px; width: 100%; margin: 0 auto;
    padding: 20px 24px 0; overflow: hidden;
  }
  .chat-full-header {
    display: flex; align-items: center; gap: 12px;
    padding-bottom: 16px; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .chat-full-header .avatar {
    width: 38px; height: 38px;
    background: rgba(240,185,11,.12); border: 1px solid rgba(240,185,11,.3);
    border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px;
  }
  .chat-full-header h3 { font-size: 15px; font-weight: 600; }
  .chat-full-header p  { font-size: 11px; color: var(--accent-green); }
  .online-dot {
    width: 7px; height: 7px; background: var(--accent-green);
    border-radius: 50%; display: inline-block; margin-right: 5px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{ opacity:1 } 50%{ opacity:.4 } }
  .chat-full-messages {
    flex: 1; overflow-y: auto; padding: 20px 0;
    display: flex; flex-direction: column; gap: 12px;
  }
  .chat-full-messages::-webkit-scrollbar { width: 3px; }
  .chat-full-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  .chat-bubble { display: flex; gap: 10px; align-items: flex-end; max-width: 80%; }
  .chat-bubble.user { align-self: flex-end; flex-direction: row-reverse; }
  .chat-bubble .bubble-avatar {
    width: 28px; height: 28px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
  }
  .chat-bubble.bot  .bubble-avatar { background: rgba(240,185,11,.12); border: 1px solid rgba(240,185,11,.2); }
  .chat-bubble.user .bubble-avatar { background: rgba(14,203,129,.12);  border: 1px solid rgba(14,203,129,.2); }
  .bubble-text { padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.5; }
  .chat-bubble.bot  .bubble-text { background: var(--bg-card); color: var(--text-primary); border-radius: 12px 12px 12px 4px; }
  .chat-bubble.user .bubble-text { background: var(--accent-yellow); color: #000; border-radius: 12px 12px 4px 12px; }
  .chat-full-input-area { padding: 16px 0 20px; border-top: 1px solid var(--border); flex-shrink: 0; }
  .chat-full-input-row {
    display: flex; gap: 10px; align-items: center;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 8px 8px 8px 14px; transition: border-color .2s;
  }
  .chat-full-input-row:focus-within { border-color: var(--accent-yellow); }
  .chat-full-input-row input {
    flex: 1; background: transparent; border: none; outline: none;
    color: var(--text-primary); font-size: 13px; font-family: var(--font-body);
  }
  .chat-full-input-row input::placeholder { color: var(--text-dim); }
  .chat-send-btn {
    width: 36px; height: 36px; background: var(--accent-yellow);
    border: none; border-radius: 8px; color: #000; font-size: 16px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: opacity .2s; flex-shrink: 0;
  }
  .chat-send-btn:hover { opacity: .85; }

  /* ══ TOAST ══ */
  .toast-container { position: fixed; top: 68px; right: 20px; z-index: 999; display: flex; flex-direction: column; gap: 8px; }
  .toast {
    padding: 10px 16px; border-radius: 6px; font-size: 13px; font-weight: 500;
    animation: toast-in .3s ease; min-width: 220px; box-shadow: 0 4px 20px rgba(0,0,0,.4);
  }
  .toast.success { background: var(--accent-green); color: #000; }
  .toast.error   { background: var(--accent-red);   color: #fff; }
  @keyframes toast-in { from { opacity:0; transform:translateX(40px); } to { opacity:1; transform:translateX(0); } }

  .skeleton {
    background: linear-gradient(90deg, var(--bg-card) 25%, var(--bg-hover) 50%, var(--bg-card) 75%);
    background-size: 200% 100%; animation: shimmer 1.4s infinite; border-radius: 3px;
  }
  @keyframes shimmer { 0%{ background-position:200% 0 } 100%{ background-position:-200% 0 } }
</style>
{% endblock %}

{% block body %}
<div class="toast-container" id="toastContainer"></div>

<!-- ══ TOPBAR ══ -->
<header class="topbar">
  <a href="#" class="topbar-logo">
    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M16 3L4 9.5V22.5L16 29L28 22.5V9.5L16 3Z" fill="#f0b90b" opacity=".15"/>
      <path d="M16 3L28 9.5V22.5L16 29L4 22.5V9.5L16 3Z" stroke="#f0b90b" stroke-width="1.5"/>
      <path d="M16 10L12 13.5V18.5L16 22L20 18.5V13.5L16 10Z" fill="#f0b90b"/>
    </svg>
    CryptoTrade
  </a>

  <div class="topbar-sep"></div>

  <nav class="topbar-nav">
    <button class="nav-link active" id="nav-dashboard" onclick="switchView('dashboard', this)">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </button>
    <button class="nav-link" id="nav-bot" onclick="switchView('bot', this)">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="3"/><path d="M12 11v2"/><path d="M9 21H6a2 2 0 0 1-2-2v-2a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v2a2 2 0 0 1-2 2h-3"/><path d="M9 17h6"/></svg>
      Bot
    </button>
    <button class="nav-link" id="nav-chatbot" onclick="switchView('chatbot', this)">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Chatbot
    </button>
    <button class="nav-link" id="nav-history" onclick="switchView('history', this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      History
    </button>

  </nav>

  <div class="topbar-right">
    <div class="balance-badge">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      <span style="color:var(--text-secondary);">Balance</span>
      <span class="val">${{ solde|number_format(2) }}</span>
    </div>

    <div class="topbar-sep"></div>
    <button class="icon-btn" title="Search">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
    <button class="icon-btn" title="Notifications">
      <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
    <button class="icon-btn" title="Settings">
