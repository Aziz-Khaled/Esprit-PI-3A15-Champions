function fetchRecommend(sym) {
    fetch('/trading/api/recommend/' + sym)
        .then(r => r.json()).then(d => {
            if (d.error) return;
            document.getElementById('maxQty').textContent = fmtQty(d.maxBuyQty);
            document.getElementById('riskPill').className = 'risk-pill ' + ({LOW:'low',MEDIUM:'med',HIGH:'high'}[d.riskLevel]||'low');
            document.getElementById('riskTxt').textContent = d.advice;
            document.getElementById('riskLabel').textContent = d.riskLevel;
            document.getElementById('maxBuyQty').textContent = fmtQty(d.maxBuyQty);
            document.getElementById('maxSellQty').textContent = fmtQty(d.maxSellQty);
            document.getElementById('recAdvice').textContent = d.advice;
            if (d.riskLevel === 'CRITICAL') document.getElementById('tradeGuardBlock').classList.add('visible');
            else document.getElementById('tradeGuardBlock').classList.remove('visible');
        }).catch(()=>{});
