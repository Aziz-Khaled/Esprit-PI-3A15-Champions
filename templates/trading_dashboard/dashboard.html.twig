// ============================================
// HISTORY
// ============================================
let allTrades = [], histFilter = 'ALL';

function loadHistory() {
    const body = document.getElementById('histTableBody');
    if (!body) return;
    body.innerHTML = '<div class="hist-empty"><div class="spin" style="width:24px;height:24px;"></div><div>Loading...</div></div>';
   
    fetch('/trading/api/trades/history')
        .then(r => r.json())
        .then(data => {
            allTrades = Array.isArray(data) ? data : [];
            updateHistSummary();
            renderHistory();
        })
        .catch(() => { body.innerHTML = '<div class="hist-empty"><div>Failed to load history.</div></div>'; });
}

function updateHistSummary() {
    document.getElementById('hsTotalTrades').textContent = allTrades.length;
    document.getElementById('hsTotalBuy').textContent = allTrades.filter(t => t.trade_type === 'BUY').length;
    document.getElementById('hsTotalSell').textContent = allTrades.filter(t => t.trade_type === 'SELL').length;
    document.getElementById('hsCompleted').textContent = allTrades.filter(t => t.status === 'COMPLETED').length;
    document.getElementById('hsPending').textContent = allTrades.filter(t => t.status === 'PENDING').length;
}

function filterHistory(f, btn) {
    histFilter = f;
    document.querySelectorAll('.hf-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderHistory();
}

function renderHistory() {
    const q = (document.getElementById('histSearch')?.value || '').toLowerCase();
    const body = document.getElementById('histTableBody');
    if (!body) return;
   
    let rows = allTrades.filter(t =>
        (histFilter === 'ALL' ? true :
         histFilter === 'BUY' ? t.trade_type === 'BUY' :
         histFilter === 'SELL' ? t.trade_type === 'SELL' :
         histFilter === 'COMPLETED' ? t.status === 'COMPLETED' :
         histFilter === 'PENDING' ? t.status === 'PENDING' : true) &&
        (!q || (t.symbol||'').toLowerCase().includes(q))
    );
   
    if (!rows.length) {
        body.innerHTML = '<div class="hist-empty"><div>No trades found.</div></div>';
        return;
    }
   
    body.innerHTML = rows.map(t => `<div class="hist-row">
        <span>#${t.id}</span>
        <span class="hr-sym">${t.symbol}</span>
        <span class="hr-type ${(t.trade_type||'').toLowerCase()}">${t.trade_type}</span>
        <span>${fmt(parseFloat(t.price) || 0)}</span>
        <span>${(parseFloat(t.quantity) || 0).toLocaleString()}</span>
        <span>${fmt((parseFloat(t.price) || 0) * (parseFloat(t.quantity) || 0))}</span>
        <span><span class="hr-mode ${(t.order_mode||'market').toLowerCase()}">${(t.order_mode||'MARKET').toUpperCase()}</span></span>
        <span><span class="hr-status ${(t.status||'').toLowerCase()}">${t.status}</span></span>
        <span>${t.date || '-'}</span>
    </div>`).join('');
}

// ============================================
// NEWS
// ============================================
function fetchNews() {
    const box = document.getElementById('newsList');
    if (!box) return;
    box.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:11px;">Loading news...</div>';
   
    fetch('/trading/api/news')
        .then(r => r.json())
        .then(arts => {
            if (!Array.isArray(arts) || arts.length === 0) {
                box.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:11px;">No news available.</div>';
                return;
            }
            const valid = arts.filter(a => a.title && a.title !== '[Removed]').slice(0, 6);
            box.innerHTML = valid.map(a => {
                const date = a.publishedAt ? new Date(a.publishedAt).toLocaleDateString('en-US', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '';
                return `<a class="news-card" href="${a.url || '#'}" target="_blank" rel="noopener"><div class="news-card-t">${escapeHtml(a.title)}</div><div class="news-card-m">${escapeHtml(a.source || '')} · ${date}</div></a>`;
            }).join('');
        })
        .catch(err => { box.innerHTML = `<div style="padding:12px 14px;color:var(--muted);font-size:11px;">Error loading news.<br><small>${err.message}</small></div>`; });
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ============================================
// CHAT
// ============================================
function quickAsk(msg) { document.getElementById('chatInp').value = msg; sendMsg(); }

function sendMsg() {
    const inp = document.getElementById('chatInp');
    const msg = inp?.value.trim();
    if (!msg) return;
    addBubble(msg, 'usr');
    inp.value = '';
    const tp = addBubble('', 'bot', true);
    fetch('/trading/api/chatbot', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({message: msg}),
    }).then(r => r.json()).then(d => { tp.remove(); addBubble(d.reply || 'No response.', 'bot'); })
      .catch(() => { tp.remove(); addBubble('Connection error.', 'bot'); });
}

function addBubble(text, role, typing=false) {
    const box = document.getElementById('msgs');
    if (!box) return null;
    const w = document.createElement('div');
    w.className = 'bubble ' + role;
    w.innerHTML = `<div class="av ${role}">${role==='bot'?'🤖':'👤'}</div><div class="bc">${text}</div>`;
    box.appendChild(w);
    box.scrollTop = box.scrollHeight;
    return w;
}

// ============================================
// BOT - MONITORING ONLY (EXECUTES WHEN CONDITION MET)
// ============================================

function toggleBot() {
    botOn = !botOn;
    const btn = document.getElementById('botBtn');
    const dot = document.getElementById('lDot');
    const sStat = document.getElementById('sStat');
   
    if (sStat) {
        sStat.textContent = botOn ? '🟢 Monitoring Active' : '⏹ Stopped';
        sStat.style.color = botOn ? 'var(--green)' : 'var(--muted)';
    }
    if (btn) {
        btn.textContent = botOn ? '⏹ Stop Monitoring' : '▶ Start Monitoring';
        btn.classList.toggle('stop', botOn);
    }
    if (dot) dot.classList.toggle('live', botOn);
   
    if (botOn) {
        logLine('it', '🔍 Monitoring started - Checking LIMIT orders every 15 seconds');
        loadBotPendingOrders();
        if (botTimer) clearInterval(botTimer);
        botTimer = setInterval(botTick, 15000);
        botTick();
    } else {
        if (botTimer) clearInterval(botTimer);
        logLine('it', '⏹ Monitoring stopped');
    }
}

function loadBotPendingOrders() {
    fetch('/trading/api/bot/pending-orders')
        .then(r => r.json())
        .then(orders => {
            botPendingOrders = orders;
            const pendingCount = document.getElementById('sPendingOrders');
            if (pendingCount) pendingCount.textContent = orders.length;
            if (orders.length > 0) {
                logLine('it', `${orders.length} LIMIT order(s) pending - monitoring active`);
                displayBotPendingOrders();
            } else {
                const section = document.getElementById('limitOrdersSection');
                if (section) section.style.display = 'none';
            }
        })
        .catch(err => console.error('Error loading pending orders:', err));
}

function displayBotPendingOrders() {
    const section = document.getElementById('limitOrdersSection');
    const list = document.getElementById('limitPendingList');
    if (!section || !list) return;
   
    if (!botPendingOrders.length) {
        section.style.display = 'none';
        return;
    }
   
    section.style.display = 'flex';
    list.innerHTML = botPendingOrders.map(o => `
        <div class="limit-order-item" id="bot-order-${o.id}">
            <span class="li-sym">${o.symbol}/USDT</span>
            <span>${o.trade_type} ${o.quantity} @ ${fmt(o.target_price)}</span>
            <span style="font-size:9px;color:var(--muted)">📌 monitored</span>
        </div>
    `).join('');
}

function checkBotPendingOrders(asset, currentPrice) {
    const pendingForAsset = botPendingOrders.filter(o => o.symbol === asset);
   
    for (const order of pendingForAsset) {
        let shouldExecute = false;
       
        if (order.trade_type === 'BUY' && currentPrice <= order.target_price) {
            shouldExecute = true;
            logLine('wt', `🎯 Condition met for ${order.symbol} BUY: market ${fmt(currentPrice)} ≤ target ${fmt(order.target_price)}`);
        } else if (order.trade_type === 'SELL' && currentPrice >= order.target_price) {
            shouldExecute = true;
            logLine('wt', `🎯 Condition met for ${order.symbol} SELL: market ${fmt(currentPrice)} ≥ target ${fmt(order.target_price)}`);
        }
       
        if (shouldExecute) {
            logLine('bt', `🚀 Executing LIMIT order #${order.id} - ${order.trade_type} ${order.quantity} ${order.symbol} @ ${fmt(currentPrice)}`);
           
            fetch('/trading/api/bot/check-execute', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: order.id, currentPrice: currentPrice })
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    logLine('bt', `✅ ORDER EXECUTED: ${order.trade_type} ${order.quantity} ${order.symbol} @ ${fmt(currentPrice)}`);
                    toast(`🎯 LIMIT ${order.trade_type} executed!`, 'ok');
                    refreshWalletBalance();
                    botPendingOrders = botPendingOrders.filter(o => o.id !== order.id);
                    displayBotPendingOrders();
                    loadHistory();
                   
                    const pendingCount = document.getElementById('sPendingOrders');
                    if (pendingCount) pendingCount.textContent = botPendingOrders.length;
                    const executedCount = document.getElementById('sExecutedOrders');
                    if (executedCount) {
                        let current = parseInt(executedCount.textContent) || 0;
                        executedCount.textContent = current + 1;
                    }
                } else if (d.error) {
                    logLine('wt', `❌ Execution error: ${d.error}`);
                }
            })
            .catch(err => logLine('wt', `❌ API error: ${err.message}`));
        }
    }
}

function botTick() {
    if (!botOn) return;
   
    const assetEl = document.getElementById('botAsset');
    if (!assetEl) return;
    const asset = assetEl.value;
    const liveData = priceMap[asset];
   
    if (!liveData) {
        logLine('it', `Waiting for price data for ${asset}/USDT...`);
        return;
    }
   
    const price = liveData.price;
    logLine('it', `🔍 Checking: ${asset}/USDT = ${fmt(price)} - ${botPendingOrders.length} order(s) pending`);
   
    // ONLY check and execute existing orders
    checkBotPendingOrders(asset, price);
}

function updateBotStats() {
    fetch('/trading/api/bot/stats/real')
        .then(r => r.json())
        .then(stats => {
            const pendingSpan = document.getElementById('sPendingOrders');
            const executedSpan = document.getElementById('sExecutedOrders');
            if (pendingSpan && stats.pendingOrders !== undefined) pendingSpan.textContent = stats.pendingOrders;
            if (executedSpan && stats.tradesToday !== undefined) executedSpan.textContent = stats.tradesToday;
        })
        .catch(() => {});
}

function logLine(cls, msg) {
    const box = document.getElementById('logList');
    if (!box) return;
   
    const now = new Date().toLocaleTimeString('en-US', { hour12: false });
    const map = { bt: 'bt', st: 'st', it: 'it', wt: 'wt' };
    const lbl = { bt: '[EXEC]', st: '[SELL]', it: '[INFO]', wt: '[WARN]' };
   
    const d = document.createElement('div');
    d.className = 'll';
    d.innerHTML = `<span class="ts">${now}</span><span class="${map[cls] || 'it'}">${lbl[cls] || '[INFO]'}</span> ${escapeHtml(msg)}`;
    box.appendChild(d);
    box.scrollTop = box.scrollHeight;
   
    if (box.querySelectorAll('.ll').length > 200) box.querySelector('.ll').remove();
}

function toast(msg, type) {
    const box = document.getElementById('toastBox');
    if (!box) return;
    const t = document.createElement('div');
    t.className = 'toast ' + type;
    t.textContent = msg;
    box.appendChild(t);
    setTimeout(() => t.remove(), 3000);
}

function toggleSecBundle() {
    const body = document.getElementById('secBody');
    const icon = document.getElementById('secToggleIcon');
    if (!body || !icon) return;
    if (body.style.display === 'none' || !body.style.display) {
        body.style.display = 'flex';
        icon.classList.add('open');
    } else {
        body.style.display = 'none';
        icon.classList.remove('open');
    }
}

// ============================================
// INITIALIZATION
// ============================================
if (curSym) {
    const chartLbl = document.getElementById('chartLbl');
    const navSym = document.getElementById('navSym');
    const tradeBtn = document.getElementById('tradeBtn');
    if (chartLbl) chartLbl.textContent = curSym + ' / USDT';
    if (navSym) navSym.textContent = curSym + '/USDT';
    if (tradeBtn) tradeBtn.textContent = 'BUY ' + curSym;
    initChart(curSym, curIv);
    fetchRecommend(curSym);
}

initWalletSelector();
fetchBinanceSnapshot();
fetchNews();
loadHistory();

setInterval(fetchNews, 5 * 60 * 1000);
setInterval(() => { if (!ws || ws.readyState !== WebSocket.OPEN) fetchBinanceSnapshot(); }, 60000);
setInterval(refreshWalletBalance, 30000);
setInterval(() => { if (botOn) updateBotStats(); }, 30000);
</script>
{% endblock %}