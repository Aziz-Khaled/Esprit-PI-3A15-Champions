        <div class="pair-stat"><span>Volume</span><span id="hVol">--</span></div>
      </div>
      <div class="chart-toolbar">
        <span style="font-size:12px;color:var(--text-secondary);margin-right:8px;" id="chartPairLabel">BTC / USDT</span>
