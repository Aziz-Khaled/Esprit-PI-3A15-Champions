// ORDER EXECUTION
// ════════════════════════════════════════════════
function pickTab(tab, btn) {
  curTab = tab;
  document.querySelectorAll('.ord-tab').forEach(t => t.classList.remove('on'));
  btn.classList.add('on');
  const b = document.getElementById('tradeBtn');
  const mode = document.getElementById('ordMode');
  if (b && mode) {
    b.textContent = mode.value === 'limit' ? 'Place LIMIT ' + tab + ' Order' : tab + ' ' + curSym;
    b.className = 'trade-btn ' + tab.toLowerCase();
  }
}
function updateTotal() {
  const qty = parseFloat(document.getElementById('qtyInp')?.value) || 0;
  const totalVal = document.getElementById('totalVal');
  if (totalVal) totalVal.textContent = '$' + (qty * curPx).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}
document.getElementById('qtyInp')?.addEventListener('input', updateTotal);
function execTrade() {
  const qty = parseFloat(document.getElementById('qtyInp')?.value);
  if (!qty || qty <= 0) { toast('Entrez une quantité valide.', 'err'); return; }
 
  const mode = document.getElementById('ordMode')?.value.toUpperCase();
 
  // ── LIMIT ORDER ──
  if (mode === 'LIMIT') {
    const targetPrice = parseFloat(document.getElementById('limitPriceInp')?.value);
    if (!targetPrice || targetPrice <= 0) { toast('Entrez un prix cible valide.', 'err'); return; }
    const direction = curTab === 'BUY' ? 'AT_OR_BELOW' : 'AT_OR_ABOVE';
    limitOrders.push({ id: limitOrderCounter++, sym: curSym, type: curTab, qty, targetPrice, direction });
    renderLimitOrders();
    fetch('{{ path('app_trading_api_execute_trade') }}', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ symbol: curSym, tradeType: curTab, quantity: qty, orderMode: 'LIMIT', targetPrice, currentPrice: curPx }),
    }).then(r => r.json()).then(d => {
      // ✅ FIX: mettre à jour le wallet même pour les LIMIT (solde non débité mais on affiche la réponse)
      if (d.newBalance !== undefined && !isNaN(parseFloat(d.newBalance))) {
        updateBalanceDisplay(d.newBalance);
      }
    }).catch(()=>{});
    toast(`📌 LIMIT ${curTab} enregistré — ${qty} ${curSym} @ $${targetPrice}`, 'ok');
    document.getElementById('qtyInp').value = '';
    document.getElementById('limitPriceInp').value = '';
    return;
  }
 
  // ── MARKET ORDER ──
  const btn = document.getElementById('tradeBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spin"></span> En cours…'; }
 
  fetch('{{ path('app_trading_api_execute_trade') }}', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ symbol: curSym, tradeType: curTab, quantity: qty, orderMode: 'MARKET', currentPrice: curPx }),
  })
  .then(r => r.json())
  .then(d => {
    if (btn) { btn.disabled = false; btn.textContent = curTab + ' ' + curSym; }
    if (d.error) { toast(d.error, 'err'); return; }
 
    // ✅ FIX PRINCIPAL : mise à jour du wallet avec vérification NaN
    const newBal = d.newBalance ?? d.balance;
    if (newBal !== undefined && !isNaN(parseFloat(newBal))) {
      updateBalanceDisplay(newBal);
      // Log dans le bot activity log aussi
      logLine('it', `💰 Wallet mis à jour: ${formatBalance(newBal)} (${curTab} ${qty} ${curSym} @ ${fmt(d.price)})`);
    }
 
    toast(`✅ ${d.tradeType} ${d.quantity} ${d.symbol} @ ${fmt(d.price)} — Solde: ${formatBalance(newBal)}`, 'ok');
    document.getElementById('qtyInp').value = '';
    updateTotal();
    // Recharger l'historique automatiquement
    if (document.getElementById('pg-hist')?.classList.contains('on')) loadHistory();
  })
  .catch(() => {
    if (btn) { btn.disabled = false; btn.textContent = curTab + ' ' + curSym; }
    toast('Trade échoué. Vérifiez votre connexion.', 'err');
  });
}
 
// ✅ NOUVELLE FONCTION CENTRALISÉE pour mettre à jour le balance partout
function updateBalanceDisplay(amount) {
  const parsed = parseFloat(amount);
  if (isNaN(parsed)) return;
  const formatted = '$' + parsed.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  // Met à jour TOUS les éléments affichant le solde
  document.getElementById('balVal').textContent = formatted;
  // Stocke en mémoire pour référence
  window._currentBalance = parsed;
}
 
// ✅ HELPER format balance
function formatBalance(amount) {
  const parsed = parseFloat(amount);
  if (isNaN(parsed)) return '$—';
  return '$' + parsed.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

