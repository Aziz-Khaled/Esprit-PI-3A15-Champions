<script src="https://s3.tradingview.com/tv.js"></script>
<script>
    // --- INITIALISATION DES VARIABLES ---
    const dbAssets = {{ assets|map(a => a.symbol|upper)|json_encode|raw }};
    let currentSymbol = dbAssets.length ? dbAssets[0] : 'BTC';
    let currentInterval = '5'; // Pour TradingView
    let currentTab = 'BUY'; // BUY ou SELL
    let tvWidget = null;

    // --- 1. GESTION DES VUES (NAVIGATION) ---
    function switchView(viewId, btn) {
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
        
        document.getElementById('view-' + viewId).classList.add('active');
        btn.classList.add('active');

        if (viewId === 'dashboard') initTradingView();
        if (viewId === 'history') refreshHistory();
    }

    // --- 2. PRIX EN TEMPS RÉEL (BINANCE) ---
    async function updatePrices() {
        try {
            const response = await fetch('/trading/api/prices');
            const data = await response.json();

            data.forEach(coin => {
                const sym = coin.symbol.replace('USDT', '');
                
                // Update Market List
                const priceEl = document.getElementById(`mp-${sym}`);
                const chgEl = document.getElementById(`mc-${sym}`);
                if (priceEl) priceEl.innerText = coin.price.toLocaleString() + " $";
                if (chgEl) {
                    chgEl.innerText = (coin.change > 0 ? '+' : '') + coin.change.toFixed(2) + "%";
                    chgEl.className = `market-chg ${coin.change >= 0 ? 'up' : 'down'}`;
                }

                // Update Header if it's the current asset
                if (sym === currentSymbol) {
                    document.getElementById('headerPrice').innerText = coin.price.toLocaleString() + " $";
                    document.getElementById('headerPrice').className = `pair-price-big ${coin.change >= 0 ? 'up' : 'down'}`;
                    document.getElementById('hChange').innerText = coin.change.toFixed(2) + "%";
                    document.getElementById('hHigh').innerText = coin.high.toLocaleString();
                    document.getElementById('hLow').innerText = coin.low.toLocaleString();
                    document.getElementById('hVol').innerText = coin.volume.toFixed(0);
                    
                    // Calcul du coût total dans le formulaire
                    updateTotalCost(coin.price);
                }
            });
        } catch (e) { console.error("Price update error", e); }
    }

    // --- 3. EXECUTION DES TRADES (ACHAT / VENTE) ---
    async function executeTrade() {
        const qty = document.getElementById('qtyInput').value;
        const mode = document.getElementById('orderMode').value.toUpperCase();
        const targetPrice = document.getElementById('targetPrice').value;

        if (!qty || qty <= 0) return showToast("Veuillez saisir une quantité", "error");

        const btn = document.getElementById('tradeBtn');
        btn.disabled = true;
        btn.innerText = "Processing...";

        try {
            const response = await fetch('/trading/api/execute-trade', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    symbol: currentSymbol,
                    quantity: qty,
                    tradeType: currentTab,
                    orderMode: mode,
                    targetPrice: targetPrice
                })
            });

            const res = await response.json();
            if (res.success) {
                showToast(res.message || "Transaction réussie !", "success");
                if (res.newBalance) {
                    document.querySelector('.balance-badge .val').innerText = `$${parseFloat(res.newBalance).toLocaleString()}`;
                }
                document.getElementById('qtyInput').value = '';
            } else {
                showToast(res.error, "error");
            }
        } catch (e) {
            showToast("Erreur de connexion serveur", "error");
        } finally {
            btn.disabled = false;
            btn.innerText = `${currentTab} ${currentSymbol}`;
        }
    }

    // --- 4. CHATBOT (IA) ---
    async function sendChatFull() {
        const input = document.getElementById('chatFullInput');
        const msg = input.value.trim();
        if (!msg) return;

        appendMessage('user', msg);
        input.value = '';

        try {
            const response = await fetch('/trading/api/chatbot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg })
            });
            const data = await response.json();
            appendMessage('bot', data.reply || data.error);
        } catch (e) {
            appendMessage('bot', "Désolé, le service IA est indisponible.");
        }
    }

    function appendMessage(role, text) {
        const container = document.getElementById('chatFullMessages');
        const div = document.createElement('div');
        div.className = `chat-bubble ${role}`;
        div.innerHTML = `
            <div class="bubble-avatar">${role === 'bot' ? '🤖' : '👤'}</div>
            <div class="bubble-text">${text}</div>
        `;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
    }

    // --- 5. UTILITAIRES & WIDGETS ---
    function initTradingView() {
        tvWidget = new TradingView.widget({
            "autosize": true,
            "symbol": `BINANCE:${currentSymbol}USDT`,
            "interval": currentInterval,
            "timezone": "Etc/UTC",
            "theme": "dark",
            "style": "1",
            "locale": "fr",
            "container_id": "tradingview-widget",
            "hide_side_toolbar": false,
            "allow_symbol_change": false,
            "save_image": false,
        });
    }

    function selectMarket(symbol, el) {
        currentSymbol = symbol;
        document.querySelectorAll('.market-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('chartPairLabel').innerText = `${symbol} / USDT`;
        document.getElementById('tradeBtn').innerText = `${currentTab} ${symbol}`;
        initTradingView();
        getRecommendation(symbol);
    }

    async function getRecommendation(symbol) {
        try {
            const res = await fetch(`/trading/api/recommend/${symbol}`);
            const data = await res.json();
            document.getElementById('maxQty').innerText = data.maxQuantity;
            document.getElementById('riskText').innerText = `Risk: ${data.riskLevel} - ${data.advice}`;
            document.getElementById('riskBadge').className = `risk-badge ${data.riskLevel.toLowerCase()}`;
        } catch (e) {}
    }

    function switchTab(type, el) {
        currentTab = type;
        document.querySelectorAll('.order-tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        const btn = document.getElementById('tradeBtn');
        btn.className = `btn-trade ${type.toLowerCase()}`;
        btn.innerText = `${type} ${currentSymbol}`;
    }

    function toggleLimitPrice() {
        const mode = document.getElementById('orderMode').value;
        document.getElementById('limitPriceGroup').style.display = (mode === 'limit') ? 'block' : 'none';
    }

    function showToast(msg, type) {
        const container = document.getElementById('toastContainer');
        const t = document.createElement('div');
        t.className = `toast ${type}`;
        t.innerText = msg;
        container.appendChild(t);
        setTimeout(() => t.remove(), 4000);
    }

    function updateTotalCost(price) {
        const qty = document.getElementById('qtyInput').value || 0;
        document.getElementById('totalCost').innerText = `$${(qty * price).toFixed(2)}`;
    }

    // --- LANCEMENT ---
    window.onload = () => {
        initTradingView();
        setInterval(updatePrices, 3000); // Mise à jour toutes les 3s
        updatePrices();
        if(dbAssets.length) getRecommendation(dbAssets[0]);
        
        // Charger les news au démarrage
        fetch('/trading/api/news').then(r => r.json()).then(news => {
            const list = document.getElementById('newsList');
            list.innerHTML = news.map(n => `
                <a href="${n.url}" target="_blank" class="news-item">
                    <div class="news-item-title">${n.title}</div>
                    <div class="news-item-meta">${n.source} • ${new Date(n.publishedAt).toLocaleDateString()}</div>
                </a>
            `).join('');
        });
    };
</script>
{% endblock %}

