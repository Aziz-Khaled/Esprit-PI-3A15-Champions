// BINANCE WEBSOCKET & PRICES
// ════════════════════════════════════════════════
let ws = null, wsReconnectTimer = null;
function fetchBinanceSnapshot() {
  if (!dbAssets || !dbAssets.length) return;
  const syms = dbAssets.map(s => '"' + s + 'USDT"').join(',');
  fetch(`https://api.binance.com/api/v3/ticker/24hr?symbols=[${syms}]`).then(r => r.json()).then(data => {
    if (!Array.isArray(data)) return;
    data.forEach(item => {
      const sym = item.symbol.replace('USDT','');
      const d = { price: parseFloat(item.lastPrice), change: parseFloat(item.priceChangePercent), high: parseFloat(item.highPrice), low: parseFloat(item.lowPrice) };
      priceMap[sym] = d;
      updateMarketRow(sym, d);
      if (sym === curSym) { curPx = d.price; updateNavbar(d); updateTotal(); updateLimitPriceBadge(); }
    });
    updateTickerAll();
    startWebSocket();
  }).catch(() => fetchServerPrices());
}
function startWebSocket() {
  if (ws) ws.close();
  clearTimeout(wsReconnectTimer);
  if (!dbAssets || !dbAssets.length) return;
  const streams = dbAssets.map(s => s.toLowerCase() + 'usdt@ticker').join('/');
  ws = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${streams}`);
  ws.onopen = () => logLine('it', 'WebSocket connected');
  ws.onmessage = (event) => {
    try {
      const tick = JSON.parse(event.data).data;
      if (!tick || !tick.s) return;
      const sym = tick.s.replace('USDT','');
      const d = { price: parseFloat(tick.c), change: parseFloat(tick.P), high: parseFloat(tick.h), low: parseFloat(tick.l) };
      priceMap[sym] = d;
      updateMarketRow(sym, d);
      updateTickerItem(sym, d);
      if (sym === curSym) { curPx = d.price; updateNavbar(d); updateTotal(); updateLimitPriceBadge(); }
      checkLimitOrders(sym, d.price);
    } catch(e) {}
  };
  ws.onclose = () => { wsReconnectTimer = setTimeout(startWebSocket, 5000); };
}
function reconnectWS() { clearTimeout(wsReconnectTimer); startWebSocket(); }
function fetchServerPrices() {
  fetch('{{ path('app_trading_api_prices') }}').then(r => r.json()).then(data => {
    if (!Array.isArray(data)) return;
    data.forEach(item => {
      const sym = item.symbol.replace('USDT','');
      const d = { price:item.price, change:item.change, high:item.high, low:item.low };
      priceMap[sym] = d;
      updateMarketRow(sym, d);
      if (sym === curSym) { curPx = d.price; updateNavbar(d); updateTotal(); updateLimitPriceBadge(); }
      checkLimitOrders(sym, d.price);
    });
    updateTickerAll();
  }).catch(()=>{});
}
function updateMarketRow(sym, d) {
  const pr = document.getElementById('mp-'+sym);
  const ch = document.getElementById('mc-'+sym);
  if (pr) pr.textContent = fmt(d.price);
  if (ch) { ch.textContent = (d.change>=0?'+':'')+d.change.toFixed(2)+'%'; ch.className='mkt-ch '+(d.change>=0?'up':'dn'); }
}
function updateNavbar(d) {
  const navPrice = document.getElementById('navPrice');
  const navChg = document.getElementById('navChg');
  const navHi = document.getElementById('navHi');
  const navLo = document.getElementById('navLo');
  if (navPrice) { navPrice.textContent = fmt(d.price); navPrice.className = 'nav-price' + (d.change>=0?'':' dn'); }
  if (navChg) { navChg.textContent = (d.change>=0?'+':'')+d.change.toFixed(2)+'%'; navChg.style.color = d.change>=0?'var(--green)':'var(--red)'; }
  if (navHi) navHi.textContent = fmt(d.high);
  if (navLo) navLo.textContent = fmt(d.low);
}
function updateTickerItem(sym, d) {
  const ticks = document.querySelectorAll('.tick');
  const i = dbAssets.indexOf(sym);
  if (i < 0) return;
  [ticks[i], ticks[i + dbAssets.length]].forEach(el => {
    if (!el) return;
    const p = el.querySelector('.tick-p'), c = el.querySelector('.tick-c');
    if (p) p.textContent = fmt(d.price);
    if (c) { c.textContent=(d.change>=0?'+':'')+d.change.toFixed(2)+'%'; c.className='tick-c '+(d.change>=0?'up':'dn'); }
  });
}
function updateTickerAll() { dbAssets.forEach(sym => { if (priceMap[sym]) updateTickerItem(sym, priceMap[sym]); }); }

