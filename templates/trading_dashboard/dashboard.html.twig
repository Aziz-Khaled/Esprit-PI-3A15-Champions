let allTrades = [], histFilter = 'ALL';
function loadHistory() {
  const body = document.getElementById('histTableBody');
  if (!body) return;
  body.innerHTML = '<div class="hist-empty"><div class="spin" style="width:24px;height:24px;"></div><div>Loading…</div></div>';
  fetch('{{ path('app_trading_api_history') }}').then(r => r.json()).then(data => {
    allTrades = Array.isArray(data) ? data : [];
    updateHistSummary();
    renderHistory();
  }).catch(() => { body.innerHTML = '<div class="hist-empty"><div>Failed to load history.</div></div>'; });
}
function updateHistSummary() {
  document.getElementById('hsTotalTrades').textContent = allTrades.length;
  document.getElementById('hsTotalBuy').textContent = allTrades.filter(t => t.trade_type === 'BUY').length;
  document.getElementById('hsTotalSell').textContent = allTrades.filter(t => t.trade_type === 'SELL').length;
  document.getElementById('hsCompleted').textContent = allTrades.filter(t => t.status === 'COMPLETED').length;
  document.getElementById('hsPending').textContent = allTrades.filter(t => t.status === 'PENDING').length;
}
function filterHistory(f, btn) {
  histFilter = f;
  document.querySelectorAll('.hf-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderHistory();
}
function renderHistory() {
  const q = (document.getElementById('histSearch')?.value || '').toLowerCase();
  const body = document.getElementById('histTableBody');
  if (!body) return;
  let rows = allTrades.filter(t => (histFilter === 'ALL' ? true : histFilter === 'BUY' ? t.trade_type === 'BUY' : histFilter === 'SELL' ? t.trade_type === 'SELL' : histFilter === 'COMPLETED' ? t.status === 'COMPLETED' : histFilter === 'PENDING' ? t.status === 'PENDING' : true) && (!q || (t.symbol||'').toLowerCase().includes(q)));
  if (!rows.length) { body.innerHTML = '<div class="hist-empty"><div>No trades match.</div></div>'; return; }
  body.innerHTML = rows.map(t => `<div class="hist-row"><span>#${t.id}</span><span class="hr-sym">${t.symbol}</span><span class="hr-type ${(t.trade_type||'').toLowerCase()}">${t.trade_type}</span><span>${fmt(parseFloat(t.price))}</span><span>${parseFloat(t.quantity).toLocaleString()}</span><span>${fmt(parseFloat(t.price)*parseFloat(t.quantity))}</span><span><span class="hr-mode ${(t.order_mode||'market').toLowerCase()}">${(t.order_mode||'MARKET').toUpperCase()}</span></span><span><span class="hr-status ${(t.status||'').toLowerCase()}">${t.status}</span></span><span>${t.date}</span></div>`).join('');
}

