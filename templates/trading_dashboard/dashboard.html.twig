function fetchNews() {
  const box = document.getElementById('newsList');
  if (!box) return;
  box.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:11px;">Chargement des news…</div>';
 
  fetch('{{ path('app_trading_api_news') }}')
    .then(r => {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(arts => {
      if (!Array.isArray(arts) || arts.length === 0) {
        box.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:11px;">Aucune news disponible.<br><small>Vérifiez votre clé NewsAPI.</small></div>';
        return;
      }
 
      // ✅ FIX: filtre les articles sans titre + affiche 6 news avec image optionnelle
      const valid = arts.filter(a => a.title && a.title !== '[Removed]').slice(0, 6);
 
      box.innerHTML = valid.map(a => {
        const date = a.publishedAt ? new Date(a.publishedAt).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '';
        return `
          <a class="news-card" href="${a.url || '#'}" target="_blank" rel="noopener">
            <div class="news-card-t">${escapeHtml(a.title)}</div>
            <div class="news-card-m">${escapeHtml(a.source || '')} · ${date}</div>
          </a>
        `;
      }).join('');
    })
    .catch(err => {
      box.innerHTML = `<div style="padding:12px 14px;color:var(--muted);font-size:11px;">Erreur chargement news.<br><small>${err.message}</small></div>`;
      console.warn('News fetch error:', err);
    });
}
 
// Helper XSS protection
function escapeHtml(str) {
  if (!str) return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

