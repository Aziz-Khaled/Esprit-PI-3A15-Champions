// BOT
// ════════════════════════════════════════════════

let botOn = false, botTimer = null;
let bTrades = 0, bWins = 0, bPnl = 0, bStrat = 'ma';
let botPosition = null;  // Position actuelle du bot
let botPendingOrders = []; // Ordres pending du bot

const priceHistory = {};
const HISTORY_MAX = 50;

function recordPrice(sym, price) {
    if (!priceHistory[sym]) priceHistory[sym] = [];
    priceHistory[sym].push(price);
    if (priceHistory[sym].length > HISTORY_MAX) priceHistory[sym].shift();
}

function pickStrat(el) {
    document.querySelectorAll('.strat-card').forEach(c => c.classList.remove('sel'));
    el.classList.add('sel');
    bStrat = el.dataset.s;
    botPosition = null; // Reset position quand on change de stratégie
    logLine('it', `Stratégie changée: ${bStrat.toUpperCase()}`);
}

function toggleBot() {
    botOn = !botOn;
    const btn = document.getElementById('botBtn');
    const dot = document.getElementById('lDot');
    const sStat = document.getElementById('sStat');
    
    if (sStat) {
        sStat.textContent = botOn ? '🟢 Running' : 'Idle';
        sStat.style.color = botOn ? 'var(--green)' : 'var(--muted)';
    }
    if (btn) {
        btn.textContent = botOn ? '⏹ Stop Bot' : '▶ Start Bot';
        btn.classList.toggle('stop', botOn);
    }
    if (dot) dot.classList.toggle('live', botOn);
    
    if (botOn) {
        botPosition = null;
        logLine('it', `Bot démarré | Stratégie: ${bStrat.toUpperCase()}`);
        // Charger les ordres pending existants
        loadBotPendingOrders();
        botTimer = setInterval(botTick, 15000); // Vérification toutes les 15 secondes
        botTick();
    } else {
        clearInterval(botTimer);
        logLine('wt', 'Bot arrêté');
    }
}

// Charger les ordres pending du bot depuis la BDD
function loadBotPendingOrders() {
    fetch('{{ path('app_trading_api_bot_pending_orders') }}')
        .then(r => r.json())
        .then(orders => {
            botPendingOrders = orders;
            if (orders.length > 0) {
                logLine('it', `${orders.length} ordre(s) LIMIT pending chargé(s) depuis la BDD`);
                displayBotPendingOrders();
            }
        })
        .catch(err => console.error('Error loading pending orders:', err));
}

// Afficher les ordres pending du bot dans l'UI
function displayBotPendingOrders() {
    const section = document.getElementById('limitOrdersSection');
    const list = document.getElementById('limitPendingList');
    if (!section || !list) return;
    
    if (!botPendingOrders.length) {
        section.style.display = 'none';
        return;
    }
    
    section.style.display = 'flex';
    list.innerHTML = botPendingOrders.map(o => `
        <div class="limit-order-item" id="bot-order-${o.id}">
            <span class="li-sym">${o.symbol}/USDT</span>
            <span>${o.trade_type} ${o.quantity} @ ${fmt(o.target_price)}</span>
            <span style="font-size:9px;color:var(--muted)">bot</span>
        </div>
    `).join('');
}

// Vérifier et exécuter les ordres pending
function checkBotPendingOrders(asset, currentPrice) {
    const pendingForAsset = botPendingOrders.filter(o => 
        o.symbol === asset && o.status !== 'COMPLETED'
    );
    
    for (const order of pendingForAsset) {
        let shouldExecute = false;
        
        if (order.trade_type === 'BUY' && currentPrice <= order.target_price) {
            shouldExecute = true;
            logLine('wt', `Condition remplie pour ordre LIMIT #${order.id}: prix marché (${fmt(currentPrice)}) ≤ prix cible (${fmt(order.target_price)})`);
        } else if (order.trade_type === 'SELL' && currentPrice >= order.target_price) {
            shouldExecute = true;
            logLine('wt', `Condition remplie pour ordre LIMIT #${order.id}: prix marché (${fmt(currentPrice)}) ≥ prix cible (${fmt(order.target_price)})`);
        }
        
        if (shouldExecute) {
            // Exécuter l'ordre via l'API
            fetch('{{ path('app_trading_api_bot_check_execute') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: order.id, currentPrice: currentPrice })
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    logLine('bt', `✅ ORDRE LIMIT EXÉCUTÉ: ${order.trade_type} ${order.quantity} ${order.symbol} @ ${fmt(currentPrice)}`);
                    toast(`🎯 LIMIT ${order.trade_type} exécuté!`, 'ok');
                    document.getElementById('balVal').textContent = '$' + d.newBalance.toFixed(2);
                    
                    // Mettre à jour la position du bot
                    if (order.trade_type === 'BUY') {
                        botPosition = {
                            symbol: order.symbol,
                            entryPrice: currentPrice,
                            quantity: order.quantity,
                            entryTime: new Date()
                        };
                    } else if (order.trade_type === 'SELL') {
                        botPosition = null;
                    }
                    
                    // Retirer de la liste locale
                    botPendingOrders = botPendingOrders.filter(o => o.id !== order.id);
                    displayBotPendingOrders();
                    loadHistory();
                }
            })
            .catch(err => logLine('wt', `Erreur exécution ordre #${order.id}: ${err.message}`));
        }
    }
}

function botTick() {
    if (!botOn) return;
    
    const assetEl = document.getElementById('botAsset');
    if (!assetEl) return;
    const asset = assetEl.value;
    const amtEl = document.getElementById('botAmt');
    const amt = amtEl ? (parseFloat(amtEl.value) || 100) : 100;
    const liveData = priceMap[asset];
    
    if (!liveData) {
        logLine('it', `En attente du prix pour ${asset}/USDT...`);
        return;
    }
    
    const price = liveData.price;
    recordPrice(asset, price);
    
    // Vérifier d'abord les ordres pending existants en BDD
    checkBotPendingOrders(asset, price);
    
    let signal = 'HOLD';
    let reason = '';
    const history = priceHistory[asset] || [];
    
    // Vérifier si on a déjà une position ouverte
    const hasPosition = botPosition && botPosition.symbol === asset;
    
    // ── STRATÉGIE MA CROSSOVER ──
    if (bStrat === 'ma' && history.length >= 20) {
        const ma5 = history.slice(-5).reduce((a, b) => a + b, 0) / 5;
        const ma20 = history.slice(-20).reduce((a, b) => a + b, 0) / 20;
        const prevMa5 = history.length >= 21 ? history.slice(-6, -1).reduce((a, b) => a + b, 0) / 5 : ma5;
        const prevMa20 = history.length >= 21 ? history.slice(-21, -1).reduce((a, b) => a + b, 0) / 20 : ma20;
        
        if (ma5 > ma20 && prevMa5 <= prevMa20 && !hasPosition) {
            signal = 'BUY';
            reason = `MA5(${ma5.toFixed(2)}) croise au-dessus MA20(${ma20.toFixed(2)})`;
        } else if (ma5 < ma20 && prevMa5 >= prevMa20 && hasPosition) {
            signal = 'SELL';
            reason = `MA5(${ma5.toFixed(2)}) croise en-dessous MA20(${ma20.toFixed(2)})`;
        }
    }
    // ── STRATÉGIE RSI ──
    else if (bStrat === 'rsi' && history.length >= 14) {
        let gains = 0, losses = 0;
        for (let i = history.length - 14; i < history.length; i++) {
            if (i === 0) continue;
            const diff = history[i] - history[i - 1];
            if (diff > 0) gains += diff;
            else losses += Math.abs(diff);
        }
        const rs = (gains / 14) / (losses / 14 || 0.001);
        const rsi = 100 - (100 / (1 + rs));
        
        if (rsi < 30 && !hasPosition) {
            signal = 'BUY';
            reason = `RSI=${rsi.toFixed(1)} — Zone survendue`;
        } else if (rsi > 70 && hasPosition) {
            signal = 'SELL';
            reason = `RSI=${rsi.toFixed(1)} — Zone surachetée (fermeture)`;
        }
    }
    // ── STRATÉGIE DCA ──
    else if (bStrat === 'dca' && !hasPosition) {
        signal = 'BUY';
        reason = 'DCA achat programmé';
    }
    
    // ⚠️ IMPORTANT: Créer un ordre LIMIT (PENDING) au lieu d'exécuter MARKET
    if (signal === 'BUY' && !hasPosition) {
        // Prix cible = prix actuel - 0.5% (pour acheter moins cher)
        const targetPrice = price * 0.995;
        const qty = amt / price;
        
        logLine('bt', `📌 Création ordre LIMIT BUY: ${qty.toFixed(6)} ${asset} @ ${fmt(targetPrice)} (marché: ${fmt(price)})`);
        
        fetch('{{ path('app_trading_api_execute_trade') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                symbol: asset,
                tradeType: 'BUY',
                quantity: qty,
                orderMode: 'LIMIT',
                targetPrice: targetPrice,
                currentPrice: price
            })
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                logLine('bt', `✅ Ordre LIMIT BUY créé (ID: ${d.tradeId}) - En attente du marché @ ${fmt(targetPrice)}`);
                toast(`📌 Ordre LIMIT BUY créé pour ${asset}`, 'ok');
                // Recharger les ordres pending
                loadBotPendingOrders();
            } else if (d.error) {
                logLine('wt', `Erreur: ${d.error}`);
            }
        })
        .catch(err => logLine('wt', `Erreur API: ${err.message}`));
    }
    else if (signal === 'SELL' && hasPosition) {
        // Prix cible = prix actuel + 0.5% (pour vendre plus cher)
        const targetPrice = price * 1.005;
        const qty = botPosition.quantity;
        
        logLine('st', `📌 Création ordre LIMIT SELL: ${qty.toFixed(6)} ${asset} @ ${fmt(targetPrice)} (marché: ${fmt(price)})`);
        
        fetch('{{ path('app_trading_api_execute_trade') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                symbol: asset,
                tradeType: 'SELL',
                quantity: qty,
                orderMode: 'LIMIT',
                targetPrice: targetPrice,
                currentPrice: price
            })
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                logLine('st', `✅ Ordre LIMIT SELL créé (ID: ${d.tradeId}) - En attente du marché @ ${fmt(targetPrice)}`);
                toast(`📌 Ordre LIMIT SELL créé pour ${asset}`, 'ok');
                loadBotPendingOrders();
            } else if (d.error) {
                logLine('wt', `Erreur: ${d.error}`);
            }
        })
        .catch(err => logLine('wt', `Erreur API: ${err.message}`));
    }
}
function updateBotStats() {
    // Utiliser la nouvelle route
    fetch('{{ path('app_trading_api_bot_stats_real') }}')
        .then(r => r.json())
        .then(stats => {
            const sTrades = document.getElementById('sTrades');
            const sWin = document.getElementById('sWin');
            const sPnl = document.getElementById('sPnl');
            const sStat = document.getElementById('sStat');
            
            if (sTrades && stats.tradesToday) sTrades.textContent = stats.tradesToday;
            if (sWin && stats.winRate) sWin.textContent = stats.winRate + '%';
            if (sPnl && stats.pnl) {
                sPnl.textContent = (stats.pnl >= 0 ? '+' : '') + '$' + stats.pnl.toFixed(2);
                sPnl.className = 'stat-v ' + (stats.pnl >= 0 ? 'g' : 'r');
            }
            if (sStat && stats.pendingOrders > 0) {
                sStat.innerHTML = `🟢 Running (${stats.pendingOrders} pending)`;
            }
        })
        .catch(() => {});
}


function logLine(cls, msg) {
  const box = document.getElementById('logList');
  if (!box) return;
 
  const now = new Date().toLocaleTimeString('fr-FR', { hour12: false });
  const map = { bt: 'bt', st: 'st', it: 'it', wt: 'wt' };
  const lbl = { bt: '[BUY]', st: '[SELL]', it: '[INFO]', wt: '[WARN]' };
 
  const d = document.createElement('div');
  d.className = 'll';
  d.innerHTML = `<span class="ts">${now}</span><span class="${map[cls] || 'it'}">${lbl[cls] || '[INFO]'}</span> ${escapeHtml(msg)}`;
  box.appendChild(d);
 
  // ✅ FIX: scroll automatique vers le bas
  box.scrollTop = box.scrollHeight;
 
  // ✅ Limite à 200 lignes pour éviter la surcharge mémoire
  const lines = box.querySelectorAll('.ll');
  if (lines.length > 200) lines[0].remove();
}

function executeBotTradeWithLog(asset, signal, entryPrice, amt, reason) {
  const qty = amt / entryPrice;
 
  logLine(signal === 'BUY' ? 'bt' : 'st',
    `${signal} ${asset}/USDT | Qty: ${qty.toFixed(6)} | Prix: ${fmt(entryPrice)} | Raison: ${reason}`
  );
 
  fetch('{{ path('app_trading_api_execute_trade') }}', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      symbol: asset,
      tradeType: signal,
      quantity: parseFloat(qty.toFixed(6)),
      orderMode: 'MARKET',
      currentPrice: entryPrice,
    }),
  })
  .then(r => r.json())
  .then(d => {
    if (d.error) {
      logLine('wt', `❌ Erreur trade bot: ${d.error}`);
      toast(d.error, 'err');
      return;
    }
 
    // ✅ FIX WALLET: mise à jour immédiate après trade bot
    const newBal = d.newBalance ?? d.balance;
    if (newBal !== undefined && !isNaN(parseFloat(newBal))) {
      updateBalanceDisplay(newBal);
      logLine('it', `💰 Wallet mis à jour: ${formatBalance(newBal)}`);
    }
 
    // Mise à jour stats bot
    bTrades++;
    const pnl = (Math.random() * 6 - 2); // simulation P&L %
    bPnl += amt * pnl / 100;
    if (pnl > 0) bWins++;
 
    const pnlEl = document.getElementById('sPnl');
    if (pnlEl) {
      pnlEl.textContent = (bPnl >= 0 ? '+' : '') + '$' + bPnl.toFixed(2);
      pnlEl.className = 'stat-v ' + (bPnl >= 0 ? 'g' : 'r');
    }
    const tradesEl = document.getElementById('sTrades');
    if (tradesEl) tradesEl.textContent = bTrades;
    const winEl = document.getElementById('sWin');
    if (winEl) winEl.textContent = Math.round(bWins / bTrades * 100) + '%';
 
    logLine('it', `P&L session: ${bPnl >= 0 ? '+' : ''}$${bPnl.toFixed(2)} | Win rate: ${Math.round(bWins/bTrades*100)}%`);
  })
  .catch(err => {
    logLine('wt', `❌ Erreur réseau bot: ${err.message}`);
  });
}


