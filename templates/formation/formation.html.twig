<div id="enrollModal" class="modal-backdrop-custom" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 9999; justify-content: center; align-items: center;" onclick="window.closeModalBg(event,'enrollModal')">
