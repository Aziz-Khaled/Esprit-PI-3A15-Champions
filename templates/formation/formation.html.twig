      </div>

      <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 0; border-bottom:1px solid var(--border); margin-bottom:20px">
        <div>
          <div style="font-size:11px; text-transform:uppercase; color:var(--text-3)">Total Cost</div>
          <div id="modal-formation-price" style="font-size:1.8rem; font-weight:800; color:var(--accent)">—</div>
        </div>
      </div>

      <form method="POST" action="{{ path('app_formation_enroll') }}" id="enrollForm">
        <input type="hidden" name="formation_id" id="modal-formation-id">

        <div class="field" style="margin-bottom: 15px;">
          <label class="f-label" style="display: block; margin-bottom: 8px;">Select Your Fiat Wallet</label>
