  }
  .modal-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 12px 30px rgba(0,229,255,.3); }
  .modal-btn-primary:disabled { background: rgba(255,255,255,.08); color: var(--text-3); cursor: not-allowed; transform: none; box-shadow: none; }
  .modal-btn-secondary {
    width: 100%; padding: 13px; margin-top: 8px; background: transparent;
    border: 1px solid var(--border); border-radius: 11px; color: var(--text-2);
    font-family: var(--font-body); font-weight: 600; font-size: 15px; cursor: pointer; transition: all .2s;
  }
  .modal-btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

