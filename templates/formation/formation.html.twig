{% extends 'base.html.twig' %}

{% block title %}Champions — Formations{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --bg-card2:     #111b2b;
    --border:       #1a2a40;
    --border-glow:  rgba(0,229,255,.15);
    --accent:       #00e5ff;
    --accent2:      #00b4cc;
    --accent-glow:  rgba(0,229,255,.18);
    --gold:         #f0b429;
    --gold-dim:     rgba(240,180,41,.10);
    --green:        #00e676;
    --green-dim:    rgba(0,230,118,.10);
    --red:          #ff1744;
    --red-dim:      rgba(255,23,68,.10);
    --text-1:       #f0f4ff;
    --text-2:       #b0bdd0;
    --text-3:       #5a7090;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
    --navbar-h:     64px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--bg-base);
    color: var(--text-1);
    min-height: 100vh;
    overflow-x: hidden;
  }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 3px; }

  .bg-grid {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      linear-gradient(rgba(0,229,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,.03) 1px, transparent 1px);
    background-size: 52px 52px;
    animation: gridDrift 25s linear infinite;
  }
  @keyframes gridDrift { 0% { background-position: 0 0; } 100% { background-position: 52px 52px; } }

  .bg-orb { position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; }
  .bg-orb-1 {
    width: 600px; height: 600px; top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(0,229,255,.08) 0%, transparent 70%);
    animation: orbFloat 10s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 440px; height: 440px; bottom: -160px; right: -100px;
    background: radial-gradient(circle, rgba(240,180,41,.07) 0%, transparent 70%);
    animation: orbFloat 14s ease-in-out infinite alternate-reverse;
  }
  @keyframes orbFloat { from { transform: translate(0,0) scale(1); } to { transform: translate(28px,18px) scale(1.06); } }

  .app-shell { display: flex; flex-direction: column; min-height: 100vh; position: relative; z-index: 1; }

  /* ── NAVBAR ── */
  .topnav {
    position: sticky; top: 0; z-index: 200; height: var(--navbar-h);
    background: rgba(8,13,20,.97); border-bottom: 1px solid var(--border);
    backdrop-filter: blur(20px);
    display: flex; align-items: center; padding: 0 32px; gap: 0; overflow: hidden;
  }
  .topnav::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.25;
  }
  .topnav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; margin-right: 36px; }
  .logo-icon {
    width: 34px; height: 34px; border-radius: 9px;
    background: linear-gradient(135deg, #1de9b6, #00b4cc);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px; color: #080d14; font-family: var(--font-head);
    box-shadow: 0 0 16px rgba(0,229,255,.3); flex-shrink: 0;
  }
  .logo-text {
    font-family: var(--font-head); font-size: 18px; font-weight: 700;
    background: linear-gradient(90deg, var(--text-1), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .topnav-links { display: flex; align-items: center; gap: 2px; flex: 1; overflow-x: auto; scrollbar-width: none; }
  .topnav-links::-webkit-scrollbar { display: none; }
  .nav-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 10px; text-decoration: none; color: var(--text-1);
    font-size: 14px; font-weight: 500; transition: all .2s ease; position: relative;
    white-space: nowrap; background: none; border: none; cursor: pointer;
    font-family: var(--font-body); text-align: left; flex-shrink: 0;
  }
  .nav-btn i { font-size: 13px; flex-shrink: 0; }
  .nav-btn:hover { color: var(--text-1); background: rgba(255,255,255,.05); }
  .nav-btn.active { color: var(--accent); background: rgba(0,229,255,.08); border: 1px solid rgba(0,229,255,.15); }
  .nav-btn.active i { color: var(--accent); }
  .nav-btn .nav-badge {
    padding: 1px 7px; border-radius: 20px; background: rgba(0,229,255,.12); color: var(--accent);
    font-size: 10.5px; font-weight: 700; font-family: var(--font-mono); flex-shrink: 0;
  }
  .nav-btn.danger { color: var(--red); }
  .nav-btn.danger:hover { background: rgba(255,23,68,.08); color: var(--red); }
  .topnav-sep { width: 1px; height: 24px; background: var(--border); margin: 0 8px; flex-shrink: 0; }
  .topnav-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-left: 16px; }
  .user-card {
    display: flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 10px;
    background: rgba(255,255,255,.03); border: 1px solid var(--border); cursor: pointer; transition: border-color .2s;
  }
  .user-card:hover { border-color: rgba(0,229,255,.2); }
  .user-avatar {
    width: 28px; height: 28px; border-radius: 8px;
    background: linear-gradient(135deg, rgba(0,229,255,.2), rgba(0,180,204,.2));
    border: 1px solid rgba(0,229,255,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--accent); flex-shrink: 0;
  }
  .user-info { line-height: 1.25; }
  .user-name { font-size: 13px; font-weight: 600; color: var(--text-1); }
  .user-role { font-size: 10.5px; color: var(--text-3); font-family: var(--font-mono); }

  /* ── TICKER ── */
  .ticker-wrap { width: 100%; background: rgba(8,13,20,.95); border-top: 1px solid var(--border); height: 38px; overflow: hidden; flex-shrink: 0; }
  .ticker-track { display: flex; align-items: center; height: 100%; white-space: nowrap; animation: tickerScroll 35s linear infinite; width: max-content; }
  .ticker-item { display: inline-flex; align-items: center; gap: 6px; padding: 0 28px; font-size: 13px; font-family: var(--font-mono); color: var(--text-2); border-right: 1px solid var(--border); }
  .ticker-item .sym { color: var(--accent); font-weight: 600; }
  .ticker-item .up { color: var(--green); }
  .ticker-item .dn { color: var(--red); }
  @keyframes tickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── MAIN CONTENT ── */
  .main-content { flex: 1; padding: 36px 48px 60px; display: flex; flex-direction: column; gap: 28px; }

  /* ── PAGE HEADER ── */
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .page-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
  .page-title { font-family: var(--font-head); font-size: 32px; font-weight: 800; line-height: 1.1; letter-spacing: -.02em; margin-bottom: 6px; }
  .page-sub { font-size: 15px; color: var(--text-2); }
  .header-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  /* ── FLASH MESSAGES ── */
  .flash-msg {
    padding: 14px 18px; border-radius: 12px; font-size: 15px; font-weight: 500;
    display: flex; align-items: center; gap: 10px; animation: fadeSlide .3s ease both;
  }
  @keyframes fadeSlide { from { opacity:0; transform: translateY(-6px); } to { opacity:1; transform: translateY(0); } }
  .flash-msg.success { background: rgba(0,230,118,.1); border: 1px solid rgba(0,230,118,.25); color: var(--green); }
  .flash-msg.error   { background: rgba(255,23,68,.1);  border: 1px solid rgba(255,23,68,.25);  color: var(--red); }
  .flash-close { margin-left: auto; cursor: pointer; opacity: .6; font-size: 16px; background: none; border: none; color: inherit; }

  /* ── STATS ROW ── */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px 24px; position: relative; overflow: hidden; transition: border-color .25s, transform .2s; }
  .stat-card:hover { border-color: rgba(0,229,255,.2); transform: translateY(-1px); }
  .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; border-radius: var(--radius) var(--radius) 0 0; }
  .stat-card.cyan::before  { background: linear-gradient(90deg, var(--accent), transparent); }
  .stat-card.gold::before  { background: linear-gradient(90deg, var(--gold), transparent); }
  .stat-card.green::before { background: linear-gradient(90deg, var(--green), transparent); }
  .stat-card.red::before   { background: linear-gradient(90deg, var(--red), transparent); }
  .stat-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 14px; }
  .stat-icon.cyan  { background: rgba(0,229,255,.1);  color: var(--accent); }
  .stat-icon.gold  { background: rgba(240,180,41,.1); color: var(--gold); }
  .stat-icon.green { background: rgba(0,230,118,.1);  color: var(--green); }
  .stat-icon.red   { background: rgba(255,23,68,.1);  color: var(--red); }
  .stat-label { font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); margin-bottom: 6px; }
  .stat-value { font-family: var(--font-head); font-size: 28px; font-weight: 700; color: var(--text-1); }

  /* ── FILTER BAR ── */
  .filter-bar {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 18px 24px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    position: relative;
  }
  .filter-bar::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    border-radius: var(--radius) var(--radius) 0 0;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.3;
  }
  .filter-label { font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-3); white-space: nowrap; }
  .f-input-search {
    flex: 1; min-width: 200px; padding: 10px 15px;
    background: rgba(0,0,0,.25); border: 1px solid rgba(90,112,144,.3);
    border-radius: 10px; color: var(--text-1); font-size: 14px; font-family: var(--font-body);
    outline: none; transition: border-color .2s, box-shadow .2s;
  }
  .f-input-search:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,229,255,.1); }
  .f-select-filter {
    padding: 10px 15px; background: rgba(0,0,0,.25); border: 1px solid rgba(90,112,144,.3);
    border-radius: 10px; color: var(--text-1); font-size: 14px; font-family: var(--font-body);
    outline: none; transition: border-color .2s; cursor: pointer; -webkit-appearance: none;
  }
  .f-select-filter:focus { border-color: var(--accent); }
  .f-select-filter option { background: #111b2b; }
  .btn-filter-apply {
    display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 10px;
    font-size: 14px; font-weight: 600; font-family: var(--font-body);
    background: var(--accent); color: #080d14; border: none; cursor: pointer;
    transition: opacity .2s, transform .15s; white-space: nowrap;
  }
  .btn-filter-apply:hover { opacity: .88; transform: translateY(-1px); }
  .btn-filter-reset {
    display: inline-flex; align-items: center; gap: 7px; padding: 10px 16px; border-radius: 10px;
    font-size: 14px; font-weight: 500; font-family: var(--font-body);
    background: transparent; color: var(--text-2); border: 1px solid var(--border);
    cursor: pointer; transition: all .2s; text-decoration: none; white-space: nowrap;
  }
  .btn-filter-reset:hover { border-color: var(--red); color: var(--red); background: rgba(255,23,68,.06); }
  .results-count { font-family: var(--font-mono); font-size: 12px; color: var(--text-3); white-space: nowrap; margin-left: auto; }
  .results-count strong { color: var(--accent); }

  /* ── FORMATIONS GRID ── */
  .formations-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; }

  /* ── FORMATION CARD ── */
  .formation-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    overflow: hidden; transition: border-color .25s, transform .2s; display: flex; flex-direction: column;
    position: relative;
  }
  .formation-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    border-radius: var(--radius) var(--radius) 0 0;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity .25s;
  }
  .formation-card:hover { border-color: rgba(0,229,255,.2); transform: translateY(-2px); }
  .formation-card:hover::before { opacity: 1; }

  .card-img-wrap {
    width: 100%; height: 148px;
    background: linear-gradient(135deg, #0a1628 0%, #0e1f38 50%, #091420 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; color: var(--accent); overflow: hidden; flex-shrink: 0; position: relative;
  }
  .card-img-wrap::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, rgba(0,229,255,.06) 0%, transparent 70%);
  }
  .card-img-wrap i { opacity: 0.4; position: relative; z-index: 1; }
  .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; opacity: 1; }

  .card-body { padding: 18px; flex: 1; display: flex; flex-direction: column; }

  .card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; margin-bottom: 10px; }
  .card-title { font-family: var(--font-head); font-size: 15px; font-weight: 700; color: var(--text-1); line-height: 1.3; }

  .statut-badge { padding: 4px 11px; border-radius: 20px; font-size: 11px; font-weight: 700; font-family: var(--font-mono); letter-spacing: .06em; white-space: nowrap; flex-shrink: 0; }
  .statut-OUVERTE  { background: rgba(0,230,118,.12); color: var(--green); border: 1px solid rgba(0,230,118,.2); }
  .statut-COMPLETE { background: rgba(240,180,41,.12); color: var(--gold);  border: 1px solid rgba(240,180,41,.2); }
  .statut-ANNULEE  { background: rgba(255,23,68,.12);  color: var(--red);   border: 1px solid rgba(255,23,68,.2); }

  .card-domaine {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11px; color: var(--accent); background: rgba(0,229,255,.08);
    border: 1px solid rgba(0,229,255,.12); border-radius: 6px; padding: 3px 10px;
    margin-bottom: 10px; width: fit-content; font-family: var(--font-mono);
  }

  .card-desc {
    font-size: 13.5px; color: var(--text-2); line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; margin-bottom: 14px; flex: 1;
  }

  .card-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 14px; }
  .meta-item { display: flex; align-items: center; gap: 6px; font-size: 12.5px; color: var(--text-3); }
  .meta-item i { color: var(--accent); width: 13px; font-size: 11px; }

  .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 13px; border-top: 1px solid var(--border); }
  .card-price { font-family: var(--font-head); font-size: 1.25rem; font-weight: 700; color: var(--text-1); }
  .card-price small { font-size: 0.68rem; font-weight: 400; color: var(--text-3); font-family: var(--font-body); }

  .btn-enroll-card {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 18px; border-radius: 9px; font-size: 13px; font-weight: 600;
    font-family: var(--font-body); background: var(--accent); color: #080d14;
    border: none; cursor: pointer; transition: all .2s; white-space: nowrap;
  }
  .btn-enroll-card:hover { opacity: .88; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,229,255,.25); }
  .btn-enroll-card.disabled { background: rgba(255,255,255,.06); color: var(--text-3); cursor: not-allowed; transform: none; box-shadow: none; }

  /* ── EMPTY STATE ── */
  .empty-state {
    grid-column: 1/-1; text-align: center; padding: 80px 20px;
    border: 1px dashed rgba(26,42,64,.8); border-radius: var(--radius);
  }
  .empty-state i { font-size: 3rem; color: var(--text-3); opacity: .3; margin-bottom: 14px; display: block; }
  .empty-state p { color: var(--text-3); font-size: 15px; }

  /* ── MODALS ── */
  .modal-backdrop-custom {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(4,8,16,.85); backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    padding: 20px; animation: fadeIn .2s ease both;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .modal-box {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 22px; width: 100%; max-width: 480px;
    position: relative; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,.7);
    animation: modalIn .3s cubic-bezier(.22,1,.36,1) both;
  }
  @keyframes modalIn { from { opacity: 0; transform: translateY(16px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  .modal-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
    opacity: 0.5;
  }
  .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 24px 28px 20px; border-bottom: 1px solid var(--border); }
  .modal-title { font-family: var(--font-head); font-size: 20px; font-weight: 700; display: flex; align-items: center; gap: 10px; }
  .modal-title-icon { width: 32px; height: 32px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 14px; }
  .modal-close { width: 30px; height: 30px; border-radius: 8px; background: rgba(255,255,255,.05); border: 1px solid var(--border); color: var(--text-2); cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; transition: all .2s; }
  .modal-close:hover { background: rgba(255,23,68,.1); border-color: rgba(255,23,68,.25); color: var(--red); }
  .modal-body { padding: 24px 28px 28px; }

  /* formation details in modal */
  .modal-formation-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
  .detail-box { background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: 10px; padding: 13px; }
  .detail-box .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-3); margin-bottom: 4px; font-weight: 700; }
  .detail-box .val { font-family: var(--font-head); font-size: 14px; font-weight: 700; color: var(--text-1); }
  .modal-desc-text { font-size: 14px; color: var(--text-2); line-height: 1.7; margin-bottom: 20px; }
  .modal-price-row { display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid var(--border); margin-bottom: 20px; }
  .modal-price-val { font-family: var(--font-head); font-size: 2rem; font-weight: 800; color: var(--accent); }
  .modal-price-val small { font-size: 0.85rem; color: var(--text-3); font-family: var(--font-body); font-weight: 400; }

  /* ── FORM ELEMENTS ── */
  .field { margin-bottom: 18px; }
  .f-label { display: block; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 7px; }
  .f-input, .f-select {
    width: 100%; padding: 12px 15px; background: rgba(0,0,0,.25);
    border: 1px solid rgba(90,112,144,.3); border-radius: 10px; color: var(--text-1);
    font-size: 15px; font-family: var(--font-body); outline: none;
    transition: border-color .2s, box-shadow .2s; -webkit-appearance: none;
  }
  .f-input:focus, .f-select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,229,255,.1); }
  .f-select option { background: #111b2b; }
  .f-input[readonly] { opacity: .5; cursor: default; }

  .balance-preview {
    background: rgba(0,229,255,.05); border: 1px solid rgba(0,229,255,.15);
    border-radius: 10px; padding: 14px 16px; margin-bottom: 16px;
    display: none;
  }
  .balance-preview.show { display: block; }
  .balance-preview-label { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 5px; }
  .balance-preview-value { font-family: var(--font-head); font-size: 22px; font-weight: 700; color: var(--accent); }
  .balance-preview-currency { font-size: 13px; color: var(--text-3); font-family: var(--font-mono); }

  .modal-btn-primary {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);
