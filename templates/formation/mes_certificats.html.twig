{% extends 'base.html.twig' %}

{% block title %}Champions — Mes Certificats{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
  :root {
    --bg-base:      #080d14;
    --bg-card:      #0e1623;
    --border:       #1a2a40;
    --accent:       #00e5ff;
    --gold:         #f0b429;
    --text-1:       #f0f4ff;
    --text-2:       #b0bdd0;
    --text-3:       #5a7090;
    --font-head:    'Syne', sans-serif;
    --font-body:    'Space Grotesk', sans-serif;
    --font-mono:    'DM Mono', monospace;
    --radius:       16px;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg-base);
    color: var(--text-1);
    min-height: 100vh;
  }

  .main-content {
    padding: 36px 48px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header { margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; }
  .page-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
  .page-title { font-family: var(--font-head); font-size: 32px; font-weight: 800; line-height: 1.1; margin-bottom: 6px; }
  .page-sub { font-size: 15px; color: var(--text-2); }

  .btn-back {
    display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px;
    border-radius: 10px; font-size: 14px; font-weight: 600; font-family: var(--font-body);
    background: rgba(255,255,255,.05); color: var(--text-1); border: 1px solid var(--border);
    text-decoration: none; transition: all .2s;
  }
  .btn-back:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.2); color: #fff; }

  .cert-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px;
  }

  .cert-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 24px; position: relative; overflow: hidden; transition: transform .2s, border-color .2s;
  }
  .cert-card:hover {
    transform: translateY(-3px); border-color: rgba(240,180,41,.3);
  }
  .cert-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .cert-icon {
    width: 48px; height: 48px; border-radius: 12px; background: rgba(240,180,41,.1);
    color: var(--gold); display: flex; align-items: center; justify-content: center;
    font-size: 24px; margin-bottom: 16px;
  }

  .cert-title {
    font-family: var(--font-head); font-size: 18px; font-weight: 700; color: var(--text-1);
    margin-bottom: 8px; line-height: 1.3;
  }
  
  .cert-meta { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--text-3); margin-bottom: 16px; }
  .cert-meta i { color: var(--accent); }

  .cert-mention {
    display: inline-block; padding: 4px 10px; background: rgba(0,229,255,.1);
    border: 1px solid rgba(0,229,255,.2); color: var(--accent); border-radius: 6px;
    font-size: 12px; font-weight: 600; margin-bottom: 20px;
  }

  .btn-download {
    display: inline-flex; align-items: center; gap: 8px; padding: 10px 0;
    color: var(--gold); font-size: 14px; font-weight: 600; text-decoration: none;
    transition: color .2s; border-top: 1px solid var(--border); width: 100%;
  }
  .btn-download:hover { color: #fff; }

  .empty-state { text-align: center; padding: 60px 20px; border: 1px dashed var(--border); border-radius: var(--radius); }
  .empty-state i { font-size: 40px; color: var(--text-3); margin-bottom: 16px; opacity: 0.5; }
  .empty-state p { color: var(--text-2); font-size: 16px; }
</style>
{% endblock %}

{% block body %}
<div class="main-content">
    <div class="page-header">
      <div>
        <div class="page-label">Récompenses</div>
        <div class="page-title">Mes Certificats</div>
        <div class="page-sub">Consultez et téléchargez vos certificats de formation.</div>
      </div>
      <div>
          <a href="{{ path('app_formations_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Retour aux formations</a>
      </div>
    </div>

    {% if certificats is empty %}
        <div class="empty-state">
            <i class="fas fa-award"></i>
            <p>Vous n'avez pas encore de certificat. Participez à une formation pour obtenir votre premier certificat !</p>
        </div>
    {% else %}
        <div class="cert-grid">
            {% for cert in certificats %}
                <div class="cert-card">
                    <div class="cert-icon"><i class="fas fa-certificate"></i></div>
                    <div class="cert-title">{{ cert.participation.formation.titre ?? 'Formation sans titre' }}</div>
                    
                    <div class="cert-meta">
                        <span><i class="far fa-calendar-alt"></i> Obtenu le {{ cert.dateEmission|date('d/m/Y') }}</span>
                    </div>

                    {% if cert.mention %}
                        <div class="cert-mention"><i class="fas fa-star"></i> Mention : {{ cert.mention }}</div>
                    {% else %}
                        <div class="cert-mention" style="color:var(--text-3); background: rgba(255,255,255,0.05); border-color: var(--border);"><i class="fas fa-check"></i> Validé</div>
                    {% endif %}

                    <a href="{{ path('app_formations_certificat_pdf', {id: cert.idCertificat}) }}" class="btn-download" target="_blank">
                        <i class="fas fa-file-pdf"></i> Obtenir mon certificat PDF
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
